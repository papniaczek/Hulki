@model Hulki.Web.Models.DailyReport

@{
    ViewData["Title"] = "Szczegóły Wpisu";

    var attachment = Model.ReportAttachments?.FirstOrDefault();

    bool isImage = attachment != null &&
                   (attachment.FilePath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) ||
                    attachment.FilePath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase) ||
                    attachment.FilePath.EndsWith(".png", StringComparison.OrdinalIgnoreCase));

    string modalId = "attachmentModal_" + Model.Id.ToString("N");

    string statusColor = Model.ReportStatus?.Name switch
    {
        "Zatwierdzony" => "#46CC5E",
        "Odrzucony" => "#dc3545",
        _ => "#adb5bd"
    };

    string statusBg = Model.ReportStatus?.Name switch
    {
        "Zatwierdzony" => "rgba(70,204,94,0.12)",
        "Odrzucony" => "rgba(220,53,69,0.12)",
        _ => "rgba(108,117,125,0.12)"
    };

    string statusBorder = Model.ReportStatus?.Name switch
    {
        "Zatwierdzony" => "rgba(70,204,94,0.3)",
        "Odrzucony" => "rgba(220,53,69,0.3)",
        _ => "rgba(108,117,125,0.3)"
    };

    string statusIcon = Model.ReportStatus?.Name switch
    {
        "Zatwierdzony" => "bi-check-circle-fill",
        "Odrzucony" => "bi-x-circle-fill",
        _ => "bi-hourglass-split"
    };
}

<div class="container mt-4">

    <!-- ALERTY -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success border-0 shadow-sm rounded-3 mb-3">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger border-0 shadow-sm rounded-3 mb-3">
            @TempData["ErrorMessage"]
        </div>
    }

    <!-- HEADER -->
    <div class="report-header-card mb-4 p-4 p-md-5 position-relative overflow-hidden rounded-4">
        <div class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">

            <div class="d-flex align-items-center gap-4">
                <div class="report-avatar">
                    <i class="bi bi-journal-check text-success fs-2"></i>
                </div>
                <div>
                    <h2 class="fw-bold text-light mb-1">
                        Wpis z dnia @Model.CreatedAt.ToString("dd.MM.yyyy")
                    </h2>
                    <p class="text-muted mb-0 small">
                        <i class="bi bi-clock me-1 text-success"></i>
                        Godzina: @Model.CreatedAt.ToString("HH:mm:ss")
                    </p>
                </div>
            </div>

            <div class="d-flex align-items-center gap-3">
                <span class="badge rounded-pill px-3 py-2 fs-6"
                      style="background:@statusBg; color:@statusColor; border:1px solid @statusBorder;">
                    <i class="bi @statusIcon me-1"></i>
                    @Model.ReportStatus?.Name
                </span>

                <a asp-action="PatientDetails" asp-route-id="@Model.AppUserId"
                   class="btn btn-back fw-bold rounded-pill px-4 py-2">
                    <i class="bi bi-arrow-left me-1"></i> Profil
                </a>
            </div>
        </div>

        <div class="header-glow"></div>
    </div>

    <div class="row g-4">

        <!-- PACJENT -->
        <div class="col-md-4">
            <div class="detail-card rounded-4 overflow-hidden">
                <div class="detail-card-header px-4 py-3">
                    <h6 class="mb-0 fw-bold text-uppercase" style="letter-spacing:1px;font-size:0.78rem;">
                        <i class="bi bi-person me-2 text-success"></i> Pacjent
                    </h6>
                </div>

                <div class="p-4">
                    <div class="d-flex align-items-center gap-3 mb-4">
                        <div class="mini-avatar">
                            <i class="bi bi-person-circle text-success fs-4"></i>
                        </div>

                        <div>
                            <h5 class="fw-bold mb-0 text-light">
                                @Model.AppUser?.FirstName @Model.AppUser?.LastName
                            </h5>
                            <p class="text-muted small mb-0">
                                <i class="bi bi-envelope me-1"></i>
                                @Model.AppUser?.Email
                            </p>
                        </div>
                    </div>

                    <a asp-action="PatientDetails" asp-route-id="@Model.AppUserId"
                       class="btn btn-custom-success w-100 fw-bold rounded-pill">
                        <i class="bi bi-eye me-1"></i> Pokaż profil
                    </a>
                </div>
            </div>
        </div>

        <!-- WPIS -->
        <div class="col-md-8">
            <div class="detail-card rounded-4 overflow-hidden">

                <div class="detail-card-header px-4 py-3">
                    <h6 class="mb-0 fw-bold text-uppercase" style="letter-spacing:1px;font-size:0.78rem;">
                        <i class="bi bi-chat-left-text me-2 text-success"></i> Odpowiedź pacjenta
                    </h6>
                </div>

                <div class="p-4">

                    <div class="content-box rounded-3 p-4 mb-4">
                        <p class="mb-0 text-light lh-lg" style="white-space:pre-line;">
                            @Model.Content
                        </p>
                    </div>

                    @if (attachment != null)
                    {
                        <div class="mb-4">
                            <p class="text-muted small text-uppercase fw-bold mb-2">
                                <i class="bi bi-paperclip me-1 text-success"></i> Załącznik
                            </p>

                            @if (isImage)
                            {
                                <div class="attachment-chip d-inline-flex align-items-center rounded-3 p-3 gap-2"
                                     style="cursor:pointer;"
                                     data-bs-toggle="modal"
                                     data-bs-target="#@modalId">

                                    <i class="bi bi-image text-success fs-4"></i>
                                    <span class="text-light small fw-semibold">
                                        @attachment.FileName
                                    </span>
                                    <i class="bi bi-eye text-muted small"></i>
                                </div>

                                <script>
                                    (function () {
                                        var modalId = '@modalId';
                                        var filePath = '@attachment.FilePath';

                                        if (!document.getElementById(modalId)) {
                                            var modalHtml =
                                                '<div class="modal fade" id="' + modalId + '" tabindex="-1">' +
                                                '<div class="modal-dialog modal-dialog-centered modal-lg">' +
                                                '<div class="modal-content bg-transparent border-0">' +
                                                '<div class="text-end mb-2">' +
                                                '<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>' +
                                                '</div>' +
                                                '<div class="modal-body p-0 text-center">' +
                                                '<img src="' + filePath + '" class="img-fluid rounded-4 shadow-lg" style="max-height:80vh;object-fit:contain;" />' +
                                                '</div></div></div></div>';

                                            document.body.insertAdjacentHTML('beforeend', modalHtml);
                                        }

                                        var el = document.getElementById(modalId);
                                        var container = document.querySelector('.container.mt-4');

                                        el.addEventListener('show.bs.modal', function () {
                                            if (container) container.style.filter = 'blur(4px)';
                                        });

                                        el.addEventListener('hidden.bs.modal', function () {
                                            if (container) container.style.filter = '';
                                        });
                                    })();
                                </script>
                            }
                            else
                            {
                                <a href="@attachment.FilePath" target="_blank"
                                   class="attachment-chip d-inline-flex align-items-center rounded-3 p-3 gap-2 text-decoration-none">

                                    <i class="bi bi-file-earmark-pdf text-danger fs-4"></i>
                                    <span class="text-light small fw-semibold">
                                        @attachment.FileName
                                    </span>
                                    <i class="bi bi-box-arrow-up-right text-muted small"></i>
                                </a>
                            }
                        </div>
                    }

                    @if (Model.ReportStatus?.Name == "Oczekujący" ||
                         (Model.ReportStatus?.Name != "Zatwierdzony" && Model.ReportStatus?.Name != "Odrzucony"))
                    {
                        <div class="d-flex justify-content-end gap-3 border-top pt-4"
                             style="border-color:rgba(255,255,255,0.07)!important;">

                            <form asp-action="RejectReport" asp-controller="Admin" method="post"
                                  onsubmit="return confirm('Odrzucić wpis?');">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id"/>

                                <button type="submit" class="btn btn-reject fw-bold rounded-pill px-4 py-2">
                                    <i class="bi bi-x-circle me-1"></i> Odrzuć
                                </button>
                            </form>

                            <form asp-action="ApproveReport" asp-controller="Admin" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@Model.Id"/>

                                <button type="submit" class="btn btn-custom-success fw-bold rounded-pill px-4 py-2">
                                    <i class="bi bi-check-circle me-1"></i> Zatwierdź
                                </button>
                            </form>
                        </div>
                    }

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .report-header-card {
        background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
        border: 1px solid rgba(70, 204, 94, 0.15);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .header-glow {
        position: absolute;
        top: -50px;
        right: -50px;
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.08) 0%, transparent 70%);
        border-radius: 50%;
    }

    .report-avatar {
        width: 72px;
        height: 72px;
        border-radius: 18px;
        background: rgba(70, 204, 94, 0.08);
        border: 1px solid rgba(70, 204, 94, 0.2);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .mini-avatar {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        background: rgba(70, 204, 94, 0.08);
        border: 1px solid rgba(70, 204, 94, 0.15);
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .detail-card {
        background: #1b1b22;
        border: 1px solid rgba(255, 255, 255, 0.05);
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .detail-card-header {
        background: rgba(0, 0, 0, 0.2);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .content-box {
        background: rgba(0, 0, 0, 0.2);
        border: 1px solid rgba(255, 255, 255, 0.06);
        min-height: 120px;
    }

    .attachment-chip {
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(255, 255, 255, 0.08);
        transition: 0.25s;
    }

    .attachment-chip:hover {
        background: rgba(70, 204, 94, 0.08);
        border-color: rgba(70, 204, 94, 0.25);
    }

    .btn-back {
        background: rgba(255, 255, 255, 0.05);
        color: #adb5bd;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .btn-back:hover {
        background: rgba(255, 255, 255, 0.1);
        color: #fff;
    }

    .btn-custom-success {
        background: rgba(70, 204, 94, 0.10);
        color: #46CC5E;
        border: 1px solid rgba(70, 204, 94, 0.3);
    }

    .btn-custom-success:hover {
        background: #46CC5E;
        color: #17171C;
    }

    .btn-reject {
        background: rgba(220, 53, 69, 0.08);
        color: #dc3545;
        border: 1px solid rgba(220, 53, 69, 0.3);
    }

    .btn-reject:hover {
        background: #dc3545;
        color: #fff;
    }
</style>