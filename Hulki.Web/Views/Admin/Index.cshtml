@{
    ViewData["Title"] = "Panel Dowodzenia";
    var recentReports = ViewBag.RecentReports as List<Hulki.Web.Models.DailyReport>;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Panel Dowodzenia Terapeuty</h2>
        <span class="text-muted">Witaj! Masz pełen wgląd w działanie kliniki.</span>
    </div>

    <div class="d-flex flex-wrap gap-2 mb-4">
        <a asp-action="Patients" class="btn btn-primary">
            Lista pacjentów
        </a>
        <a asp-action="ShopItems" class="btn btn-info text-white">
            Przedmioty w sklepie
        </a>
        <a asp-controller="TherapyGroup" asp-action="Index" class="btn btn-success">
            Grupy terapeutyczne
        </a>
    </div>

    <div class="row mb-5 g-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-primary text-white h-100 rounded-3 hover-shadow transition"
                 style="box-shadow: 0 0 6px 1px rgba(52, 89, 230, 0.5) !important;">
                <div class="card-body d-flex align-items-center p-4">
                    <i class="bi bi-people-fill fs-1 me-4 opacity-75"></i>
                    <div>
                        <h5 class="card-title mb-0 fw-light">Zarejestrowani Pacjenci</h5>
                        <h1 class="fw-bold mb-0 display-5">@ViewBag.TotalPatients</h1>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-success text-white h-100 rounded-3 hover-shadow transition"
                 style="box-shadow: 0 0 6px 1px rgba(47, 179, 128, 0.5) !important;">
                <div class="card-body d-flex align-items-center p-4">
                    <i class="bi bi-journal-check fs-1 me-4 opacity-75"></i>
                    <div>
                        <h5 class="card-title mb-0 fw-light">Dzisiejsze Raporty</h5>
                        <h1 class="fw-bold mb-0 display-5">@ViewBag.ReportsToday</h1>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card border-0 shadow-sm bg-warning text-white h-100 rounded-3 hover-shadow transition"
                 style="box-shadow: 0 0 6px 1px rgba(244, 189, 97, 0.5) !important;">
                <div class="card-body d-flex align-items-center p-4">
                    <i class="bi bi-collection-fill fs-1 me-4 opacity-75"></i>
                    <div>
                        <h5 class="card-title mb-0 fw-light">Grupy Wsparcia</h5>
                        <h1 class="fw-bold mb-0 display-5">@ViewBag.TotalGroups</h1>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div
            class="card-header bg-black bg-opacity-25 border-bottom p-4 d-flex justify-content-between align-items-center">
            <h5 class="mb-0 fw-bold"><i class="bi bi-activity text-danger"></i> Ostatnia aktywność pacjentów</h5>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead style="--bs-table-bg: #1D2124; color: #ffffff;">
                    <tr>
                        <th class="ps-4 py-3">Data wpisu</th>
                        <th class="py-3">Pacjent</th>
                        <th class="py-3">Samopoczucie</th>
                        <th class="py-3">Krótka treść</th>
                    </tr>
                </thead>
                <tbody>
                    @if (recentReports != null && recentReports.Any())
                    {
                        foreach (var report in recentReports)
                        {
                            <tr style="cursor: pointer;"
                                onclick="window.location.href='@Url.Action("ReportDetails", new { id = report.Id })'">
                                <td class="ps-4 align-middle text-muted small">@report.CreatedAt.ToString("dd.MM.yyyy HH:mm")
                                </td>
                                <td class="align-middle fw-bold">@report.AppUser?.FirstName @report.AppUser?.LastName</td>
                                <td class="align-middle">
                                    <span class="badge bg-secondary rounded-pill px-3">@report.ReportStatus?.Name</span>
                                </td>
                                <td class="align-middle text-truncate" style="max-width: 350px; color: #6c757d;">
                                    @report.Content
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center p-5 text-muted">Brak wpisów. Pacjenci leniwi sad :(</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-3px);
        box-shadow: 0 .5rem 1.5rem rgba(0, 0, 0, .15) !important;
    }

    .transition {
        transition: all 0.3s ease;
    }
</style>