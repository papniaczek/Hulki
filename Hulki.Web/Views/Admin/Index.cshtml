@{
    ViewData["Title"] = "Panel Dowodzenia";
    var recentReports = ViewBag.RecentReports as List<Hulki.Web.Models.DailyReport>;

    string StatusColor(string status) => status switch
    {
        "Zatwierdzony" => "#46CC5E",
        "Odrzucony" => "#dc3545",
        _ => "#adb5bd"
    };

    string StatusBg(string status) => status switch
    {
        "Zatwierdzony" => "rgba(70,204,94,0.12)",
        "Odrzucony" => "rgba(220,53,69,0.12)",
        _ => "rgba(108,117,125,0.12)"
    };

    string StatusBorder(string status) => status switch
    {
        "Zatwierdzony" => "rgba(70,204,94,0.3)",
        "Odrzucony" => "rgba(220,53,69,0.3)",
        _ => "rgba(108,117,125,0.3)"
    };
}

<div class="container mt-4 mb-5">

    <div class="admin-header-card mb-4 p-4 position-relative overflow-hidden rounded-4">
        <div class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div>
                <h2 class="text-primary fw-bold mb-1 text-uppercase" style="letter-spacing: 1px;">
                    Panel Dowodzenia Terapeuty
                </h2>
                <p class="text-light mb-0 fs-5 fw-light opacity-75">Masz pełen wgląd w działanie kliniki.</p>
            </div>
            <div class="d-flex flex-wrap gap-2 mt-3 mt-md-0">
                <a asp-action="Patients"
                   class="btn btn-list-patients fw-bold rounded-pill text-uppercase custom-btn-nav">Lista pacjentów</a>
                <a asp-action="ShopItems"
                   class="btn btn-shop fw-bold rounded-pill text-uppercase custom-btn-nav">Sklep</a>
                <a asp-controller="TherapyGroup" asp-action="Index"
                   class="btn btn-groups fw-bold rounded-pill text-uppercase custom-btn-nav">Grupy</a>
            </div>
        </div>
        <div class="profile-header-glow-left"></div>
        <div class="profile-header-glow-right"></div>
    </div>

    <div class="row mb-4 g-4">
        <div class="col-md-4">
            <div class="card stat-card-admin border-0 h-100 rounded-4" style="--admin-color: #0dcaf0;">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="icon-box me-4" style="color: #0dcaf0; background: rgba(13, 202, 240, 0.1);">
                        <i class="bi bi-people-fill fs-2"></i>
                    </div>
                    <div>
                        <h6 class="text-uppercase text-muted fw-bold mb-1" style="letter-spacing: 1px;">Zarejestrowani
                        </h6>
                        <h2 class="fw-bold mb-0 text-white display-5 text-shadow-info">@ViewBag.TotalPatients</h2>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card stat-card-admin border-0 h-100 rounded-4" style="--admin-color: #46CC5E;">
                <div class="card-body d-flex align-items-center p-4">
                    <div class="icon-box me-4" style="color: #46CC5E; background: rgba(70, 204, 94, 0.1);">
                        <i class="bi bi-journal-check fs-2"></i>
                    </div>
                    <div>
                        <h6 class="text-uppercase text-muted fw-bold mb-1" style="letter-spacing: 1px;">Dzisiejsze
                            Raporty</h6>
                            <h2 class="fw-bold mb-0 text-white display-5 text-shadow-success">@ViewBag.ReportsToday</h2>
                        </div>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card stat-card-admin border-0 h-100 rounded-4" style="--admin-color: #ffc107;">
                    <div class="card-body d-flex align-items-center p-4">
                        <div class="icon-box me-4" style="color: #ffc107; background: rgba(255, 193, 7, 0.1);">
                            <i class="bi bi-collection-fill fs-2"></i>
                        </div>
                        <div>
                            <h6 class="text-uppercase text-muted fw-bold mb-1" style="letter-spacing: 1px;">Grupy Wsparcia
                            </h6>
                            <h2 class="fw-bold mb-0 text-white display-5 text-shadow-warning">@ViewBag.TotalGroups</h2>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="card border-0 shadow-sm rounded-4 table-card">
            <div class="card-header border-bottom border-secondary p-4 d-flex justify-content-between align-items-center"
                 style="background-color: #141418">
                <h5 class="mb-0 fw-bold text-uppercase text-light" style="letter-spacing: 1px;">
                    <i class="bi bi-activity text-danger me-2"></i> Ostatnia aktywność pacjentów
                </h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-dark table-hover mb-0 custom-table">
                        <thead style="background-color: #1B1B22">
                            <tr class="text-uppercase text-muted small" style="letter-spacing: 1px;">
                                <th class="ps-4 py-3 border-secondary">Data wpisu</th>
                                <th class="py-3 border-secondary">Pacjent</th>
                                <th class="py-3 border-secondary">Status</th>
                                <th class="py-3 border-secondary">Krótka treść</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (recentReports != null && recentReports.Any())
                            {
                                foreach (var report in recentReports)
                                {
                                    var status = report.ReportStatus?.Name;

                                    <tr style="cursor: pointer;"
                                        onclick='window.location.href="@Url.Action("ReportDetails", new { id = report.Id })"'>
                                        <td class="ps-4 align-middle text-muted small fw-bold">
                                            @report.CreatedAt.ToString("dd.MM.yyyy HH:mm")</td>
                                            <td class="align-middle fw-bold text-light">@report.AppUser?.FirstName
                                                @report.AppUser?.LastName</td>
                                                <td class="align-middle">
                                                    <span class="badge rounded-pill px-2 py-1"
                                                          style="background:@StatusBg(status); color:@StatusColor(status); border:1px solid @StatusBorder(status); font-size: 0.8rem">
                                                        @status
                                                    </span>
                                                </td>
                                                <td class="align-middle text-truncate text-muted" style="max-width: 350px;">
                                                    @report.Content
                                                </td>
                                            </tr>
                                        }
                                    }
                    else
                                    {
                                        <tr>
                                            <td colspan="4" class="text-center p-5 text-muted fw-bold">
                                                <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>
                                                Brak wpisów. Pacjenci leniwi :(
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>

            <style>
                .btn-list-patients {
                    border: 1px solid #0dcaf0 !important;
                    box-shadow: none;
                }

                .btn-list-patients:hover,
                .btn-list-patients:active,
                .btn-list-patients:focus {
                    background-color: #0dcaf0 !important;
                    color: #18181E !important;
                    box-shadow: 0 0 5px #0dcaf0;
                }

                .btn-shop {
                    border: 1px solid #46CC5E !important;
                    box-shadow: none;
                }

                .btn-shop:hover,
                .btn-shop:active,
                .btn-shop:focus {
                    background-color: #46CC5E !important;
                    color: #18181E !important;
                    box-shadow: 0 0 5px #46CC5E;
                }

                .btn-groups {
                    border: 1px solid #FFC107 !important;
                    box-shadow: none;
                }

                .btn-groups:hover,
                .btn-groups:active,
                .btn-groups:focus {
                    background-color: #FFC107 !important;
                    color: #18181E !important;
                    box-shadow: 0 0 5px #FFC107;
                }

                .admin-header-card {
                    background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
                    border: 1px solid rgba(70, 204, 94, 0.15);
                    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
                }

                .profile-header-glow-left {
                    position: absolute;
                    top: -50px;
                    left: -50px;
                    width: 250px;
                    height: 250px;
                    background: radial-gradient(circle, rgba(70, 204, 94, 0.15) 0%, transparent 70%);
                    border-radius: 50%;
                    z-index: 0;
                    pointer-events: none;
                }

                .profile-header-glow-right {
                    position: absolute;
                    top: -100px;
                    right: -80px;
                    width: 250px;
                    height: 250px;
                    background: radial-gradient(circle, rgba(70, 204, 94, 0.15) 0%, transparent 70%);
                    border-radius: 50%;
                    z-index: 0;
                    pointer-events: none;
                }

                .custom-btn-nav {
                    background: #17171C;
                    transition: all 0.2s ease;
                }

                .custom-btn-nav:hover {
                    box-shadow: 0 0 20px rgba(var(--main-color-rgb), 0.5);
                }

                .stat-card-admin {
                    background-color: #1b1b22;
                    border: 1px solid rgba(255, 255, 255, 0.05) !important;
                    border-bottom: 3px solid var(--admin-color) !important;
                    transition: all 0.3s ease;
                    box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
                }

                .stat-card-admin:hover {
                    transform: translateY(-5px);
                    background-color: #1f1f27;
                    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.4), 0 0 15px var(--admin-color);
                }

                .icon-box {
                    width: 60px;
                    height: 60px;
                    border-radius: 14px;
                    display: flex;
                    justify-content: center;
                    align-items: center;
                }

                .text-shadow-info {
                    text-shadow: 0 0 15px rgba(13, 202, 240, 0.5);
                }

                .text-shadow-success {
                    text-shadow: 0 0 15px rgba(70, 204, 94, 0.5);
                }

                .text-shadow-warning {
                    text-shadow: 0 0 15px rgba(255, 193, 7, 0.5);
                }

                .table-card {
                    background-color: #1F1F28;
                    border: 1px solid rgba(255, 255, 255, 0.05) !important;
                    overflow: hidden;
                }

                .custom-table {
                    background-color: transparent !important;
                    --bs-table-bg: transparent;
                    --bs-table-hover-bg: rgba(255, 255, 255, 0.03);
                }

                .custom-table td {
                    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
                }
            </style>