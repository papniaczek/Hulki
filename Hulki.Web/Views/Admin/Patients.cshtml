@model IEnumerable<Hulki.Web.Models.AppUser>

@{
    ViewData["Title"] = "Lista Pacjentów";
    var wallets = ViewBag.Wallets as Dictionary<string, int> ?? new();
    var reportCounts = ViewBag.ReportCounts as Dictionary<string, int> ?? new();
    var search = ViewBag.Search as string;
}

<div class="container mt-4 text-light">
    <div class="patients-header-card mb-5 p-4 p-md-5 position-relative overflow-hidden rounded-4" style="min-height: 160px;">
        <div class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div class="mb-4 mb-md-0">
                <h2 class="text-primary fw-bold mb-2 text-uppercase" style="letter-spacing: 1px;">
                    Lista Pacjentów
                </h2>
                <p class="text-light mb-0 fs-5 fw-light opacity-75">Zarządzaj pacjentami, monitoruj ich aktywność i saldo punktów.</p>
            </div>
            <div class="mt-3 mt-md-0">
                <a asp-action="Index" class="btn btn-light fw-bold rounded-pill px-4 text-uppercase custom-btn-nav">
                    <i class="bi bi-arrow-left me-2"></i>Wróć do listy
                </a>
            </div>
        </div>
        <div class="patients-header-glow"></div>
    </div>

    <!-- WYSZUKIWARKA -->
    <style>
        .custom-search-group .form-control:focus {
            box-shadow: none !important;
        }
    
        .custom-search-group:focus-within {
            box-shadow: 0 0 2px 2px rgba(255, 255, 255, 0.5) !important;
            border-radius: 0.375rem;
            /* Utrzymuje zaokrąglenie cienia na rogach */
        }
    
        .custom-search-group:focus-within .input-group-text,
        .custom-search-group:focus-within .form-control {
            border-color: #ffffffff !important;
        }
    </style>

    <!-- LICZNIK -->

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-header border-bottom border-secondary p-4 bg-transparent">
            <div class="d-flex justify-content-between align-items-center w-100">

                <!-- LEWA STRONA -->
                <h5 class="mb-0 fw-bold text-uppercase text-light" style="letter-spacing: 1px;">
                    <i class="bi bi-people text-danger me-2"></i> Lista pacjentów
                </h5>

                <!-- PRAWA STRONA -->
                <form method="get" asp-action="Patients" id="searchForm">
                    <div class="input-group custom-search-group" style="max-width: 300px;">
                        <span class="input-group-text bg-dark border-secondary text-light">
                            <i class="bi bi-search"></i>
                        </span>

                        <input type="text"
                               name="search"
                               value="@search"
                               id="searchInput"
                               class="form-control bg-dark border-secondary text-light"
                               placeholder="Wyszukaj pacjenta..."
                               autofocus/>
                    </div>
                </form>

            </div>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 custom-table">
                    <thead>
                    <tr>
                        <th class="ps-4 py-3 border-secondary">Pacjent</th>
                        <th class="py-3 border-secondary">E-mail</th>
                        <th class="py-3 text-center border-secondary">Saldo</th>
                        <th class="py-3 text-center border-secondary">Wpisy</th>
                        <th class="py-3 text-center border-secondary">Status konta</th>
                        <th class="py-3 text-end border-secondary"style="padding-right: 3.5rem;">Akcje</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.Any())
                    {
                        foreach (var p in Model)
                        {
                            var balance = wallets.TryGetValue(p.Id, out var b) ? b : 0;
                            var reportCount = reportCounts.TryGetValue(p.Id, out var c) ? c : 0;
                            var isLocked = p.LockoutEnd.HasValue && p.LockoutEnd.Value > DateTimeOffset.Now;

                            <tr>
                                <td class="ps-4 fw-bold align-middle">
                                    <i class="bi bi-person-circle text-primary me-2"></i>
                                    @p.FirstName @p.LastName
                                </td>
                                <td class="text-muted small align-middle">@p.Email</td>
                                <td class="text-center align-middle">
                                    <span class="badge bg-success rounded-pill px-3">@balance pkt</span>
                                </td>
                                <td class="text-center align-middle">
                                    <span class="badge bg-info rounded-pill px-3">@reportCount</span>
                                </td>
                                <td class="text-center align-middle">
                                    @if (isLocked)
                                    {
                                        <span class="badge bg-danger">Zablokowane</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Aktywne</span>
                                    }
                                </td>
                                <td class="text-end pe-4">
                                    <a asp-action="PatientDetails" asp-route-id="@p.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> Szczegóły
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center p-5 text-muted">
                                <i class="bi bi-emoji-frown fs-3 d-block mb-2"></i>
                                Nie znaleziono pacjentów spełniających kryteria.
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>


<style>
    .patients-header-card {
        background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
        border: 1px solid rgba(70, 204, 94, 0.15);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .patients-header-glow {
        position: absolute;
        top: -50px;
        right: -50px;
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .card {
        background-color: #1b1b22;
        border: 1px solid rgba(255, 255, 255, 0.03);
        transition: all 0.3s ease;
    }


    .custom-btn-nav {
        transition: all 0.2s ease;
    }

    .custom-btn-nav:hover {
        box-shadow: 0 0 20px rgba(70, 204, 94, 0.5) !important;
    }


    .table-card {
        background-color: #1b1b22;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        overflow: hidden;
    }

    .custom-table {
        background-color: transparent !important;
        --bs-table-bg: transparent;
        --bs-table-hover-bg: rgba(255, 255, 255, 0.03);
    }

    .custom-table td {
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }
</style>

<script>
    let timeout = null;

    const input = document.getElementById("searchInput");

    input.addEventListener("input", function () {
        clearTimeout(timeout);

        timeout = setTimeout(() => {
            sessionStorage.setItem("keepFocus", "1");
            this.form.submit();
        }, 300);
    });

    window.addEventListener("load", () => {
        if (sessionStorage.getItem("keepFocus") === "1") {
            const el = document.getElementById("searchInput");
            if (el) {
                el.focus();
                el.setSelectionRange(el.value.length, el.value.length);
            }
            sessionStorage.removeItem("keepFocus");
        }
    });
</script>