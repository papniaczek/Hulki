@model IEnumerable<Hulki.Web.Models.AppUser>

@{
    ViewData["Title"] = "Lista Pacjentów";
    var wallets = ViewBag.Wallets as Dictionary<string, int> ?? new();
    var reportCounts = ViewBag.ReportCounts as Dictionary<string, int> ?? new();
    var isTherapist = ViewBag.IsTherapist as Dictionary<string, bool> ?? new();
    var search = ViewBag.Search as string;
}

<div class="container mt-4 text-light">
    <div class="patients-header-card mb-5 p-4 p-md-5 position-relative overflow-hidden rounded-4" style="min-height: 160px;">
        <div class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div class="mb-4 mb-md-0">
                <h2 class="text-primary fw-bold mb-2 text-uppercase" style="letter-spacing: 1px;">
                    Lista Pacjentów
                </h2>
                <p class="text-light mb-0 fs-5 fw-light opacity-75">Zarządzaj pacjentami, monitoruj ich aktywność i saldo punktów.</p>
            </div>
            <div class="mt-3 mt-md-0">
                <a asp-action="Index" class="btn btn-light fw-bold rounded-pill px-4 text-uppercase custom-btn-nav">
                    <i class="bi bi-arrow-left me-2"></i>Wróć do panelu
                </a>
            </div>
        </div>
        <div class="patients-header-glow"></div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success rounded-3 border-0 mb-4"
             style="background: rgba(70,204,94,.12); border-left: 3px solid #46CC5E !important; color: #46CC5E;">
            <i class="bi bi-check-circle me-2"></i>@TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger rounded-3 border-0 mb-4"
             style="background: rgba(224,92,92,.12); border-left: 3px solid #e05c5c !important; color: #e05c5c;">
            <i class="bi bi-exclamation-circle me-2"></i>@TempData["ErrorMessage"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4 table-card">
        <div class="card-header border-bottom border-secondary p-4 d-flex justify-content-between align-items-center" style="background-color: #141418">
            <h5 class="mb-0 fw-bold text-uppercase text-light" style="letter-spacing: 1px;">
                <i class="bi bi-people text-danger me-2"></i> Lista pacjentów
            </h5>

            <form method="get" asp-action="Patients" id="searchForm">
                <div class="input-group custom-search-group" style="max-width: 300px;">
                    <span class="input-group-text bg-dark border-secondary text-light">
                        <i class="bi bi-search"></i>
                    </span>
                    <input type="text"
                           name="search"
                           value="@search"
                           id="searchInput"
                           class="form-control bg-dark border-secondary text-light"
                           placeholder="Wyszukaj pacjenta..."
                           autofocus/>
                </div>
            </form>
        </div>

        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-dark table-hover mb-0 custom-table">
                    <thead style="background-color: #1B1B22">
                    <tr class="text-uppercase text-muted small" style="letter-spacing: 1px;">
                        <th class="ps-4 py-3 border-secondary">Pacjent</th>
                        <th class="py-3 border-secondary">E-mail</th>
                        <th class="py-3 text-center border-secondary">Rola</th>
                        <th class="py-3 text-center border-secondary">Saldo</th>
                        <th class="py-3 text-center border-secondary">Wpisy</th>
                        <th class="py-3 text-center border-secondary">Status konta</th>
                        <th class="py-3 text-end border-secondary pe-4">Akcje</th>
                    </tr>
                    </thead>
                    <tbody>
                    @if (Model.Any())
                    {
                        foreach (var p in Model)
                        {
                            var balance = wallets.TryGetValue(p.Id, out var b) ? b : 0;
                            var reportCount = reportCounts.TryGetValue(p.Id, out var c) ? c : 0;
                            var isLocked = p.LockoutEnd.HasValue && p.LockoutEnd.Value > DateTimeOffset.Now;
                            var isTherap = isTherapist.TryGetValue(p.Id, out var t) && t;

                            <tr style="cursor:pointer;"
                                onclick='window.location.href="@Url.Action("PatientDetails", new { id = p.Id })"'>

                                <td class="ps-4 fw-bold align-middle text-light">
                                    <i class="bi bi-person-circle text-primary me-2"></i>
                                    @p.FirstName @p.LastName
                                </td>

                                <td class="text-muted small align-middle">@p.Email</td>

                                @* KOLUMNA ROLI *@
                                <td class="text-center align-middle">
                                    @if (isTherap)
                                    {
                                        <span class="role-badge role-therapist">
                                            <i class="bi bi-briefcase-fill me-1"></i>Terapeuta
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="role-badge role-patient">
                                            <i class="bi bi-person-fill me-1"></i>Pacjent
                                        </span>
                                    }
                                </td>

                                <td class="text-center align-middle">
                                    <span class="badge bg-success rounded-pill px-3">@balance pkt</span>
                                </td>

                                <td class="text-center align-middle">
                                    <span class="badge bg-info rounded-pill px-3">@reportCount</span>
                                </td>

                                <td class="text-center align-middle">
                                    @if (isLocked)
                                    {
                                        <span class="badge bg-danger">Zablokowane</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">Aktywne</span>
                                    }
                                </td>

                                @* AKCJE *@
                                <td class="text-end pe-4 align-middle" onclick="event.stopPropagation()">
                                    <div class="d-flex justify-content-end align-items-center gap-2">

                                        @* Przycisk: Szczegóły *@
                                        <a asp-action="PatientDetails" asp-route-id="@p.Id"
                                           class="btn btn-sm btn-outline-primary rounded-pill px-3" style="font-size: 12px">
                                            <i class="bi bi-eye me-1"></i>Szczegóły
                                        </a>

                                        @* Przycisk: Nadaj / Odbierz rolę Terapeuty *@
                                        <form method="post"
                                              asp-action="ToggleTherapist"
                                              asp-controller="Admin"
                                              onsubmit="return confirmToggle(this, '@p.FirstName @p.LastName', @(isTherap ? "true" : "false"))">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="userId" value="@p.Id"/>
                                            <input type="hidden" name="returnUrl" value="@Url.Action("Patients", new { search })"/>

                                            @if (isTherap)
                                            {
                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <button type="submit"
                                                            class="btn btn-sm btn-therapist-revoke btn-therapist-action rounded-pill px-3"
                                                            title="Odbierz rolę terapeuty">
                                                        <i class="bi bi-person-dash me-1"></i>Odbierz rolę
                                                    </button>
                                                }
                                            }
                                            else
                                            {
                                                @if (User.IsInRole("Admin"))
                                                {
                                                    <button type="submit"
                                                            class="btn btn-sm btn-therapist-grant btn-therapist-action rounded-pill px-3"
                                                            title="Nadaj rolę terapeuty">
                                                        <i class="bi bi-person-check me-1"></i>Ustaw terapeutą
                                                    </button>
                                                }
                                            }
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center p-5 text-muted fw-bold">
                                <i class="bi bi-emoji-frown fs-1 d-block mb-2 opacity-50"></i>
                                Nie znaleziono pacjentów spełniających kryteria.
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
    .btn-therapist-action {
        width: 170px;
        font-size: 12px !important;
    }

    .patients-header-card {
        background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
        border: 1px solid rgba(70, 204, 94, 0.15);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .patients-header-glow {
        position: absolute;
        top: -50px;
        right: -50px;
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .custom-btn-nav {
        transition: all 0.2s ease;
    }

    .custom-btn-nav:hover {
        box-shadow: 0 0 20px rgba(70, 204, 94, 0.5) !important;
    }

    .table-card {
        background-color: #1F1F28;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        overflow: hidden;
    }

    .custom-table {
        background-color: transparent !important;
        --bs-table-bg: transparent;
        --bs-table-hover-bg: rgba(255, 255, 255, 0.03);
    }

    .custom-table td {
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    }

    .custom-search-group .form-control:focus {
        box-shadow: none !important;
    }

    .custom-search-group:focus-within {
        box-shadow: 0 0 2px 2px rgba(255, 255, 255, 0.5) !important;
        border-radius: 0.375rem;
    }

    .custom-search-group:focus-within .input-group-text,
    .custom-search-group:focus-within .form-control {
        border-color: #fff !important;
    }

    /* Badge roli */
    .role-badge {
        display: inline-flex;
        align-items: center;
        padding: 3px 10px;
        border-radius: 20px;
        font-size: 11px;
        font-weight: 600;
        white-space: nowrap;
    }

    .role-therapist {
        background: rgba(70, 204, 94, .12);
        color: #46CC5E;
        border: 1px solid rgba(70, 204, 94, .3);
    }

    .role-patient {
        background: rgba(136, 136, 170, .1);
        color: #8888aa;
        border: 1px solid rgba(136, 136, 170, .2);
    }

    /* Przyciski roli */
    .btn-therapist-grant {
        background: transparent;
        border: 1px solid rgba(70, 204, 94, .4);
        color: #46CC5E;
        font-size: 12px;
        transition: all .2s;
    }

    .btn-therapist-grant:hover {
        background: rgba(70, 204, 94, .15);
        border-color: #46CC5E;
        color: #46CC5E;
        box-shadow: 0 0 12px rgba(70, 204, 94, .3);
    }

    .btn-therapist-revoke {
        background: transparent;
        border: 1px solid rgba(224, 92, 92, .4);
        color: #e05c5c;
        font-size: 12px;
        transition: all .2s;
    }

    .btn-therapist-revoke:hover {
        background: rgba(224, 92, 92, .12);
        border-color: #e05c5c;
        color: #e05c5c;
        box-shadow: 0 0 12px rgba(224, 92, 92, .3);
    }
</style>

<script>
    // Potwierdzenie zmiany roli
    function confirmToggle(form, name, isCurrentlyTherapist) {
        const action = isCurrentlyTherapist === 'true'
            ? `Czy na pewno chcesz odebrać rolę terapeuty użytkownikowi ${name}?`
            : `Czy na pewno chcesz nadać rolę terapeuty użytkownikowi ${name}?`;
        return confirm(action);
    }

    // Live search
    let timeout = null;
    const input = document.getElementById("searchInput");
    input.addEventListener("input", function () {
        clearTimeout(timeout);
        timeout = setTimeout(() => {
            sessionStorage.setItem("keepFocus", "1");
            this.form.submit();
        }, 300);
    });

    window.addEventListener("load", () => {
        if (sessionStorage.getItem("keepFocus") === "1") {
            const el = document.getElementById("searchInput");
            if (el) { el.focus(); el.setSelectionRange(el.value.length, el.value.length); }
            sessionStorage.removeItem("keepFocus");
        }
    });
</script>
