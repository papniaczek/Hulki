@{
    ViewData["Title"] = "Mój Profil";
    var user = ViewBag.User as AppUser;
    var inventory = ViewBag.Inventory as List<RewardItem>;
    var reports = ViewBag.Reports as List<DailyReport>;
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mx-3 mt-3" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="container mt-4">
    <!-- HEADER -->
    <div class="row mb-4">
        <div class="col-12">
            <div class="card border-0 shadow-sm text-white p-4 d-flex flex-row align-items-center justify-content-between rounded-4"
                 style="background: linear-gradient(135deg, #46CC5E, #1F8F3A); box-shadow: 0px 0px 10px 1px rgba(0, 0, 0, 0.55) !important">
                <div class="d-flex align-items-center gap-3" style="text-shadow: 0 2px 6px rgba(0,0,0,0.6);">
                    <div class="rounded-circle bg-white bg-opacity-25 d-flex align-items-center justify-content-center"
                         style="width:64px;height:64px;font-size:1.8rem;">
                        <i class="bi bi-person-fill"></i>
                    </div>
                    <div>
                        <h2 class="mb-0 fw-bold">@user.FirstName @user.LastName</h2>
                        <p class="mb-0 text-white-50 small">
                            <i class="bi bi-envelope me-1"></i>@user.Email
                        </p>
                    </div>
                </div>
                <div class="text-end">
                    <div class="text-white-50 small text-uppercase fw-bold mb-1">Saldo portfela</div>
                    <div id="points" class="fw-bold" style="font-size:2.2rem;">
                        @ViewBag.Points <i class="bi bi-star-fill text-warning" style="font-size:1.5rem;"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <!-- EKWIPUNEK -->
        <div class="col-md-7 mb-4">
            <h5 class="mb-3 fw-bold text-secondary" style="text-align: center;">
                Mój Ekwipunek
            </h5>
            <h5 style="text-align: center; margin-bottom: 20px; margin-top: -5px;">
                <span class="badge bg-primary ms-2" style="text-shadow: 0 2px 6px rgba(0,0,0,0.6);">
                    Liczba posiadanych przedmiotów: @inventory.Count
                </span>
            </h5>

            @if (inventory != null && inventory.Any())
            {
                <div class="row g-3" id="inventoryGrid">
                    @foreach (var item in inventory)
                    {
                        var rarityColor = item.ItemRarity?.HexColor ?? "#adb5bd";
                        var rarityName = item.ItemRarity?.Name ?? "Pospolity";

                        string emoji = rarityName switch
                        {
                            "Legendarny" => "👑",
                            "Mityczny" => "🔥",
                            "Epicki" => "💎",
                            "Rzadki" => "🔷",
                            "Niepospolity" => "🟢",
                            _ => "🛡️"
                        };

                        <div class="col-6 col-md-4">
                            <div class="inventory-card card border-0 shadow-sm h-100 text-center position-relative overflow-hidden"
                                 data-item-id="@item.Id" style="border-top: 4px solid @rarityColor !important;
                                box-shadow: 0px 0px 7px 1px rgba(0,0,0,0.55) !important;
                                cursor: pointer;
                                transition: transform 0.15s, box-shadow 0.15s;">

                                <!-- IKONA ZAZNACZENIA -->
                                <div class="item-check position-absolute top-0 end-0 m-1"
                                     style="display:none; z-index:10; margin-right: 0.65rem !important">
                                    <i class="bi bi-check-circle-fill text-white"
                                       style="font-size:1.3rem; filter: drop-shadow(0 0 2px rgba(0,0,0,0.6));"></i>
                                </div>

                                <div class="card-body py-3 px-2">
                                    @if (!string.IsNullOrWhiteSpace(item.IconPath))
                                    {
                                        <img src="@item.IconPath" alt="@item.Name" class="mb-2 rounded"
                                             style="width:3rem;height:3rem;object-fit:cover;"
                                             onerror="this.onerror=null;this.outerHTML='<i class=\'bi bi-box-seam default-item-icon mb-2 d-block\' style=\'font-size:2.2rem;color:'+'@rarityColor'+';\'></i>';" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-box-seam default-item-icon mb-2 d-block"
                                           style="font-size:2.2rem;color:@rarityColor;" title="Brak przypisanej grafiki">
                                        </i>
                                    }
                                    <div class="fw-bold small text-truncate mb-1" title="@item.Name">@item.Name</div>
                                    <span class="badge mb-2" style="background-color:@rarityColor;">@rarityName</span>

                                    <!-- PRZYCISK SPRZEDAJ (pojedynczy) -->
                                    <form asp-controller="Store" asp-action="SellItem" method="post"
                                          class="mt-1 single-sell-form">
                                        <input type="hidden" name="itemId" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger w-100"
                                                onclick="return confirm('Na pewno sprzedać @item.Name?')">
                                            <i class="bi bi-cash-coin me-1"></i>Sprzedaj
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- PASEK MULTI-SELL -->
                <form asp-controller="Store" asp-action="SellMultiple" method="post" id="multiSellForm">
                    <div id="multiSellBar"
                         style="display:none; position:fixed; bottom:5rem; left:50%; transform:translateX(-50%); width: calc(100% - 2rem); max-width: 800px; z-index:999; background:#1e2330; padding: 14px 24px; box-shadow: 0 -4px 20px rgba(0,0,0,0.35); border-radius: 8px; border: 1px solid #ffffff;">
                        <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
                            <span class="text-white fw-semibold">
                                Zaznaczono: <span id="selectedNum" class="text-primary fw-bold">0</span> przedmiotów
                            </span>
                            <div class="d-flex gap-2 flex-wrap">
                                <button type="button" id="btnSelectAll" class="btn btn-sm btn-select-all">
                                    Zaznacz wszystko
                                </button>
                                <button type="button" id="btnDeselectAll" class="btn btn-sm btn-unselect-all">
                                    Odznacz wszystko
                                </button>
                                <button type="submit" class="btn btn-sm btn-sell-selected"
                                        onclick="return confirmMultiSell()">
                                    Sprzedaj zaznaczone
                                </button>
                            </div>
                        </div>
                    </div>
                </form>
            }
            else
            {
                <div class="card border-0 shadow-sm">
                    <div class="card-body text-center p-5 text-muted"
                         style="box-shadow: 0px 0px 10px 1px rgba(0,0,0,0.45); border-radius: 0.5rem;">
                        <i class="bi bi-box fs-1 d-block mb-3"></i>
                        <p class="mb-3">Twój ekwipunek jest pusty.<br>Zdobądź punkty i otwórz pierwszą skrzynkę!</p>
                        <a asp-controller="Store" asp-action="Index" class="btn btn-outline-primary">
                            Przejdź do sklepu
                        </a>
                    </div>
                </div>
            }
        </div>

        <!-- OSTATNIE WPISY -->
        <div class="col-md-5 mb-4">
            <h5 class="mb-3 fw-bold text-secondary" style="text-align: center;">
                Ostatnie wpisy
            </h5>
            <h5 style="text-align: center; margin-bottom: 20px; margin-top: -5px;">
                <span class="badge bg-primary ms-2" style="text-shadow: 0 2px 6px rgba(0,0,0,0.6);">
                    @if (reports != null && reports.Any())
                    {
                        <span>Ostatni wpis dnia: @(reports.First().CreatedAt.ToString("dd.MM.yyyy"))</span>
                    }
                    else
                    {
                        @:Brak wpisów
                    }
                </span>
            </h5>
            <div class="card border-0" style="box-shadow: 0px 0px 10px 1px rgba(0,0,0,0.45); border-radius: 0.5rem;">
                <div class="card-body p-0">
                    <ul class="list-group list-group-flush rounded-3">
                        @if (reports != null && reports.Any())
                        {
                            foreach (var report in reports)
                            {
                                <li class="list-group-item px-3 py-3">
                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                        <small class="text-muted">
                                            <i class="bi bi-calendar3 me-1"></i>@report.CreatedAt.ToString("dd.MM.yyyy")
                                        </small>
                                        <span class="badge bg-secondary">@report.ReportStatus.Name</span>
                                    </div>
                                    <p class="mb-0 small text-truncate text-muted" style="max-width:260px;">@report.Content</p>
                                </li>
                            }
                        }
                        else
                        {
                            <li class="list-group-item p-4 text-center text-muted">
                                <i class="bi bi-journal-x fs-3 d-block mb-2"></i>
                                Brak wpisów w dzienniczku.
                            </li>
                        }
                    </ul>
                </div>
                <div class="card-footer bg-transparent border-0 text-center pb-3">
                    <a asp-controller="Patient" asp-action="DailyReport" class="btn btn-primary"
                       style="color: #0d6efd; border: 1px solid #0d6efd; background-color: transparent; transition: all 0.2s ease-in-out;"
                       onmouseover="this.style.backgroundColor='#0d6efd'; this.style.color='#ffffff';"
                       onmouseout="this.style.backgroundColor='transparent'; this.style.color='#0d6efd';">
                        Dodaj wpis
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .inventory-card.selected {
        background-color: rgba(55, 63, 77, 0.582) !important;
        transform: scale(0.97);
    }

    .inventory-card.selected .item-check {
        display: block !important;
    }

    .inventory-card:hover {
        transform: scale(0.98);
    }

    .inventory-card.selected:hover {
        transform: scale(0.97);
    }

    body.multi-mode .single-sell-form {
        display: none !important;
    }

    /* Odstep na dole strony zeby pasek nie zakrywal zawartosci */
    body.multi-mode {
        padding-bottom: 80px;
    }
</style>

<script>
    (function () {
        const cards = document.querySelectorAll('.inventory-card');
        const form = document.getElementById('multiSellForm');
        const bar = document.getElementById('multiSellBar');
        const btnSelectAll = document.getElementById('btnSelectAll');
        const btnDeselectAll = document.getElementById('btnDeselectAll');
        const selectedNum = document.getElementById('selectedNum');

        let selected = new Set();

        function updateUI() {
            const count = selected.size;
            const anySelected = count > 0;

            bar.style.display = anySelected ? '' : 'none';
            selectedNum.textContent = count;
            document.body.classList.toggle('multi-mode', anySelected);

            btnSelectAll.style.display = (count === cards.length) ? 'none' : '';
            btnDeselectAll.style.display = anySelected ? '' : 'none';
        }

        function toggleCard(card) {
            const id = card.dataset.itemId;
            if (selected.has(id)) {
                selected.delete(id);
                card.classList.remove('selected');
            } else {
                selected.add(id);
                card.classList.add('selected');
            }
            updateUI();
        }

        cards.forEach(card => {
            card.addEventListener('click', function (e) {
                if (e.target.closest('.single-sell-form')) return;
                toggleCard(card);
            });
        });

        btnSelectAll.addEventListener('click', () => {
            cards.forEach(card => {
                selected.add(card.dataset.itemId);
                card.classList.add('selected');
            });
            updateUI();
        });

        btnDeselectAll.addEventListener('click', () => {
            selected.clear();
            cards.forEach(card => card.classList.remove('selected'));
            updateUI();
        });

        form.addEventListener('submit', function () {
            form.querySelectorAll('input[name="itemIds"]').forEach(el => el.remove());
            selected.forEach(id => {
                const input = document.createElement('input');
                input.type = 'hidden';
                input.name = 'itemIds';
                input.value = id;
                form.appendChild(input);
            });
        });

        window.confirmMultiSell = function () {
            return confirm(`Na pewno chcesz sprzedać ${selected.size} przedmiotów?`);
        };
    })();
</script>
