@{
    ViewData["Title"] = "Dzienniczek Pacjenta";
    bool alreadyReported = ViewBag.AlreadyReportedToday == true;
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            <div class="custom-card-container mb-5 p-4 p-md-5 position-relative overflow-hidden rounded-4">
                <div class="position-relative z-1">
                    <h2 class="text-center mb-2 text-primary fw-bold text-uppercase" style="letter-spacing: 1px;">
                        <i class="bi bi-journal-heart me-2"></i>Dzienniczek Postępów
                    </h2>
                    <p class="text-center text-light opacity-75 mb-4">
                        Opisz jak minął Ci dzień. Każdy szczery wpis to <strong class="text-primary">+10 punktów</strong>,
                        <i class="bi bi-star-fill text-warning"></i> za załącznik <strong>dodatkowe +5</strong>!
                    </p>

                    @if (alreadyReported)
                    {
                        <div class="text-center py-5">
                            <div class="mb-3">
                                <img src="~/graphics/smile.png" alt="Sukces" style="width:150px; filter: drop-shadow(0 0 15px rgba(70,204,94,0.4));"/>
                            </div>
                            <h4 class="text-success fw-bold text-uppercase">Dzisiejszy wpis już dodany!</h4>
                            <p class="text-muted">Świetna robota! Wróć jutro, żeby kontynuować swoją passę.</p>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary fw-bold rounded-pill px-4 mt-3 custom-glow-btn">
                                <i class="bi bi-house me-1"></i> Wróć do strony głównej
                            </a>
                        </div>
                    }
                    else
                    {
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger border-0 shadow-sm">
                                @Html.ValidationSummary(false, "", new { @class = "text-danger list-unstyled mb-0" })
                            </div>
                        }

                        <div class="mb-4 p-4 rounded-3 prompt-container shadow-sm border border-secondary">
                            <p class="fw-bold mb-3 text-info text-center text-uppercase" style="letter-spacing: 1px;">
                                Nie wiesz od czego zacząć? Kliknij pytanie:
                            </p>

                            <div class="d-flex flex-wrap gap-2 justify-content-center">
                                <button type="button" class="btn btn-sm btn-outline-info rounded-pill prompt-btn"
                                        data-prompt="Jak minął mi dzisiaj dzień? Czy miałem pokusy i jak sobie z nimi poradziłem?">
                                    💬 Jak minął dzień?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-info rounded-pill prompt-btn"
                                        data-prompt="Co dziś zrobiłem, żeby zadbać o siebie i swoje zdrowie?">
                                    💪 Co zrobiłem dla siebie?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-info rounded-pill prompt-btn"
                                        data-prompt="Jakie emocje towarzyszyły mi dzisiaj? Skąd się wzięły i jak sobie z nimi poradziłem?">
                                    😌 Jakie emocje odczuwałem?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-info rounded-pill prompt-btn"
                                        data-prompt="Z czego jestem dziś dumny? Co poszło dobrze, nawet jeśli to mała rzecz?">
                                    🌟 Z czego jestem dumny?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-info rounded-pill prompt-btn"
                                        data-prompt="Co było najtrudniejsze dzisiaj i co pomogło mi przez to przejść?">
                                    🧗 Co było najtrudniejsze?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-info rounded-pill prompt-btn"
                                        data-prompt="Jaki mam plan na jutro? Co chcę zrobić inaczej lub lepiej?">
                                    📅 Plan na jutro
                                </button>
                            </div>
                        </div>

                        <form asp-controller="Patient" asp-action="DailyReport" method="post" enctype="multipart/form-data">

                            <div class="mb-4">
                                <label class="form-label fw-bold text-light text-uppercase small">Treść raportu <span class="text-danger">*</span></label>
                                <textarea id="reportContent" name="content" class="form-control bg-dark text-light border-secondary custom-input-focus" rows="6" required
                                          placeholder="Napisz tutaj swoje przemyślenia..."></textarea>
                            </div>

                            <div id="attachmentContainer" class="mb-4 p-4 rounded-3 border border-secondary" style="background-color: #1b1b22;">
                                <label class="form-label fw-bold text-light d-flex align-items-center">
                                    <i class="bi bi-paperclip fs-5 me-2 text-warning"></i> Dowód utrzymania postanowienia
                                    <span class="badge bg-warning text-dark ms-3 rounded-pill">Opcjonalne +5 pkt</span>
                                </label>

                                <p class="small text-muted mb-3">
                                    Zrzut ekranu usuniętej aplikacji, zdjęcie z siłowni, cokolwiek co pomogło Ci w trzeźwości.
                                </p>

                                <input id="attachmentInput" type="file" name="attachment" class="form-control bg-dark text-light border-secondary" accept=".jpg,.jpeg,.png,.pdf"/>

                                <div id="attachmentError" class="text-danger mt-2 d-none small fw-bold">
                                    Dozwolone są tylko pliki JPG, JPEG, PNG oraz PDF.
                                </div>
                            </div>

                            <button id="saveBtn" type="submit" class="btn btn-primary btn-lg w-100 fw-bold rounded-pill text-uppercase custom-glow-btn" style="letter-spacing: 1px;">
                                Zapisz raport i odbierz punkty <i class="bi bi-star-fill text-warning ms-1"></i>
                            </button>
                        </form>
                    }
                </div>
                <div class="custom-card-glow"></div>
            </div>
        </div>
    </div>
</div>

<style>
    .custom-card-container {
        background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
        border: 1px solid rgba(70, 204, 94, 0.15);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .custom-card-glow {
        position: absolute;
        top: -100px;
        left: 50%;
        transform: translateX(-50%);
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .prompt-container {
        background-color: rgba(0, 0, 0, 0.2);
    }

    .custom-input-focus:focus {
        background-color: #17171c;
        border-color: #46CC5E;
        box-shadow: 0 0 10px rgba(70, 204, 94, 0.25);
        color: white;
    }

    .custom-glow-btn {
        transition: all 0.3s ease;
    }

    .custom-glow-btn:hover {
        background: #46CC5E;
        color: #17171C !important;
        box-shadow: 0 0 15px rgba(70, 204, 94, 0.6);
        transform: scale(1.02);
    }
</style>

<script>
    document.querySelectorAll('.prompt-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            const textarea = document.getElementById('reportContent');
            const prompt = this.getAttribute('data-prompt');
            if (textarea.value.trim() === '') {
                textarea.value = prompt + '\n\n';
            } else {
                textarea.value += '\n\n' + prompt + '\n\n';
            }
            textarea.focus();
            textarea.setSelectionRange(textarea.value.length, textarea.value.length);
        });
    });

    const fileInput = document.getElementById('attachmentInput');
    const saveBtn = document.getElementById('saveBtn');
    const errorDiv = document.getElementById('attachmentError');
    const container = document.getElementById('attachmentContainer');
    const allowedExtensions = ['jpg', 'jpeg', 'png', 'pdf'];

    fileInput.addEventListener('change', function () {
        if (!this.files.length) {
            errorDiv.classList.add('d-none');
            container.classList.remove('border-danger');
            container.classList.add('border-secondary');
            saveBtn.disabled = false;
            return;
        }

        const fileName = this.files[0].name.toLowerCase();
        const extension = fileName.split('.').pop();

        if (!allowedExtensions.includes(extension)) {
            errorDiv.classList.remove('d-none');
            container.classList.remove('border-secondary');
            container.classList.add('border-danger');
            saveBtn.disabled = true;
        } else {
            errorDiv.classList.add('d-none');
            container.classList.add('border-secondary');
            container.classList.remove('border-danger');
            saveBtn.disabled = false;
        }
    });
</script>