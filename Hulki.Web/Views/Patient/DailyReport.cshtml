@{
    ViewData["Title"] = "Dzienniczek Pacjenta";
    bool alreadyReported = ViewBag.AlreadyReportedToday == true;
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">

            @if (TempData["ErrorMessage"] != null)
            {
                <div class="alert alert-warning alert-dismissible fade show mb-4" role="alert">
                    <i class="bi bi-clock-history me-2"></i> @TempData["ErrorMessage"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            <div class="card shadow border-0">
                <div class="card-body p-5">
                    <h2 class="text-center mb-2 text-primary">
                        <i class="bi bi-journal-heart me-2"></i>Dzienniczek Postępów
                    </h2>
                    <p class="text-center text-muted mb-4">
                        Opisz jak minął Ci dzień. Każdy szczery wpis to <strong>+10 punktów</strong>,
                        <i class="bi bi-star-fill text-warning"></i> za załącznik <strong>dodatkowe +5</strong>!
                    </p>

                    @if (alreadyReported)
                    {
                        <div class="text-center py-5">
                            <div class="mb-3">
                                <img src="~/graphics/smile.png" alt="Sukces" style="width:150px;" />
                            </div>
                            <h4 class="text-success fw-bold">Dzisiejszy wpis już dodany!</h4>
                            <p class="text-muted">Świetna robota! Wróć jutro, żeby kontynuować swoją passę.</p>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-primary mt-3">
                                <i class="bi bi-house me-1"></i> Wróć do strony głównej
                            </a>
                        </div>
                    }
                    else
                    {
                        @if (!ViewData.ModelState.IsValid)
                        {
                            <div class="alert alert-danger">
                                @Html.ValidationSummary(false, "", new { @class = "text-danger list-unstyled mb-0" })
                            </div>
                        }
                        <div class="mb-4 p-3 rounded-3" style="background: #1d1d1d; border: 1px solid rgb(52, 89, 230); text-align: center;">
                            <p class="fw-bold mb-2 text-primary">
                                Nie wiesz od czego zacząć? Kliknij pytanie:
                            </p>
                            <div class="d-flex flex-wrap gap-2" style="justify-content: center;">
                                <button type="button" class="btn btn-sm btn-outline-primary prompt-btn"
                                        data-prompt="Jak minął mi dzisiaj dzień? Czy miałem pokusy i jak sobie z nimi poradziłem?">
                                    💬 Jak minął dzień?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-primary prompt-btn"
                                        data-prompt="Co dziś zrobiłem, żeby zadbać o siebie i swoje zdrowie?">
                                    💪 Co zrobiłem dla siebie?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-primary prompt-btn"
                                        data-prompt="Jakie emocje towarzyszyły mi dzisiaj? Skąd się wzięły i jak sobie z nimi poradziłem?">
                                    😌 Jakie emocje odczuwałem?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-primary prompt-btn"
                                        data-prompt="Z czego jestem dziś dumny? Co poszło dobrze, nawet jeśli to mała rzecz?">
                                    🌟 Z czego jestem dumny?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-primary prompt-btn"
                                        data-prompt="Co było najtrudniejsze dzisiaj i co pomogło mi przez to przejść?">
                                    🧗 Co było najtrudniejsze?
                                </button>
                                <button type="button" class="btn btn-sm btn-outline-primary prompt-btn"
                                        data-prompt="Jaki mam plan na jutro? Co chcę zrobić inaczej lub lepiej?">
                                    📅 Plan na jutro
                                </button>
                            </div>
                        </div>

                        <form asp-controller="Patient" asp-action="DailyReport" method="post" enctype="multipart/form-data">

                            <div class="mb-4">
                                <label class="form-label fw-bold">Treść raportu <span class="text-danger">*</span></label>
                                <textarea id="reportContent" name="content" class="form-control" rows="6" required
                                          placeholder="Napisz tutaj swoje przemyślenia..."></textarea>
                            </div>

                            <div class="mb-4 p-3 bg-dark rounded border">
                                <label class="form-label fw-bold text-light">
                                    <i class="bi bi-paperclip"></i> Dowód utrzymania postanowienia
                                    <span class="badge bg-secondary ms-2">opcjonalne +5 pkt</span>
                                </label>
                                <p class="small text-muted mb-2">Zrzut ekranu usuniętej aplikacji, zdjęcie z siłowni,
                                    cokolwiek co pomogło Ci w trzeźwości.</p>
                                    <input type="file" name="attachment" class="form-control" accept=".jpg,.jpeg,.png,.pdf" />
                                </div>

                                <button type="submit" class="btn btn-success btn-lg w-100">
                                    Zapisz raport i odbierz punkty <i class="bi bi-star-fill text-warning ms-1"></i>
                                </button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.prompt-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const textarea = document.getElementById('reportContent');
                const prompt = this.getAttribute('data-prompt');
                if (textarea.value.trim() === '') {
                    textarea.value = prompt + '\n\n';
                } else {
                    textarea.value += '\n\n' + prompt + '\n\n';
                }
                textarea.focus();
                textarea.setSelectionRange(textarea.value.length, textarea.value.length);
            });
        });
    </script>
