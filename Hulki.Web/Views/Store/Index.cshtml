@model IEnumerable<Hulki.Web.Models.Game>

@{
    ViewData["Title"] = "Sklep z Nagrodami";
}

<div class="container mt-4">

    <!-- HEADER SKLEPU (Dokładnie jak na Twoim screenie) -->
    <div class="card bg-dark text-light border-light-subtle mb-4">
        <div class="card-body d-flex justify-content-between align-items-center p-4">
            <div>
                <h2 class="text-primary fw-bold mb-1">Sklep z Nagrodami</h2>
                <p class="text-muted mb-0">Wymieniaj punkty z Dzienniczka na ekskluzywne wyposażenie.</p>
            </div>
            <div class="text-end">
                <h6 class="text-uppercase text-muted fw-bold mb-1" style="letter-spacing: 1px;">Twój portfel</h6>
                <h2 class="text-success fw-bold mb-0">@ViewBag.Points</h2>
            </div>
        </div>
    </div>

    <!-- KOMUNIKATY (Błędy i sukcesy) -->
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm border-0">@TempData["ErrorMessage"]</div>
    }
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm border-0">@TempData["SuccessMessage"]</div>
    }

    <!-- PRZYCISK TYLKO DLA TERAPEUTY / ADMINA -->
    @if (User.IsInRole("Admin") || User.IsInRole("Terapeuta"))
    {
        <div class="text-end mb-4">
            <button type="button" class="btn btn-outline-info fw-bold" data-bs-toggle="modal"
                    data-bs-target="#addItemModal">
                <i class="bi bi-plus-circle"></i> Dodaj nowy przedmiot do puli
            </button>
        </div>
    }

    <!-- MODAL (Formularz) -->
    <div class="modal fade" id="addItemModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content bg-dark text-light border-secondary shadow-lg">

                <div class="modal-header border-secondary">
                    <h5 class="modal-title text-info fw-bold">Kreator Nagród</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>

                <form asp-controller="Store" asp-action="AddRewardItem" method="post">
                    <div class="modal-body">
                        <p class="text-muted small">Przedmiot zostanie natychmiast dodany do ogólnej puli losowań w
                            sklepie.</p>

                            <div class="mb-3">
                                <label class="form-label">Nazwa przedmiotu</label>
                                <input type="text" name="name" class="form-control bg-dark text-light border-secondary"
                                       required placeholder="np. Złoty Miecz Trzeźwości" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Rzadkość</label>
                                <select name="itemRarityId" class="form-select bg-dark text-light border-secondary"
                                        required>
                                    @if (ViewBag.Rarities != null)
                                    {
                                        foreach (var rarity in ViewBag.Rarities)
                                        {
                                            <option value="@rarity.Id">@rarity.Name</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Opis</label>
                                <textarea name="description" class="form-control bg-dark text-light border-secondary"
                                          rows="2" placeholder="Krótki opis przedmiotu"></textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Cena (pkt)</label>
                                <input type="number" min="0" name="price" value="0"
                                       class="form-control bg-dark text-light border-secondary" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Ścieżka do ikony</label>
                                <input type="text" name="iconPath" class="form-control bg-dark text-light border-secondary"
                                       placeholder="/images/shop/icon.png" />
                            </div>
                        </div>
                        <div class="modal-footer border-secondary">
                            <button type="button" class="btn px-4" data-bs-dismiss="modal"
                                    style="color: #DA292E; border: 1px solid #DA292E; background-color: transparent; transition: all 0.2s ease-in-out;"
                                    onmouseover="this.style.backgroundColor='#DA292E'; this.style.color='#ffffff';"
                                    onmouseout="this.style.backgroundColor='transparent'; this.style.color='#DA292E';">
                                Anuluj
                            </button>
                            <button type="submit" class="btn btn-info fw-bold">Zapisz przedmiot</button>
                        </div>
                    </form>

                </div>
            </div>
        </div>

        <!-- LISTA GIER -->
        <div class="row">
            @foreach (var game in Model)
            {
                // MAGIA: Dynamiczne dobieranie akcji z kontrolera na podstawie typu gry!
                string actionName = "PlayRoulette"; // Domyślnie ładujemy ruletkę dla bezpieczeństwa

                if (game.GameType?.Name == "Zdrapka")
                {
                    actionName = "PlayScratchcard";
                }
                else if (game.GameType?.Name == "3 Karty")
                {
                    actionName = "PlayCards";
                }
                else if (game.GameType?.Name == "Lootbox" || game.GameType?.Name == "Koło Fortuny")
                {
                    actionName = "PlayRoulette";
                }

                <div class="col-md-4 mb-4">
                    <div class="card h-100 bg-dark text-light border-light-subtle shadow-sm">
                        <div class="card-header text-center border-bottom border-light-subtle pt-4 pb-3">
                            <h4 class="card-title fw-bold mb-0">@game.Name</h4>
                        </div>
                        <div class="card-body text-center d-flex align-items-center justify-content-center p-4">
                            <p class="card-text text-muted mb-0">@game.Description</p>
                        </div>
                        <div class="card-footer bg-dark border-top-0 p-4 pt-0">
                            <!-- FORMULARZ WYSYŁAJĄCY DO ODPOWIEDNIEJ METODY -->
                            <form asp-controller="Store" asp-action="@actionName" method="post">
                                <input type="hidden" name="gameId" value="@game.Id" />
                                <button type="submit" class="btn btn-warning w-100 fw-bold rounded-3 py-2" style="color: #000;">
                                    Otwórz za @game.Cost pkt
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>