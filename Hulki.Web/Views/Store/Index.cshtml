@model IEnumerable<Hulki.Web.Models.Game>
@{
    ViewData["Title"] = "Sklep i Nagrody";
}

<div class="container mt-5">
    
    <div class="d-flex justify-content-between align-items-center mb-5 bg-dark-subtle p-4 rounded shadow-sm border border-light-subtle">
        <div>
            <h2 class="m-0 text-primary fw-bold"><i class="bi bi-shop"></i> Sklep z Nagrodami</h2>
            <p class="text-muted m-0">Wymieniaj punkty z Dzienniczka na ekskluzywne wyposażenie.</p>
        </div>
        <div class="text-center">
            <span class="text-muted small text-uppercase fw-bold">Twój Portfel</span>
            <h2 class="m-0 text-success fw-bold">@ViewBag.Points <i class="bi bi-star-fill text-warning"></i></h2>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm p-4 fs-5 fw-bold text-center border-success">
            @TempData["SuccessMessage"]
        </div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm text-center fw-bold">
            @TempData["ErrorMessage"]
        </div>
    }

    <div class="row">
        @foreach (var game in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow border border-light-subtle h-100 text-center bg-dark-subtle">
                    <div class="card-header bg-dark text-white p-3 bg-dark-subtle">
                        <h4 class="m-0">@game.Name</h4>
                    </div>
                    <div class="card-body d-flex flex-column justify-content-between p-4">
                        <i class="bi bi-box-seam text-primary mb-3" style="font-size: 5rem;"></i>
                        <p class="text-muted">@game.Description</p>
                        
                        <form asp-controller="Store" asp-action="OpenLootbox" method="post">
                            <input type="hidden" name="gameId" value="@game.Id" />
                            @if (ViewBag.Points >= game.Cost)
                            {
                                <button type="submit" class="btn btn-warning btn-lg w-100 fw-bold">
                                    Otwórz za @game.Cost pkt <i class="bi bi-star-fill text-dark"></i>
                                </button>
                            }
                            else
                            {
                                <button type="button" class="btn btn-secondary btn-lg w-100 fw-bold" disabled>
                                    Za mało punktów (@game.Cost pkt)
                                </button>
                            }
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
</div>