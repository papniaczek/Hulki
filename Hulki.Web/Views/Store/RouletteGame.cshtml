@{
    ViewData["Title"] = "Otwieranie Skrzyni";
    var wonItem = ViewBag.WonItem as Hulki.Web.Models.RewardItem;
}

<style>
    .roulette-header {
        background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
        border: 1px solid rgba(70, 204, 94, 0.15);
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .roulette-header-glow-left {
        position: absolute;
        top: -70px;
        left: -50px;
        width: 450px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.15) 0%, transparent 80%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .roulette-header-glow-right {
        position: absolute;
        top: -70px;
        right: -80px;
        width: 450px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.15) 0%, transparent 80%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .roulette-header-glow-center {
        position: absolute;
        top: -70px;
        right: 300px;
        width: 700px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 81, 0.15) 0%, transparent 80%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .roulette-header h2 {
        position: relative;
        z-index: 1;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .roulette-header p {
        position: relative;
        z-index: 1;
        margin: 10px 0 0 0;
    }

    .roulette-container {
        position: relative;
        width: 100%;
        max-width: 800px;
        height: 180px;
        margin: 0 auto;
        background: #1b1b22;
        border: 1px solid rgba(70, 204, 94, 0.2);
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 10px 25px rgba(70, 204, 94, 0.15);
        transition: all 0.3s ease;
    }

    .roulette-pointer {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 4px;
        height: 100%;
        background: #46CC5E;
        z-index: 10;
        box-shadow: 0 0 15px rgba(70, 204, 94, 0.6);
    }

    .roulette-track {
        display: flex;
        height: 100%;
        width: max-content;
        transition: transform 6s cubic-bezier(0.1, 0.8, 0.15, 1);
    }

    .roulette-item {
        width: 150px;
        height: 100%;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-right: 1px solid rgba(70, 204, 94, 0.1);
        padding: 10px;
        text-align: center;
        background: linear-gradient(180deg, #1f1f27 0%, #1a1a20 100%);
    }

    .btn-success {
        background-color: #46CC5E;
        border-color: #46CC5E;
        transition: all 0.3s ease;
    }

    .btn-success:hover {
        box-shadow: 0 0 15px rgba(70, 204, 94, 0.4);
    }

    #retry-btn {
        animation: fadeInUp 0.4s ease;
    }
</style>

<div class="container mt-5 text-center text-light">
    <div class="roulette-header">
        <div class="roulette-header-glow-left"></div>
        <div class="roulette-header-glow-center"></div>
        <div class="roulette-header-glow-right"></div>
        <h2 class="text-light" style="text-shadow: 0 2px 8px rgba(0, 0, 0, 1)">Otwieranie Skrzyni</h2>
        <p class="text-muted" style="text-shadow: 0 2px 8px rgba(0, 0, 0, 1)">Zobaczmy, co przygotował dla Ciebie los!</p>
    </div>

    <div class="roulette-container shadow-lg">
        <div class="roulette-pointer"></div>
        <div class="roulette-track" id="roulette-track"></div>
    </div>

    <button id="spin-btn" class="btn btn-success px-5 py-3 fw-bold mt-5" onclick="spinRoulette()">
        LOSUJ!
    </button>


    <form asp-controller="Store" asp-action="PlayRoulette" method="post" id="retry-form" class="d-none mt-3">
        <input type="hidden" name="gameId" value="@ViewBag.GameId"/>
        <button type="submit" id="retry-btn" class="btn btn-success px-5 py-3 fw-bold" style="margin-top: 28px">
            <i class="bi bi-arrow-repeat me-2"></i><strong>SPRÓBUJ PONOWNIE! (@ViewBag.GameCost PKT)</strong>
        </button>
    </form>

    <div id="result-message" class="mt-4 alert alert-success d-none bg-dark text-success border-success">
        <h4 class="mb-3">@Html.Raw(ViewBag.Message)</h4>
        <a asp-action="Index" class="btn btn-outline-success px-4 py-2">Wróć do sklepu</a>
    </div>
</div>

<script>
    const allItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AllRewards));
    const wonItem = { name: "@Html.Raw(wonItem.Name)", rarity: "@Html.Raw(wonItem.ItemRarity.Name)" };

    const track = document.getElementById('roulette-track');
    const itemWidth = 150;
    const totalItems = 60;
    const winIndex = 50;

    window.onload = () => {
        for (let i = 0; i < totalItems; i++) {
            let itemData = (i === winIndex) ? wonItem : allItems[Math.floor(Math.random() * allItems.length)];
            let colorStyle =
                itemData.rarity === 'Legendarny' ? '#ffc107' :
                    itemData.rarity === 'Epicki' ? '#6F42C1' :
                        itemData.rarity === 'Rzadki' ? '#0D6EFD' :
                            itemData.rarity === 'Niepospolity' ? '#198754' :
                                itemData.rarity === 'Mityczny' ? '#DC3545' :
                                    '#f8f9fa';
            let el = document.createElement('div');
            el.className = 'roulette-item';
            el.innerHTML = `<span class="badge bg-secondary mb-3">${itemData.rarity}</span>
                <span class="small fw-bold" style="color:${colorStyle}">${itemData.name}</span>`;
            track.appendChild(el);
        }
    };

    function spinRoulette() {
        document.getElementById('spin-btn').disabled = true;

        const containerWidth = document.querySelector('.roulette-container').offsetWidth;
        let randomOffset = Math.floor(Math.random() * (itemWidth - 20)) - ((itemWidth - 20) / 2);
        let finalOffset = (winIndex * itemWidth) + (itemWidth / 2) - (containerWidth / 2) + randomOffset;

        track.style.transform = `translateX(-${finalOffset}px)`;

        setTimeout(() => {
            document.getElementById('result-message').classList.remove('d-none');
            document.getElementById('spin-btn').style.display = 'none';
            document.getElementById('retry-form').classList.remove('d-none');
        }, 6000);
    }
</script>
