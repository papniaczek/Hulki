@{
    ViewData["Title"] = "Otwieranie Skrzyni";
    var wonItem = ViewBag.WonItem as Hulki.Web.Models.RewardItem;
}

<style>
    /* Stylowanie całej ruletki */
    .roulette-container {
        position: relative;
        width: 100%;
        max-width: 800px;
        height: 180px;
        margin: 0 auto;
        background: #1c1f23;
        border: 2px solid #343a40;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: inset 0 0 25px rgba(0,0,0,0.9);
    }
    
    /* Złoty pasek po środku wyznaczający wygraną */
    .roulette-pointer {
        position: absolute;
        top: 0;
        left: 50%;
        transform: translateX(-50%);
        width: 4px;
        height: 100%;
        background: #ffc107;
        z-index: 10;
        box-shadow: 0 0 15px #ffc107;
    }

    /* Pasek po którym suną przedmioty */
    .roulette-track {
        display: flex;
        height: 100%;
        width: max-content;
        /* Wykres cubic-bezier odpowiada za realistyczne "zwalnianie" ruletki */
        transition: transform 6s cubic-bezier(0.1, 0.8, 0.15, 1);
    }

    /* Wygląd pojedynczego przedmiotu */
    .roulette-item {
        width: 150px;
        height: 100%;
        flex-shrink: 0;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        border-right: 1px solid #2b3035;
        padding: 10px;
        text-align: center;
        background: linear-gradient(180deg, #212529 0%, #1a1d20 100%);
    }
</style>

<div class="container mt-5 text-center text-light">
    <h2>Trwa otwieranie skrzyni...</h2>
    <p class="text-muted mb-5">Zobaczmy, co przygotował dla Ciebie los!</p>

    <!-- Kontener Ruletki -->
    <div class="roulette-container shadow-lg">
        <div class="roulette-pointer"></div>
        <div class="roulette-track" id="roulette-track">    
            <!-- Tutaj JS dynamicznie wygeneruje elementy -->
        </div>
    </div>

    <!-- Zaczynamy animację w momencie kliknięcia przycisku -->
    <button id="spin-btn" class="btn btn-warning px-5 py-3 fw-bold mt-5" onclick="spinRoulette()">
        LOSUJ!
    </button>

    <!-- Komunikat z wynikiem, ukryty domyślnie -->
    <div id="result-message" class="mt-4 alert alert-success d-none bg-dark text-success border-success">
        <h4 class="mb-3">@Html.Raw(ViewBag.Message)</h4>
        <a asp-action="Index" class="btn btn-outline-success px-4 py-2">Wróć do sklepu</a>
    </div>
</div>

<!-- Serializujemy listę z C# prosto do zmiennej w JavaScript -->
<script>
    const allItems = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(ViewBag.AllRewards));
    const wonItem = { name: "@Html.Raw(wonItem.Name)", rarity: "@Html.Raw(wonItem.ItemRarity.Name)" };
    
    const track = document.getElementById('roulette-track');
    const itemWidth = 150; // Szerokość zadeklarowana w CSS
    const totalItems = 60; // Całkowita ilość przedmiotów w taśmociągu
    const winIndex = 50;   // Pozycja w taśmociągu, na której znajdzie się nasz wygrany przedmiot

    // Krok 1: Wypełnianie ruletki elementami zaraz po wczytaniu okna
    window.onload = () => {
        for(let i = 0; i < totalItems; i++) {
            // Jeśli to nasza docelowa pozycja (50), wstawiamy gwarantowaną wygraną.
            // W przeciwnym razie losujemy byle co z listy dla "tła".
            let itemData = (i === winIndex) ? wonItem : allItems[Math.floor(Math.random() * allItems.length)];
            
            let colorClass = itemData.rarity === 'Legendarny' ? 'text-warning' : 'text-light';
            
            let el = document.createElement('div');
            el.className = 'roulette-item';
            el.innerHTML = `<span class="badge bg-secondary mb-3">${itemData.rarity}</span>
                            <span class="small fw-bold ${colorClass}">${itemData.name}</span>`;
            track.appendChild(el);
        }
    };

    // Krok 2: Odpalanie obrotu po kliknięciu
    function spinRoulette() {
        document.getElementById('spin-btn').disabled = true; // Blokujemy przycisk
        
        const containerWidth = document.querySelector('.roulette-container').offsetWidth;
        
        // Chcemy zatrzymać się w losowym miejscu na środku "wygrywającego" kafelka (winIndex)
        // Obliczamy o ile przesunąć oś X. (Środek okna to połowa containerWidth)
        let randomOffset = Math.floor(Math.random() * (itemWidth - 20)) - ((itemWidth - 20) / 2);
        let finalOffset = (winIndex * itemWidth) + (itemWidth / 2) - (containerWidth / 2) + randomOffset;
        
        // Uruchamiamy animację przesuwania
        track.style.transform = `translateX(-${finalOffset}px)`;
        
        // Odkrywamy przycisk "Wróć" i wynik dokładnie po 6 sekundach (tyle trwa animacja w CSS)
        setTimeout(() => {
            document.getElementById('result-message').classList.remove('d-none');
            document.getElementById('spin-btn').style.display = 'none'; // Zwijamy przycisk
        }, 6000); 
    }
</script>