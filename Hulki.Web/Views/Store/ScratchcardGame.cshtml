@{
    ViewData["Title"] = "Szczęśliwa Zdrapka";
    var wonItem = ViewBag.WonItem as Hulki.Web.Models.RewardItem;
}

<style>
    .scratch-container { position: relative; width: 350px; height: 250px; margin: 0 auto; border-radius: 10px; overflow: hidden; border: 2px solid #6c757d;}
    
    .scratch-result { position: absolute; width: 100%; height: 100%; background: #212529; color: white; display: flex; align-items: center; justify-content: center; flex-direction: column; z-index: 1; }
    
    .scratch-cover { position: absolute; width: 100%; height: 100%; background: repeating-linear-gradient(45deg, #495057, #495057 10px, #343a40 10px, #343a40 20px); z-index: 2; display: flex; align-items: center; justify-content: center; color: #adb5bd; font-weight: bold; font-size: 1.5rem; cursor: pointer; transition: opacity 1.5s ease-out; }
    
    /* Nowa klasa, którą dodaje JS */
    .scratch-cover.scratched { opacity: 0; pointer-events: none; }
    
    
</style>

<div class="container mt-5 text-center text-light">
    <h2>Szczęśliwa Zdrapka</h2>
    <p class="text-muted">Przejedź kursorem lub kliknij w szare pole, aby odkryć nagrodę!</p>

    <div class="scratch-container mt-5">
        <!-- Zwycięski przedmiot (ukryty pod spodem) -->
        <div class="scratch-result">
            @if (!string.IsNullOrWhiteSpace(wonItem.IconPath))
            {
                <img src="@wonItem.IconPath" alt="@wonItem.Name"
                     class="mb-2 rounded"
                     style="width:4rem;height:4rem;object-fit:cover;"
                     onerror="this.onerror=null;this.outerHTML='<i class=\'bi bi-box-seam text-warning mb-2\' style=\'font-size:3rem;\'></i>';" />
            }
            else
            {
                <i class="bi bi-box-seam text-warning mb-2" style="font-size:3rem;" title="Brak przypisanej grafiki"></i>
            }
            <h4 class="text-warning fw-bold mb-3">@Html.Raw(wonItem.Name)</h4>
            <span class="badge bg-light text-dark mb-3" style="letter-spacing: 1px;">@Html.Raw(wonItem.ItemRarity.Name)</span>
            <p class="text-success small fw-bold">@Html.Raw(ViewBag.Message)</p>
        </div>
        
        <!-- Szare pole zdrapki -->
        <div class="scratch-cover" id="cover-layer" onclick="scratchIt()">
            <i class="bi bi-magic me-2"></i> KLIKNIJ, ABY ZDRAPAĆ
        </div>
    </div>

    <div id="btn-back" class="mt-5" style="visibility: hidden; opacity: 0; transition: opacity 1s;">
        <a asp-action="Index" class="btn btn-outline-warning px-5 py-2 fw-bold">Wróć do sklepu</a>
    </div>
</div>

<script>
    let isScratched = false;

    function scratchIt() {
        if (isScratched) return;
        isScratched = true;

        const cover = document.getElementById('cover-layer');
        const btnBack = document.getElementById('btn-back');

        // Bezpowrotnie usuwamy warstwę nakładki (dodając klasę opacity 0)
        cover.classList.add('scratched');

        // Gdy warstwa zniknie, pokazujemy przycisk powrotu
        setTimeout(() => {
            btnBack.style.visibility = 'visible';
            btnBack.style.opacity = '1';
        }, 1500);
    }
</script>