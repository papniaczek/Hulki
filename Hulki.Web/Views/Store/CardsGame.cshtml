@{
    ViewData["Title"] = "Wybierz Kartę!";
    var wonItem = ViewBag.WonItem as Hulki.Web.Models.RewardItem;
    var missed1 = ViewBag.Missed1 as Hulki.Web.Models.RewardItem;
    var missed2 = ViewBag.Missed2 as Hulki.Web.Models.RewardItem;
}

<style>
    .cards-header {
        background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
        border: 1px solid rgba(70, 204, 94, 0.15);
        border-radius: 12px;
        padding: 30px;
        margin-bottom: 30px;
        position: relative;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .cards-header-glow-left {
        position: absolute;
        top: -70px;
        left: -50px;
        width: 350px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.15) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .cards-header-glow-right {
        position: absolute;
        top: -70px;
        right: -80px;
        width: 350px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.15) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .cards-header h2 {
        position: relative;
        z-index: 1;
        margin: 0;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .cards-header p {
        position: relative;
        z-index: 1;
        margin: 10px 0 0 0;
    }

    .flip-card {
        background-color: transparent;
        width: 100%;
        height: 300px;
        perspective: 1000px;
        cursor: pointer;
    }

    .flip-card-inner {
        position: relative;
        width: 100%;
        height: 100%;
        text-align: center;
        transition: transform 0.6s;
        transform-style: preserve-3d;
    }

    .flip-card.flipped .flip-card-inner {
        transform: rotateY(180deg);
    }

    .flip-card-front,
    .flip-card-back {
        position: absolute;
        width: 100%;
        height: 100%;
        -webkit-backface-visibility: hidden;
        backface-visibility: hidden;
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        padding: 20px;
    }

    .flip-card-front {
        background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
        color: white;
        border: 2px solid rgba(70, 204, 94, 0.3);
        box-shadow: 0 0 15px rgba(70, 204, 94, 0.15);
        transition: all 0.3s ease;
    }

    .flip-card-front:hover {
        border-color: rgba(70, 204, 94, 0.6);
        box-shadow: 0 0 20px rgba(70, 204, 94, 0.25);
    }

    .flip-card-back {
        background: linear-gradient(135deg, #1f1f27 0%, #1a1a20 100%);
        color: white;
        transform: rotateY(180deg);
        border: 1px solid rgba(70, 204, 94, 0.2);
    }

    .winner-card {
        background: linear-gradient(135deg, #46CC5E 0%, #3daa4a 100%);
        color: #000;
        border: 2px solid #46CC5E;
        box-shadow: 0 0 20px rgba(70, 204, 94, 0.4);
    }

    .winner-card h5 {
        color: #000;
    }
</style>

<div class="container mt-5 text-center text-light">
    <div class="cards-header">
        <div class="cards-header-glow-left"></div>
        <div class="cards-header-glow-center"></div>
        <div class="cards-header-glow-right"></div>
        <h2 class="text-light">Zaufaj swojemu instynktowi</h2>
        <p class="text-muted">Wybierz jedną z kart, aby poznać swoją nagrodę!</p>
    </div>

    <div class="row mt-5" id="cards-container">
        @for (int i = 0; i < 3; i++)
        {
            <div class="col-md-4 mb-4">
                <div class="flip-card" onclick="revealCard(this)">
                    <div class="flip-card-inner shadow">
                        <div class="flip-card-front">
                            <h1>
                                <i class="bi bi-question-circle" style="font-size: 4rem; color: #46CC5E;"></i>
                            </h1>
                            <p class="mt-3" style="color: #46CC5E;">Kliknij mnie</p>
                        </div>
                        <div class="flip-card-back">
                            <h5 class="item-name fw-bold mb-3"></h5>
                            <span class="badge item-rarity text-uppercase" style="letter-spacing: 1px; color: #000; background-color: rgba(255,255,255,0.7);"></span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    <div id="result-message" class="mt-4 alert alert-success d-none bg-dark text-success border-success">
        <h4 class="mb-3">@Html.Raw(ViewBag.Message)</h4>
        <a asp-action="Index" class="btn btn-outline-success px-4 py-2">Wróć do sklepu</a>
    </div>
</div>

<script>
    let isRevealed = false;


    const wonItemName = "@Html.Raw(wonItem.Name)";
    const wonItemRarity = "@Html.Raw(wonItem.ItemRarity.Name)";
    const missedItems = [
        { name: "@Html.Raw(missed1.Name)", rarity: "@Html.Raw(missed1.ItemRarity.Name)" },
        { name: "@Html.Raw(missed2.Name)", rarity: "@Html.Raw(missed2.ItemRarity.Name)" }
    ];

    function revealCard(clickedCard) {
        if (isRevealed) return;
        isRevealed = true;

        const allCards = document.querySelectorAll('.flip-card');
        let missedIndex = 0;

        allCards.forEach(card => {
            const backFace = card.querySelector('.flip-card-back');
            const nameEl = backFace.querySelector('.item-name');
            const rarityEl = backFace.querySelector('.item-rarity');

            if (card === clickedCard) {

                nameEl.innerText = wonItemName;
                rarityEl.innerText = wonItemRarity;
                backFace.classList.add('winner-card');
                card.classList.add('flipped');
            } else {

                nameEl.innerText = missedItems[missedIndex].name;
                rarityEl.innerText = missedItems[missedIndex].rarity;

                setTimeout(() => {
                    card.classList.add('flipped');
                    backFace.style.opacity = "0.5";
                }, 1000 + (missedIndex * 500));
                missedIndex++;
            }
        });

        setTimeout(() => {
            document.getElementById('result-message').classList.remove('d-none');
        }, 1500);
    }
</script>