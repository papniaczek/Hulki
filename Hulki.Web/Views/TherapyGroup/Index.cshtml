@model IEnumerable<Hulki.Web.Models.TherapyGroup>

@{
    ViewData["Title"] = "Grupy Wspierające";
    string currentUserId = ViewBag.CurrentUserId as string;
}

<div class="container mt-4 text-light">

    <div class="card bg-dark text-light border-secondary mb-4">
        <div class="card-body d-flex justify-content-between align-items-center p-4">
            <div>
                <h2 class="text-primary fw-bold mb-1">Grupy Wsparcia Terapeutycznego</h2>
                <p class="text-muted mb-0">Dołącz do bezpiecznej przestrzeni i walcz o lepsze jutro razem z innymi.</p>
            </div>
            @if (User.IsInRole("Admin") || User.IsInRole("Terapeuta"))
            {
                <div>
                    <a asp-action="Create" class="btn btn-success fw-bold px-4 py-2">
                        <i class="bi bi-plus-lg me-1"></i> Stwórz nową grupę
                    </a>
                </div>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success bg-dark text-success border-success shadow-sm mb-4">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger bg-dark text-danger border-danger shadow-sm mb-4">@TempData["ErrorMessage"]</div>
    }

    <div class="row">
        @foreach (var group in Model)
        {
            // Liczymy tylko zatwierdzonych uczestników w grupie
            int approvedCount = group.PatientGroups?.Count(pg => pg.IsApproved) ?? 0;

            // Szukamy rekordu powiązania aktualnego użytkownika z tą grupą
            var userMembership = group.PatientGroups?.FirstOrDefault(pg => pg.AppUserId == currentUserId);

            <div class="col-md-6 mb-4">
                <div class="card h-100 bg-dark text-light border-secondary shadow-sm d-flex flex-column justify-content-between">

                    <div class="card-body p-4">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h4 class="text-info fw-bold mb-0">@group.Name</h4>
                            <span class="badge bg-secondary text-uppercase px-2 py-1 small">@group.TherapyType?.Name</span>
                        </div>

                        <p class="text-muted mb-4" style="min-height: 50px;">@group.Description</p>

                        <div class="d-flex align-items-center justify-content-between text-muted small border-top border-secondary pt-3">
                            <div>
                                <i class="bi bi-people-fill me-1 text-primary"></i>
                                Uczestnicy: <strong class="text-light">@approvedCount / @group.MaxParticipants</strong>
                            </div>

                            <div>
                                @if (userMembership != null)
                                {
                                    if (userMembership.IsApproved)
                                    {
                                        <span class="badge bg-success px-3 py-2 text-uppercase fw-bold"><i class="bi bi-patch-check-fill me-1"></i> Członek</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark px-3 py-2 text-uppercase fw-bold"><i class="bi bi-hourglass-split me-1"></i> Oczekuje</span>
                                    }
                                }
                            </div>
                        </div>
                    </div>

                    <div class="card-footer bg-dark border-top-0 p-4 pt-0 d-flex flex-column gap-2">
                        @if (User.IsInRole("Admin") || User.IsInRole("Terapeuta"))
                        {
                            <a asp-action="Details" asp-route-id="@group.Id" class="btn btn-success w-100 fw-bold py-2">
                                <i class="bi bi-door-open-fill me-1"></i> Wejdź do grupy
                            </a>

                            <div class="d-flex gap-2 w-100">
                                <a asp-action="Manage" asp-route-id="@group.Id" class="btn btn-outline-info flex-grow-1 fw-bold" title="Zarządzaj wnioskami pacjentów">
                                    <i class="bi bi-shield-check me-1"></i> Wnioski (@group.PatientGroups?.Count(pg => !pg.IsApproved))
                                </a>
                                <a asp-action="Edit" asp-route-id="@group.Id" class="btn btn-outline-warning fw-bold" title="Edytuj grupę">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <form asp-action="Delete" asp-route-id="@group.Id" method="post" onsubmit="return confirm('Czy na pewno usunąć grupę? Spowoduje to wypisanie wszystkich pacjentów.');" class="d-inline">
                                    <button type="submit" class="btn btn-outline-danger fw-bold" title="Usuń grupę">
                                        <i class="bi bi-trash3-fill"></i>
                                    </button>
                                </form>
                            </div>
                        }
                        else
                        {
                            if (userMembership == null)
                            {
                                if (approvedCount >= group.MaxParticipants)
                                {
                                    <button class="btn btn-danger w-100 fw-bold py-2" disabled>Brak wolnych miejsc</button>
                                }
                                else
                                {
                                    <form asp-action="Join" method="post" class="w-100">
                                        <input type="hidden" name="id" value="@group.Id"/>
                                        <button type="submit" class="btn btn-primary w-100 fw-bold py-2">
                                            <i class="bi bi-box-arrow-in-right me-1"></i> Zapisz się do grupy
                                        </button>
                                    </form>
                                }
                            }
                            else if (!userMembership.IsApproved)
                            {
                                <button class="btn btn-outline-warning w-100 fw-bold py-2" disabled style="opacity: 0.7;">
                                    <i class="bi bi-clock-history me-1"></i> Oczekiwanie na decyzję terapeuty...
                                </button>
                            }
                            else
                            {
                                <a asp-action="Details" asp-route-id="@group.Id" class="btn btn-success w-100 fw-bold py-2">
                                    <i class="bi bi-door-open-fill me-1"></i> Wejdź do grupy
                                </a>
                            }
                        }
                    </div>

                </div>
            </div>
        }
    </div>
</div>