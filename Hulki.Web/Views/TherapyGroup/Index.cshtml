@model IEnumerable<Hulki.Web.Models.TherapyGroup>
@{
    ViewData["Title"] = "Grupy Wsparcia";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-people-fill text-primary"></i> Panele Terapii</h2>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-lg"></i> Dodaj nową grupę</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm">
            @TempData["SuccessMessage"]
        </div>
    }

    <div class="card shadow-sm border-0">
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Nazwa Grupy</th>
                        <th>Opis</th>
                        <th>Typ Terapii</th>
                        <th class="text-end">Akcje</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold align-middle">@item.Name</td>
                                <td class="align-middle text-muted">@item.Description</td>
                                <td class="align-middle"><span class="badge bg-info text-dark">@item.TherapyType?.Name</span></td>
                                <td class="text-end align-middle">
                                    <div class="btn-group" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Edytuj</a>
                                        <form asp-action="Delete" asp-route-id="@item.Id" method="post" class="d-inline" onsubmit="return confirm('Czy na pewno chcesz usunąć tę grupę?');">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">Usuń</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="4" class="text-center p-4 text-muted">Brak grup w systemie. Dodaj pierwszą!</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>