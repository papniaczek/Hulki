@model Hulki.Web.Models.TherapyGroup

@{
    ViewData["Title"] = "Edytuj grupę: " + Model.Name;
}

<div class="container mt-4 mb-5 text-light">

    <div class="edit-header-card mb-4 p-4 p-md-5 position-relative overflow-hidden rounded-4">
        <div class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div>
                <h2 class="text-warning fw-bold mb-1 text-uppercase" style="letter-spacing: 1px;">
                    Edycja: @Model.Name
                </h2>
                <p class="text-light mb-0 fs-5 fw-light opacity-75">
                    Aktualizuj ustawienia grupy terapeutycznej.
                </p>
            </div>
            <div class="mt-3 mt-md-0">
                <a asp-action="Index" class="btn btn-light fw-bold rounded-pill px-4 text-uppercase custom-btn-nav">
                    <i class="bi bi-arrow-left me-2"></i>Wróć do listy
                </a>
            </div>
        </div>
        <div class="edit-glow"></div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card dark-panel-card rounded-4 border-0">
                <div class="card-body p-4 p-md-5">

                    <form asp-action="Edit" method="post">
                        <input type="hidden" asp-for="Id"/>
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm rounded-3 mb-4"></div>

                        <div class="mb-4 position-relative">
                            <label asp-for="Name" class="form-label text-info fw-bold text-uppercase small" style="letter-spacing: 0.5px;">Nazwa grupy <span class="text-danger">*</span></label>
                            <input asp-for="Name" class="form-control custom-input" required
                                   data-val="true" data-val-required="Nazwa grupy nie może być puste."/>
                            <span asp-validation-for="Name" class="custom-val-error"></span>
                        </div>

                        <div class="mb-4 position-relative">
                            <label asp-for="TherapyTypeId" class="form-label text-info fw-bold text-uppercase small" style="letter-spacing: 0.5px;">Rodzaj Terapii <span class="text-danger">*</span></label>
                            <select asp-for="TherapyTypeId" class="form-select custom-input" required
                                    data-val="true" data-val-required="Rodzaj terapii nie może być puste.">
                                <option value="">-- Wybierz rodzaj terapii --</option>
                                @if (ViewBag.TherapyTypes != null)
                                {
                                    foreach (var type in ViewBag.TherapyTypes)
                                    {
                                        <option value="@type.Id">@type.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="TherapyTypeId" class="custom-val-error"></span>
                        </div>

                        <div class="mb-4 position-relative">
                            <label asp-for="MaxParticipants" class="form-label text-info fw-bold text-uppercase small" style="letter-spacing: 0.5px;">Maksymalna liczba uczestników <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark text-info border-secondary">
                                    <i class="bi bi-people-fill"></i>
                                </span>
                                <input asp-for="MaxParticipants" class="form-control custom-input" type="number" min="2" max="100" required
                                       data-val="true" data-val-required="Maksymalna liczba uczestników nie może być puste."/>
                            </div>
                            <span asp-validation-for="MaxParticipants" class="custom-val-error"></span>
                        </div>

                        <div class="mb-5 position-relative">
                            <label asp-for="Description" class="form-label text-info fw-bold text-uppercase small" style="letter-spacing: 0.5px;">Opis i zasady grupy</label>
                            <textarea asp-for="Description" class="form-control custom-input" rows="4" data-val-required="Opis i zasady grupy są wymagane!"></textarea>
                            <span asp-validation-for="Description" class="custom-val-error"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-warning btn-lg fw-bold rounded-pill text-uppercase custom-glow-btn-warning">
                                <i class="bi bi-save me-2"></i> Zapisz zmiany
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .edit-header-card {
        background: linear-gradient(135deg, #1b1b22 0%, #111116 100%);
        border: 1px solid rgba(255, 193, 7, 0.2);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .edit-glow {
        position: absolute;
        top: -100px;
        right: -50px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(255, 193, 7, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .custom-btn-nav {
        transition: all 0.2s ease;
    }

    .custom-btn-nav:hover {
        box-shadow: 0 0 20px rgba(255, 193, 7, 0.5);
    }


    .dark-panel-card {
        background-color: #1b1b22;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        border-top: 3px solid #ffc107 !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }


    .custom-input {
        background-color: #121217 !important;
        border: 1px solid #3f3f46 !important;
        color: #ffffff !important;
        border-radius: 8px !important;
        padding: 0.8rem 1rem !important;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }

    .custom-input:focus {
        border-color: #ffc107 !important;
        box-shadow: 0 0 15px rgba(255, 193, 7, 0.25) !important;
        outline: none !important;
    }

    .input-group .custom-input {
        border-top-left-radius: 0 !important;
        border-bottom-left-radius: 0 !important;
        border-left: 1px solid #52525b !important;
    }

    .input-group-text {
        background-color: #121217 !important;
        border: 1px solid #3f3f46 !important;
        border-right: none !important;
        border-top-left-radius: 8px !important;
        border-bottom-left-radius: 8px !important;
        padding: 0.8rem 1.2rem !important;
    }

    .custom-glow-btn-warning {
        background-color: #ffc107;
        color: #111116 !important;
        border: none;
        transition: all 0.3s ease;
    }

    .custom-glow-btn-warning:hover {
        background-color: #ffca2c;
        box-shadow: 0 0 20px rgba(255, 193, 7, 0.5);
        transform: translateY(-2px);
    }

    .custom-val-error {
        display: block;
        margin-top: 0.4rem;
        font-size: 0.85rem;
        font-weight: 700;
        color: #ff4d4d;
        text-shadow: 0 0 8px rgba(255, 77, 77, 0.4);
    }

    .input-validation-error {
        border-color: #ff4d4d !important;
        box-shadow: 0 0 10px rgba(255, 77, 77, 0.2) !important;
    }

    .field-validation-error {
        color: #ff4d4d !important;
    }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}