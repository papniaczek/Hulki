@model Hulki.Web.Models.TherapyGroup

@{
    ViewData["Title"] = "Zarządzaj Grupą";
    var pendingRequests = Model.PatientGroups.Where(pg => !pg.IsApproved).ToList();
    var approvedMembers = Model.PatientGroups.Where(pg => pg.IsApproved).ToList();
}

<div class="container mt-4 mb-5 text-light">

    <div class="manage-header-card mb-4 p-4 rounded-4 position-relative overflow-hidden">
        <div class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div>
                <h2 class="fw-bold mb-1 text-warning text-uppercase" style="letter-spacing: 1px;">
                    <i class="bi bi-gear-fill me-2"></i>Zarządzanie: @Model.Name
                </h2>
                <p class="text-light opacity-75 mb-0 fs-5">Pojemność grupy: <strong class="text-white">@approvedMembers.Count / @Model.MaxParticipants</strong></p>
            </div>
            <div class="mt-3 mt-md-0">
                <a asp-action="Index" class="btn btn-light fw-bold rounded-pill px-4 text-uppercase">Wróć do listy</a>
            </div>
        </div>
        <div class="manage-glow"></div>
    </div>

    <div class="row mt-4 g-4">
        <div class="col-md-6">
            <div class="card dark-panel-card rounded-4 h-100" style="border-top: 3px solid #0dcaf0 !important;">
                <div class="card-header bg-transparent border-bottom border-secondary p-4">
                    <h5 class="text-info fw-bold mb-0 text-uppercase" style="letter-spacing: 1px;">
                        <i class="bi bi-person-lines-fill me-2"></i>Wnioski oczekujące <span class="badge bg-info text-dark ms-2 rounded-pill">@pendingRequests.Count</span>
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (pendingRequests.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var request in pendingRequests)
                            {
                                <div class="p-3 bg-dark border border-secondary rounded-4 d-flex justify-content-between align-items-center member-card">
                                    <div>
                                        <strong class="text-light fs-5">@request.AppUser.UserName</strong><br/>
                                        <small class="text-muted fw-bold">Aplikował: @request.JoinedDate.ToShortDateString()</small>
                                    </div>
                                    <div class="d-flex gap-2">
                                        <form asp-action="Approve" method="post" class="m-0">
                                            <input type="hidden" name="groupId" value="@Model.Id"/>
                                            <input type="hidden" name="userId" value="@request.AppUserId"/>
                                            <button type="submit" class="btn btn-success rounded-circle action-btn" title="Zatwierdź">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                        <form asp-action="Reject" method="post" class="m-0">
                                            <input type="hidden" name="groupId" value="@Model.Id"/>
                                            <input type="hidden" name="userId" value="@request.AppUserId"/>
                                            <button type="submit" class="btn btn-danger rounded-circle action-btn" title="Odrzuć">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted opacity-50">
                            <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                            <p class="fw-bold text-uppercase">Brak nowych wniosków</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card dark-panel-card rounded-4 h-100" style="border-top: 3px solid #46CC5E !important;">
                <div class="card-header bg-transparent border-bottom border-secondary p-4">
                    <h5 class="text-success fw-bold mb-0 text-uppercase" style="letter-spacing: 1px;">
                        <i class="bi bi-people-fill me-2"></i>Obecni członkowie <span class="badge bg-success text-dark ms-2 rounded-pill">@approvedMembers.Count</span>
                    </h5>
                </div>
                <div class="card-body p-4">
                    @if (approvedMembers.Any())
                    {
                        <div class="d-flex flex-column gap-3">
                            @foreach (var member in approvedMembers)
                            {
                                <div class="p-3 bg-dark border border-secondary rounded-4 d-flex justify-content-between align-items-center member-card">
                                    <div class="d-flex align-items-center">
                                        <div class="bg-success bg-opacity-10 text-success rounded-circle d-flex justify-content-center align-items-center me-3" style="width: 40px; height: 40px;">
                                            <i class="bi bi-person-check-fill fs-5"></i>
                                        </div>
                                        <strong class="text-light fs-5">@member.AppUser.UserName</strong>
                                    </div>
                                    <form asp-action="Reject" method="post" class="m-0" onsubmit="return confirm('Wyrzucić pacjenta z grupy?');">
                                        <input type="hidden" name="groupId" value="@Model.Id"/>
                                        <input type="hidden" name="userId" value="@member.AppUserId"/>
                                        <button type="submit" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold text-uppercase remove-btn">Usuń</button>
                                    </form>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center py-5 text-muted opacity-50">
                            <i class="bi bi-person-x fs-1 d-block mb-2"></i>
                            <p class="fw-bold text-uppercase">Grupa jest pusta</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .manage-header-card {
        background: linear-gradient(135deg, #1b1b22 0%, #0d0d0f 100%);
        border: 1px solid rgba(255, 193, 7, 0.2);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .manage-glow {
        position: absolute;
        top: -50px;
        left: -50px;
        width: 200px;
        height: 200px;
        background: radial-gradient(circle, rgba(255, 193, 7, 0.15) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .dark-panel-card {
        background-color: #1b1b22;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        box-shadow: 0 5px 15px rgba(0, 0, 0, 0.3);
    }

    .member-card {
        transition: all 0.2s ease;
    }

    .member-card:hover {
        background: #23232c !important;
        border-color: rgba(255, 255, 255, 0.2) !important;
    }

    .action-btn {
        width: 35px;
        height: 35px;
        display: flex;
        justify-content: center;
        align-items: center;
        transition: transform 0.2s;
    }

    .action-btn:hover {
        transform: scale(1.1);
    }

    .remove-btn:hover {
        box-shadow: 0 0 10px rgba(220, 53, 69, 0.5);
    }
</style>