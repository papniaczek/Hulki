@model Hulki.Web.Models.TherapyGroup

@{
    ViewData["Title"] = "Stwórz Grupę Wspierającą";
}

<div class="container mt-4 text-light">
    <div class="card bg-dark border-secondary p-4 shadow">
        <h2 class="text-primary fw-bold mb-4">Nowa Grupa Wsparcia</h2>

        <form asp-action="Create" method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold text-info">Nazwa Grupy</label>
                <input asp-for="Name" class="form-control bg-dark text-light border-secondary" required placeholder="np. Grupa Poranna - Motywacja"/>
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Description" class="form-label fw-bold text-info">Opis i cel grupy</label>
                <textarea asp-for="Description" class="form-control bg-dark text-light border-secondary" rows="3" required placeholder="Napisz krótko do kogo skierowana jest grupa..."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MaxParticipants" class="form-label fw-bold text-info">Limit uczestników</label>
                <input asp-for="MaxParticipants" type="number" class="form-control bg-dark text-light border-secondary" min="1" max="100" required/>
                <span asp-validation-for="MaxParticipants" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="TherapyTypeId" class="form-label fw-bold text-info">Typ Terapii</label>
                <select asp-for="TherapyTypeId" class="form-select bg-dark text-light border-secondary" required>
                    @if (ViewBag.TherapyTypes != null)
                    {
                        foreach (var type in ViewBag.TherapyTypes)
                        {
                            <option value="@type.Id">@type.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="TherapyTypeId" class="text-danger"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit"
                        class="btn fw-bold px-4"
                        style="color: #0d6efd; border: 1px solid #0d6efd; background-color: transparent; transition: all 0.2s ease-in-out;"
                        onmouseover="this.style.backgroundColor='#0d6efd'; this.style.color='#ffffff';"
                        onmouseout="this.style.backgroundColor='transparent'; this.style.color='#0d6efd';">
                    Stwórz grupę
                </button>
                <a asp-action="Index"
                   class="btn px-4"
                   style="color: #DA292E; border: 1px solid #DA292E; background-color: transparent; transition: all 0.2s ease-in-out;"
                   onmouseover="this.style.backgroundColor='#DA292E'; this.style.color='#ffffff';"
                   onmouseout="this.style.backgroundColor='transparent'; this.style.color='#DA292E';">
                    Anuluj
                </a>
            </div>
        </form>
    </div>
</div>