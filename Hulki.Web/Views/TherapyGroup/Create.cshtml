

@model Hulki.Web.Models.TherapyGroup

@{
    ViewData["Title"] = "Utwórz Nową Grupę";
}

<div class="container mt-4 mb-5 text-light">

    <div class="create-header-card mb-4 p-4 p-md-5 position-relative overflow-hidden rounded-4">
        <div class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div>
                <h2 class="text-info fw-bold mb-1 text-uppercase" style="letter-spacing: 1px;">
                    Kreator Grupy Wsparcia
                </h2>
                <p class="text-light mb-0 fs-5 fw-light opacity-75">
                    Zdefiniuj nową przestrzeń terapeutyczną dla swoich pacjentów.
                </p>
            </div>
            <div class="mt-3 mt-md-0">
                <a asp-action="Index" class="btn btn-light fw-bold rounded-pill px-4 text-uppercase custom-btn-nav">
                    <i class="bi bi-arrow-left me-2"></i>Wróć do listy
                </a>
            </div>
        </div>
        <div class="create-glow"></div>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card dark-panel-card rounded-4 border-0">
                <div class="card-body p-4 p-md-5">

                    <form asp-action="Create" method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 shadow-sm rounded-3 mb-4"></div>

                        <div class="mb-4">
                            <label asp-for="Name" class="form-label text-info fw-bold text-uppercase small" style="letter-spacing: 0.5px;">Nazwa grupy <span class="text-danger">*</span></label>
                            <input asp-for="Name"
                                   class="form-control custom-input"
                                   placeholder="np. Anonimowi Pracoholicy - Grupa Wtorkowa"
                                   data-val-required="Nazwa grupy jest wymagana."/>
                            <span asp-validation-for="Name" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TherapyTypeId" class="form-label text-info fw-bold text-uppercase small" style="letter-spacing: 0.5px;">Rodzaj Terapii <span class="text-danger">*</span></label>
                            <select asp-for="TherapyTypeId" class="form-select custom-input" required data-val-required="Rodzaj terapii jest wymagany.">
                                <option value="">-- Wybierz rodzaj terapii --</option>
                                @if (ViewBag.TherapyTypes != null)
                                {
                                    foreach (var type in ViewBag.TherapyTypes)
                                    {
                                        <option value="@type.Id">@type.Name</option>
                                    }
                                }
                            </select>
                            <span asp-validation-for="TherapyTypeId" class="text-danger small fw-bold"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="MaxParticipants" class="form-label text-info fw-bold text-uppercase small" style="letter-spacing: 0.5px;">Maksymalna liczba uczestników <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-dark text-info border-secondary">
                                    <i class="bi bi-people-fill"></i>
                                </span>
                                <input asp-for="MaxParticipants" class="form-control custom-input" type="number" min="2" max="100" value="10" required data-val-required="Maksymalna liczba uczestników jest wymagana."/>
                            </div>
                            <span asp-validation-for="MaxParticipants" class="text-danger small fw-bold"></span>
                            <div class="form-text text-muted small mt-1">Sugerowana optymalna wielkość grupy to 8-12 osób.</div>
                        </div>

                        <div class="mb-5">
                            <label asp-for="Description" class="form-label text-info fw-bold text-uppercase small" style="letter-spacing: 0.5px;">Opis i zasady grupy</label>
                            <textarea asp-for="Description" class="form-control custom-input" rows="4" placeholder="Wpisz krótki opis, cele grupy oraz główne zasady..." data-val-required="Opis i zasady grupy są wymagane!"></textarea>
                            <span asp-validation-for="Description" class="text-danger small fw-bold" ></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-info btn-lg fw-bold rounded-pill text-uppercase custom-glow-btn">
                                Utwórz Grupę i Opublikuj
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .create-header-card {
        background: linear-gradient(135deg, #1b1b22 0%, #111116 100%);
        border: 1px solid rgba(13, 202, 240, 0.2);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .create-glow {
        position: absolute;
        top: -100px;
        right: -50px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(13, 202, 240, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .custom-btn-nav {
        transition: all 0.2s ease;
    }

    .custom-btn-nav:hover {
        box-shadow: 0 0 20px rgba(13, 202, 240, 0.5);
    }

    .dark-panel-card {
        background-color: #1b1b22;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        border-top: 3px solid #0dcaf0 !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .custom-input {
        background-color: #121217 !important;
        border: 1px solid #3f3f46 !important;
        color: #ffffff !important;
        border-radius: 8px !important;
        padding: 0.8rem 1rem !important;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }

    .custom-input::placeholder {
        color: #6c757d !important;
    }

    .custom-input:focus {
        border-color: #0dcaf0 !important;
        box-shadow: 0 0 15px rgba(13, 202, 240, 0.25) !important;
        outline: none !important;
    }

    .input-group .custom-input {
        border-top-left-radius: 0 !important;
        border-bottom-left-radius: 0 !important;
        border-left: 1px solid #52525b !important;
    }

    .input-group-text {
        background-color: #121217 !important;
        border: 1px solid #3f3f46 !important;
        border-right: none !important;
        border-top-left-radius: 8px !important;
        border-bottom-left-radius: 8px !important;
        padding: 0.8rem 1.2rem !important;
    }

    .custom-glow-btn {
        background-color: #0dcaf0;
        color: #111116 !important;
        border: none;
        transition: all 0.3s ease;
    }

    .custom-glow-btn:hover {
        background-color: #31d2f2;
        box-shadow: 0 0 20px rgba(13, 202, 240, 0.5);
    }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}