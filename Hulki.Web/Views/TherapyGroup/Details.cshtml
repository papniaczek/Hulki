@model Hulki.Web.Models.TherapyGroup

@{
    ViewData["Title"] = Model.Name;
    var messages = ViewBag.Messages as IEnumerable<Hulki.Web.Models.GroupMessage>;
    var quests = ViewBag.Quests as IEnumerable<Hulki.Web.Models.GroupQuest>;
    var resources = ViewBag.Resources as IEnumerable<Hulki.Web.Models.GroupResource>; // Nowa paczka danych
    string currentUserId = ViewBag.CurrentUserId as string;
    bool isStaff = ViewBag.IsStaff ?? false;
}

<div class="container mt-4 text-light">
    
    <div class="card mb-4 " style="box-shadow: 0px 0px 4px 0px rgba(0, 0, 0, 0.55); !important border-radius: 0.5rem;!important">
        <div class="card-body p-4 d-flex justify-content-between align-items-center">
            <div>
                <span class="badge bg-primary mb-2">@Model.TherapyType.Name</span>
                <h1 class="fw-bold mb-1 text-info">@Model.Name</h1>
                <p class="text-muted mb-0">@Model.Description</p>
            </div>
            @if(isStaff)
            {
                <a asp-action="Manage" asp-route-id="@Model.Id" class="btn btn-outline-warning fw-bold">
                    Zarządzaj grupą
                </a>
            }
        </div>
    </div>

    <ul class="nav nav-tabs border-secondary mb-4" id="groupTabs" role="tablist">
        <li class="nav-item" role="presentation">
            <button class="nav-link active bg-dark text-info fw-bold border-secondary border-bottom-0" id="wall-tab" data-bs-toggle="tab" data-bs-target="#wall" type="button" role="tab">
                <i class="bi bi-chat-square-text"></i> Tablica Grupy
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link bg-dark text-light fw-bold border-secondary" id="quests-tab" data-bs-toggle="tab" data-bs-target="#quests" type="button" role="tab">
                <i class="bi bi-trophy"></i> Wyzwania i Quizy
            </button>
        </li>
        <li class="nav-item" role="presentation">
            <button class="nav-link bg-dark text-light fw-bold border-secondary" id="resources-tab" data-bs-toggle="tab" data-bs-target="#resources" type="button" role="tab">
                <i class="bi bi-folder2-open"></i> Materiały od Terapeuty
            </button>
        </li>
    </ul>

    <div class="tab-content" id="groupTabsContent">
        
        <div class="tab-pane fade show active" id="wall" role="tabpanel">
            <div class="row">
                <div class="col-md-8 mx-auto">
                    <div class="card bg-dark border-secondary shadow-sm mb-4">
                        <div class="card-body">
                            <form asp-action="AddMessage" method="post">
                                <input type="hidden" name="groupId" value="@Model.Id" />
                                <div class="input-group">
                                    <input type="text" name="content" class="form-control bg-dark text-light border-secondary" placeholder="Napisz coś do grupy... Podziel się swoim dniem!" required autocomplete="off">
                                    <button class="btn btn-primary fw-bold" type="submit"><i class="bi bi-send-fill"></i> Wyślij</button>
                                </div>
                            </form>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-3">
                        @if (messages != null && messages.Any())
                        {
                            foreach (var msg in messages)
                            {
                                bool isMine = (msg.AppUserId == currentUserId);
                                string displayName = msg.AppUser != null 
                                    ? (!string.IsNullOrWhiteSpace(msg.AppUser.UserName) ? msg.AppUser.UserName : msg.AppUser.Email) 
                                    : "Nieznany pacjent";

                                <div class="card bg-dark border-secondary shadow-sm mb-3">
                                    <div class="card-body">
                                        <div class="d-flex justify-content-between align-items-center mb-2">
                                            <strong class="@(isMine ? "text-success" : "text-info")">
                                                <i class="bi bi-person-circle me-1"></i> @displayName
                                            </strong>
                                            <small class="text-muted">@msg.CreatedAt.ToString("g")</small>
                                        </div>
                                        <p class="mb-0 text-light">@msg.Content</p>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="text-center py-5 text-muted">
                                <i class="bi bi-chat-dots fs-1 mb-3 d-block text-secondary"></i>
                                <h5>Brak wiadomości</h5>
                                <p>Bądź pierwszą osobą, która przywita się z grupą!</p>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

        <div class="tab-pane fade" id="quests" role="tabpanel">
            
            @if(isStaff)
            {
                <div class="text-end mb-4">
                    <button class="btn btn-warning fw-bold text-dark" data-bs-toggle="modal" data-bs-target="#createQuestModal">
                        <i class="bi bi-plus-circle"></i> Stwórz wyzwanie
                    </button>
                </div>

                <div class="modal fade" id="createQuestModal" tabindex="-1">
                    <div class="modal-dialog modal-lg">
                        <div class="modal-content bg-dark text-light border-secondary">
                            <form asp-action="CreateQuest" method="post">
                                <input type="hidden" name="groupId" value="@Model.Id" />
                                <div class="modal-header border-secondary">
                                    <h5 class="modal-title text-warning fw-bold">Nowe Wyzwanie</h5>
                                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label text-info">Tytuł</label>
                                        <input type="text" name="title" class="form-control bg-dark text-light border-secondary" required placeholder="np. Quiz o nałogach" />
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-info">Typ zadania</label>
                                        <select name="questType" id="questTypeSelect" class="form-select bg-dark text-light border-secondary" onchange="toggleQuizFields()">
                                            <option value="Otwarte">Otwarte Pytanie (Odpowiedź tekstowa)</option>
                                            <option value="QuizABCD">Quiz ABCD (Automatyczne sprawdzanie)</option>
                                        </select>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label text-info">Treść zadania / Pytanie</label>
                                        <textarea name="description" class="form-control bg-dark text-light border-secondary" rows="3" required></textarea>
                                    </div>
                                    
                                    <div id="abcdFields" class="d-none bg-secondary bg-opacity-25 p-3 rounded mb-3 border border-secondary">
                                        <h6 class="text-warning mb-3">Odpowiedzi (wypełnij wybrane)</h6>
                                        <div class="row g-2">
                                            <div class="col-md-6">
                                                <div class="input-group">
                                                    <span class="input-group-text bg-dark text-light border-secondary">A</span>
                                                    <input type="text" name="optionA" class="form-control bg-dark text-light border-secondary" placeholder="Opcja A" />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="input-group">
                                                    <span class="input-group-text bg-dark text-light border-secondary">B</span>
                                                    <input type="text" name="optionB" class="form-control bg-dark text-light border-secondary" placeholder="Opcja B" />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="input-group">
                                                    <span class="input-group-text bg-dark text-light border-secondary">C</span>
                                                    <input type="text" name="optionC" class="form-control bg-dark text-light border-secondary" placeholder="Opcja C" />
                                                </div>
                                            </div>
                                            <div class="col-md-6">
                                                <div class="input-group">
                                                    <span class="input-group-text bg-dark text-light border-secondary">D</span>
                                                    <input type="text" name="optionD" class="form-control bg-dark text-light border-secondary" placeholder="Opcja D" />
                                                </div>
                                            </div>
                                        </div>
                                        <div class="mt-3">
                                            <label class="form-label fw-bold text-success">Prawidłowa odpowiedź</label>
                                            <select name="correctOption" class="form-select bg-dark text-light border-success">
                                                <option value="A">Opcja A</option>
                                                <option value="B">Opcja B</option>
                                                <option value="C">Opcja C</option>
                                                <option value="D">Opcja D</option>
                                            </select>
                                        </div>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label text-warning">Nagroda (Punkty)</label>
                                        <input type="number" name="rewardPoints" class="form-control bg-dark text-light border-secondary" min="5" value="50" required />
                                    </div>
                                </div>
                                <div class="modal-footer border-secondary">
                                    <button type="submit" class="btn btn-warning text-dark fw-bold">Zapisz i Opublikuj</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }

            <div class="row">
                @if (quests != null && quests.Any())
                {
                    foreach (var quest in quests)
                    {
                        var mySubmission = quest.Submissions?.FirstOrDefault(s => s.AppUserId == currentUserId);

                        <div class="col-12 mb-4">
                            <div class="card bg-dark border-warning shadow-sm">
                                <div class="card-header border-warning d-flex justify-content-between align-items-center bg-transparent">
                                    <div>
                                        <span class="badge bg-secondary me-2">@(quest.QuestType == "QuizABCD" ? "Quiz" : "Otwarte")</span>
                                        <h5 class="mb-0 d-inline text-warning fw-bold">@quest.Title</h5>
                                    </div>
                                    <div class="d-flex align-items-center gap-3">
                                        <span class="badge bg-warning text-dark fs-6"><i class="bi bi-coin"></i> +@quest.RewardPoints pkt</span>
                                        
                                        @if(isStaff)
                                        {
                                            <form asp-action="DeleteQuest" method="post" onsubmit="return confirm('Czy na pewno chcesz bezpowrotnie usunąć to wyzwanie wraz ze wszystkimi odpowiedziami pacjentów?');" class="d-inline">
                                                <input type="hidden" name="questId" value="@quest.Id" />
                                                <input type="hidden" name="groupId" value="@Model.Id" />
                                                <button type="submit" class="btn btn-sm btn-outline-danger" title="Usuń wyzwanie"><i class="bi bi-trash3"></i></button>
                                            </form>
                                        }
                                    </div>
                                </div>
                                <div class="card-body">
                                    <p class="text-light mb-4 fs-5">@quest.Description</p>

                                    @if(isStaff)
                                    {
                                        <hr class="border-secondary" />
                                        <div class="d-flex justify-content-between align-items-center">
                                            <h6 class="text-info mb-0"><i class="bi bi-inboxes"></i> Odpowiedzi pacjentów:</h6>
                                            @if(quest.QuestType == "QuizABCD")
                                            {
                                                <span class="badge bg-success text-dark">Prawidłowa odpowiedź: @quest.CorrectOption</span>
                                            }
                                        </div>
                                        
                                        @if(quest.Submissions == null || !quest.Submissions.Any())
                                        {
                                            <p class="text-muted small mt-2">Brak odpowiedzi.</p>
                                        }
                                        else
                                        {
                                            <div class="list-group list-group-flush mt-3">
                                                @foreach(var sub in quest.Submissions)
                                                {
                                                    <div class="list-group-item bg-dark border-secondary text-light">
                                                        <div class="d-flex justify-content-between">
                                                            <strong>@sub.AppUser.UserName</strong>
                                                            <small class="text-muted">@sub.SubmittedAt.ToShortDateString()</small>
                                                        </div>
                                                        <p class="mb-2 mt-1">
                                                            @if(quest.QuestType == "QuizABCD") { <span>Zaznaczył opcję: </span> }
                                                            <strong>@sub.AnswerText</strong>
                                                        </p>
                                                        
                                                        @if(!sub.IsEvaluated)
                                                        {
                                                            <div class="d-flex gap-2">
                                                                <form asp-action="EvaluateQuest" method="post">
                                                                    <input type="hidden" name="submissionId" value="@sub.Id" />
                                                                    <input type="hidden" name="groupId" value="@Model.Id" />
                                                                    <input type="hidden" name="accept" value="true" />
                                                                    <button class="btn btn-sm btn-success">Zalicz (+@quest.RewardPoints pkt)</button>
                                                                </form>
                                                                <form asp-action="EvaluateQuest" method="post">
                                                                    <input type="hidden" name="submissionId" value="@sub.Id" />
                                                                    <input type="hidden" name="groupId" value="@Model.Id" />
                                                                    <input type="hidden" name="accept" value="false" />
                                                                    <button class="btn btn-sm btn-danger">Odrzuć</button>
                                                                </form>
                                                            </div>
                                                        }
                                                        else
                                                        {
                                                            <span class="badge @(sub.IsAccepted ? "bg-success" : "bg-danger")">
                                                                @(sub.IsAccepted ? "Zaliczone (Automatycznie)" : "Odrzucone")
                                                            </span>
                                                        }
                                                    </div>
                                                }
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        if(mySubmission == null)
                                        {
                                            <form asp-action="SubmitQuest" method="post" class="bg-secondary bg-opacity-10 p-3 rounded border border-secondary">
                                                <input type="hidden" name="questId" value="@quest.Id" />
                                                <input type="hidden" name="groupId" value="@Model.Id" />
                                                
                                                @if(quest.QuestType == "QuizABCD")
                                                {
                                                    <div class="d-flex flex-column gap-2 mb-3">
                                                        @if(!string.IsNullOrEmpty(quest.OptionA)) { 
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" name="answerText" value="A" id="q@(quest.Id)A" required>
                                                                <label class="form-check-label text-light" for="q@(quest.Id)A"><strong>A:</strong> @quest.OptionA</label>
                                                            </div> 
                                                        }
                                                        @if(!string.IsNullOrEmpty(quest.OptionB)) { 
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" name="answerText" value="B" id="q@(quest.Id)B" required>
                                                                <label class="form-check-label text-light" for="q@(quest.Id)B"><strong>B:</strong> @quest.OptionB</label>
                                                            </div> 
                                                        }
                                                        @if(!string.IsNullOrEmpty(quest.OptionC)) { 
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" name="answerText" value="C" id="q@(quest.Id)C" required>
                                                                <label class="form-check-label text-light" for="q@(quest.Id)C"><strong>C:</strong> @quest.OptionC</label>
                                                            </div> 
                                                        }
                                                        @if(!string.IsNullOrEmpty(quest.OptionD)) { 
                                                            <div class="form-check">
                                                                <input class="form-check-input" type="radio" name="answerText" value="D" id="q@(quest.Id)D" required>
                                                                <label class="form-check-label text-light" for="q@(quest.Id)D"><strong>D:</strong> @quest.OptionD</label>
                                                            </div> 
                                                        }
                                                    </div>
                                                }
                                                else
                                                {
                                                    <div class="mb-3">
                                                        <textarea name="answerText" class="form-control bg-dark text-light border-secondary" placeholder="Wpisz swoją odpowiedź..." rows="2" required></textarea>
                                                    </div>
                                                }
                                                <button class="btn btn-warning fw-bold text-dark w-100" type="submit">Prześlij odpowiedź</button>
                                            </form>
                                        }
                                        else
                                        {
                                            <div class="alert bg-dark border-secondary mt-3 mb-0">
                                                <strong>Twoja odpowiedź:</strong> @mySubmission.AnswerText
                                                <div class="mt-2">
                                                    @if(!mySubmission.IsEvaluated)
                                                    {
                                                        <span class="badge bg-secondary"><i class="bi bi-clock"></i> Oczekuje na ocenę terapeuty</span>
                                                    }
                                                    else if(mySubmission.IsAccepted)
                                                    {
                                                        <span class="badge bg-success"><i class="bi bi-check-circle"></i> Zaliczone (+@quest.RewardPoints pkt)</span>
                                                    }
                                                    else
                                                    {
                                                        <span class="badge bg-danger"><i class="bi bi-x-circle"></i> Niezaliczone / Błędna odpowiedź</span>
                                                    }
                                                </div>
                                            </div>
                                        }
                                    }
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="text-center py-5 text-muted w-100">
                        <i class="bi bi-trophy fs-1 mb-3 d-block text-secondary"></i>
                        <h5>Brak aktywnych wyzwań</h5>
                        <p>Terapeuta jeszcze niczego tutaj nie dodał.</p>
                    </div>
                }
            </div>
        </div>

        <div class="tab-pane fade" id="resources" role="tabpanel">
            <div class="row">
                
                @if (isStaff)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card bg-dark border-secondary p-3 shadow-sm">
                            <h5 class="text-info fw-bold mb-3"><i class="bi bi-cloud-upload"></i> Udostępnij materiał</h5>
                            <form asp-action="UploadResource" method="post" enctype="multipart/form-data">
                                <input type="hidden" name="groupId" value="@Model.Id" />
                                
                                <div class="mb-3">
                                    <label class="form-label small text-muted">Tytuł materiału</label>
                                    <input type="text" name="title" class="form-control bg-dark text-light border-secondary" required placeholder="np. Karta radzenia sobie ze stresem" />
                                </div>
                                
                                <div class="mb-3">
                                    <label class="form-label small text-muted">Wybierz plik (PDF, JPG, PNG)</label>
                                    <input type="file" name="uploadedFile" class="form-control bg-dark text-light border-secondary" accept=".pdf,.png,.jpg,.jpeg" required />
                                </div>
                                
                                <button type="submit" class="btn btn-info fw-bold w-100 mt-2">Wyślij do grupy</button>
                            </form>
                        </div>
                    </div>
                }

                <div class="@(isStaff ? "col-md-8" : "col-12")">
                    <div class="card bg-dark border-secondary p-4 shadow-sm">
                        <h4 class="text-light fw-bold mb-4"><i class="bi bi-file-earmark-text text-primary"></i> Pliki i arkusze edukacyjne</h4>
                        
                        <div class="row">
                            @if (resources != null && resources.Any())
                            {
                                foreach (var res in resources)
                                {
                                    // Sprawdzamy rozszerzenie pliku, by dobrać odpowiednią ikonkę
                                    string iconClass = "bi-file-earmark-text text-muted";
                                    if (res.FilePath.EndsWith(".pdf", StringComparison.OrdinalIgnoreCase)) iconClass = "bi-file-earmark-pdf text-danger";
                                    else if (res.FilePath.EndsWith(".png", StringComparison.OrdinalIgnoreCase) || res.FilePath.EndsWith(".jpg", StringComparison.OrdinalIgnoreCase) || res.FilePath.EndsWith(".jpeg", StringComparison.OrdinalIgnoreCase)) iconClass = "bi-file-earmark-image text-success";

                                    <div class="col-sm-6 mb-3">
                                        <div class="p-3 rounded border border-secondary bg-secondary bg-opacity-10 d-flex justify-content-between align-items-center">
                                            <div class="d-flex align-items-center gap-3 overflow-hidden">
                                                <i class="bi @iconClass fs-2 flex-shrink-0"></i>
                                                <div class="overflow-hidden">
                                                    <h6 class="text-light mb-1 text-truncate fw-bold" title="@res.Title">@res.Title</h6>
                                                    <small class="text-muted d-block" style="font-size: 0.75rem;">Dodano: @res.CreatedAt.ToShortDateString()</small>
                                                </div>
                                            </div>
                                            <a href="@res.FilePath" download class="btn btn-sm btn-outline-light ms-2 flex-shrink-0" style="color: white;" onmouseover="this.style.color='black'" onmouseout="this.style.color='white'" title="Pobierz plik">
                                                <i class="bi bi-download"></i>
                                            </a>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="text-center py-5 text-muted w-100">
                                    <i class="bi bi-folder-x fs-1 mb-3 d-block text-secondary"></i>
                                    <h5>Brak dostępnych materiałów</h5>
                                    <p class="mb-0">Terapeuta nie udostępnił jeszcze żadnych plików pomocniczych dla tej grupy.</p>
                                </div>
                            }
                        </div>
                    </div>
                </div>

            </div>
        </div>

    </div>
</div>

<script>
    function toggleQuizFields() {
        var type = document.getElementById("questTypeSelect").value;
        var abcdFields = document.getElementById("abcdFields");
        if(type === "QuizABCD") {
            abcdFields.classList.remove("d-none");
        } else {
            abcdFields.classList.add("d-none");
        }
    }
</script>