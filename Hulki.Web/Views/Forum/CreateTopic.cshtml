@{
    var category = ViewBag.Category as Hulki.Web.Models.ForumCategory;
    ViewData["Title"] = "Nowy Temat - " + category?.Name;
}

<div class="container mt-4 text-light">
    <div class="create-header-card mb-5 p-4 p-md-5 position-relative overflow-hidden rounded-4">
        <div class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div>
                <h2 class="text-info fw-bold mb-1 text-uppercase" style="letter-spacing: 1px;">
                    Nowy temat
                </h2>
                <p class="text-light mb-0 fs-5 fw-light opacity-75">
                    w dziale: <strong class="text-primary">@category?.Name</strong>
                </p>
            </div>
            <div class="mt-3 mt-md-0">
                <a asp-action="Index" class="btn btn-light fw-bold rounded-pill px-4 text-uppercase custom-btn-nav">
                    <i class="bi bi-arrow-left me-2"></i>Wróć do listy
                </a>
            </div>
        </div>

        <div class="create-glow"></div>
    </div>
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card dark-panel-card rounded-4 border-0">

                <div class="card-body p-5">
                    <form asp-action="CreateTopic" method="post">
                        <input type="hidden" name="forumCategoryId" value="@category?.Id" />

                        <div class="mb-4">
                            <label class="form-label text-info fw-bold text-uppercase small"
                                   style="letter-spacing: 0.5px;">Tytuł tematu <span class="text-danger">*</span></label>
                            <input type="text" name="title" class="form-control custom-input" required
                                   placeholder="Napisz krótki i zwięzły tytuł..." maxlength="200" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label text-info fw-bold text-uppercase small"
                                   style="letter-spacing: 0.5px;">Treść <span class="text-danger">*</span></label>
                            <textarea name="content" class="form-control custom-input" rows="8" required
                                      placeholder="Opisz dokładnie swój problem lub przemyślenia..."></textarea>
                        </div>

                        <div class="d-grid">
                            <button type="submit"
                                    class="btn btn-info btn-lg fw-bold rounded-pill text-uppercase custom-glow-btn">
                                Utwórz Temat i Opublikuj
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .create-header-card {
        background: linear-gradient(135deg, #1b1b22 0%, #111116 100%);
        border: 1px solid rgba(13, 202, 240, 0.2);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .create-glow {
        position: absolute;
        top: -100px;
        right: -50px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(13, 202, 240, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .custom-btn-nav {
        transition: all 0.2s ease;
    }

    .custom-btn-nav:hover {
        box-shadow: 0 0 20px rgba(13, 202, 240, 0.5);
    }


    .form-control:focus {
        background-color: #131319 !important;
        border-color: #46CC5E !important;
        color: #fff !important;
        box-shadow: 0 0 10px rgba(70, 204, 94, 0.2);
    }

    .form-control::placeholder {
        color: rgba(255, 255, 255, 0.5) !important;
    }

    .btn-custom-success {
        background-color: rgba(70, 204, 94, 0.10);
        color: #46CC5E;
        border: 1px solid rgba(70, 204, 94, 0.3);
        transition: all 0.3s ease;
    }

    .custom-glow-btn:hover {
        background: #6C5CE7 !important;
        color: #fff !important;
        box-shadow: 0 0 15px rgba(108, 92, 231, 0.6);
    }

    .dark-panel-card {
        background-color: #1b1b22;
        border: 1px solid rgba(255, 255, 255, 0.05) !important;
        border-top: 3px solid #0dcaf0 !important;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    }

    .custom-input {
        background-color: #121217 !important;
        border: 1px solid #3f3f46 !important;
        color: #ffffff !important;
        border-radius: 8px !important;
        padding: 0.8rem 1rem !important;
        font-size: 0.95rem;
        transition: all 0.3s ease;
    }

    .custom-input::placeholder {
        color: #6c757d !important;
    }

    .custom-input:focus {
        border-color: #0dcaf0 !important;
        box-shadow: 0 0 15px rgba(13, 202, 240, 0.25) !important;
        outline: none !important;
    }

    .custom-glow-btn {
        background-color: #0dcaf0;
        color: #111116 !important;
        border: none;
        transition: all 0.3s ease;
    }

    .custom-glow-btn:hover {
        background-color: #31d2f2 !important;
        color: #111116 !important;
        box-shadow: 0 0 20px rgba(13, 202, 240, 0.5);
    }
</style>