@model Hulki.Web.Models.ForumCategory
@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb bg-dark-subtle">
            <li class="breadcrumb-item"><a asp-action="Index">Forum</a></li>
            <li class="breadcrumb-item active" aria-current="page">@Model.Name</li>
        </ol>
    </nav>

    <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
        <h3>@Model.Name</h3>
        <a asp-action="CreateTopic" asp-route-categoryId="@Model.Id" class="btn btn-success fw-bold">
            <i class="bi bi-plus-lg"></i> Załóż nowy temat
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm">@TempData["ErrorMessage"]</div>
    }

    <div class="list-group shadow-sm">
        @if (Model.ForumTopics != null && Model.ForumTopics.Any())
        {
            foreach (var topic in Model.ForumTopics.OrderByDescending(t => t.CreatedAt))
            {
                <a asp-action="Topic" asp-route-id="@topic.Id" class="list-group-item list-group-item-action p-4 bg-dark-subtle">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <h5 class="mb-1 fw-bold text-light">@topic.Title</h5>
                        <small class="text-muted">@topic.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                    </div>
                    <p class="mb-1 text-muted">Autor: @topic.AppUser?.FirstName @topic.AppUser?.LastName</p>
                    <small><i class="bi bi-chat-dots"></i> Odpowiedzi: @(topic.Posts?.Count ?? 0)</small>
                </a>
            }
        }
        else
        {
            <div class="list-group-item p-5 text-center text-muted">
                Brak tematów w tym dziale. Bądź pierwszy i załóż nowy temat!
            </div>
        }
    </div>
</div>