@{
    ViewData["Title"] = "Nowe Forum";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow border-0 bg-dark-subtle">
                <div class="card-header p-3" style="background-color: rgba(70, 204, 94, 0.15); border-bottom: 1px solid rgba(70, 204, 94, 0.3);">
                    <h4 class="m-0 text-light fw-bold">
                        <i class="bi bi-folder-plus me-2 text-success"></i>Nowe Forum
                    </h4>
                </div>
                <div class="card-body p-4">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger">@TempData["ErrorMessage"]</div>
                    }

                    <form asp-action="CreateCategory" method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold text-light">Nazwa forum</label>
                            <input type="text" name="name" class="form-control" required
                                   placeholder="Np. Motywacja, Porady, Sukcesy..." maxlength="100" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-light">Opis <span class="text-muted fw-normal">(opcjonalny)</span></label>
                            <textarea name="description" class="form-control" rows="4"
                                      placeholder="Krótki opis czego dotyczy to forum..." maxlength="500"></textarea>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="Index"
                               class="btn btn-outline-secondary text-light"
                               style="border-color: rgba(255,255,255,0.2);">Anuluj</a>
                            <button type="submit" class="btn btn-success fw-bold px-4">
                                <i class="bi bi-plus-circle me-1"></i> Utwórz forum
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
