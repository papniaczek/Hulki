@model Hulki.Web.Models.ForumTopic
@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-4 text-light">
    <div class="topic-header-card mb-5 p-4 position-relative overflow-hidden rounded-4" style="min-height: 140px;">
        <div class="position-relative z-1 d-flex flex-column justify-content-center">
            <div class="mb-2">
                <h2 class="text-primary fw-bold text-uppercase" style="letter-spacing: 1px;">
                    <i class="bi bi-chat-dots-fill me-2"></i>@Model.Title
                </h2>
                <p class="text-light mb-0 fs-6 fw-light opacity-75">
                    <i class="bi bi-person-fill me-2"></i>@Model.AppUser?.FirstName @Model.AppUser?.LastName
                    <span class="ms-3"><i class="bi bi-calendar3 me-1"></i>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                </p>
            </div>
        </div>
        <div class="topic-header-glow"></div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm border-0 rounded-3 mb-4 d-flex align-items-center">
            <i class="bi bi-check-circle-fill me-2 fs-5"></i> @TempData["SuccessMessage"]
        </div>
    }

    <div class="topic-card card h-100 d-flex flex-column border-0 rounded-4 shadow-lg" style="background-color: #1b1b22; margin-bottom: 2rem;">
        <div class="card-body p-5">
            <p class="fs-5 text-light" style="white-space: pre-wrap; line-height: 1.8;">@Model.Content</p>
        </div>
    </div>

    <h5 class="mb-4 fw-bold text-primary text-uppercase" style="letter-spacing: 1px;">
        <i class="bi bi-chat-left-text-fill me-2"></i>Odpowiedzi (@(Model.Posts?.Count ?? 0))
    </h5>

    @if (Model.Posts != null && Model.Posts.Any())
    {
        foreach (var post in Model.Posts.OrderBy(p => p.CreatedAt))
        {
            <div class="topic-card card border-0 rounded-4 shadow-md mb-3" style="background-color: #1b1b22;">
                <div class="card-body p-4">
                    <div class="d-flex align-items-start mb-3 border-bottom border-secondary pb-3">
                        <div class="post-icon-wrapper me-3 flex-shrink-0">
                            <i class="bi bi-person-fill text-primary fs-5"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-bold text-light">@post.AppUser?.FirstName @post.AppUser?.LastName</div>
                            <small class="text-muted"><i class="bi bi-calendar3 me-1"></i>@post.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                        </div>
                    </div>
                    <p class="mb-0 text-light" style="white-space: pre-wrap;">@post.Content</p>
                </div>
            </div>
        }
    }

    <div class="form-card card border-0 rounded-4 shadow-lg mt-5" style="background-color: #1b1b22;">
        <div class="card-header p-4 d-flex align-items-center gap-3" style="background: linear-gradient(135deg, rgba(70, 204, 94, 0.15) 0%, rgba(70, 204, 94, 0.05) 100%); border-bottom: 1px solid rgba(70, 204, 94, 0.3); border-radius: 16px 16px 0 0;">
            <div class="form-icon-wrapper">
                <i class="bi bi-reply-fill text-primary fs-4"></i>
            </div>
            <div>
                <h5 class="m-0 fw-bold text-light">Dodaj odpowiedź</h5>
                <small class="text-muted">Podziel się swoją opinią</small>
            </div>
        </div>
        <div class="card-body p-4">
            <form asp-action="CreatePost" method="post">
                <input type="hidden" name="forumTopicId" value="@Model.Id"/>
                <div class="mb-4">
                    <textarea name="content" class="form-control form-control-lg bg-dark border-secondary text-light rounded-3" rows="4" placeholder="Napisz co myślisz..." required></textarea>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Category" asp-route-id="@Model.ForumCategoryId"
                       class="btn btn-outline-secondary fw-bold rounded-pill px-4 py-2"
                       style="border-color: #DA292E; color: #DA292E; background-color: transparent; transition: all 0.2s ease-in-out;"
                       onmouseover="this.style.backgroundColor='#DA292E'; this.style.color='#ffffff';"
                       onmouseout="this.style.backgroundColor='transparent'; this.style.color='#DA292E';">Anuluj</a>
                    <button type="submit" class="btn btn-custom-success fw-bold rounded-pill px-4 py-2" style="background-color: #46CC5E; color: #17171C; border: none;">Wyślij odpowiedź</button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
    .topic-header-card {
        background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
        border: 1px solid rgba(70, 204, 94, 0.15);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .topic-header-glow {
        position: absolute;
        top: -50px;
        right: -50px;
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .topic-card {
        border: 1px solid rgba(255, 255, 255, 0.03) !important;
        transition: all 0.3s ease;
    }

    .topic-card:hover {
        box-shadow: 0 10px 25px rgba(70, 204, 94, 0.15) !important;
    }

    .post-icon-wrapper {
        width: 40px;
        height: 40px;
        border-radius: 10px;
        background: rgba(70, 204, 94, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        background-color: #1f1f27 !important;
        border-color: #46CC5E !important;
        color: #fff !important;
        box-shadow: 0 0 10px rgba(70, 204, 94, 0.2);
    }

    .form-control::placeholder {
        color: rgba(255, 255, 255, 0.5) !important;
    }

    .btn-custom-success {
        background-color: rgba(70, 204, 94, 0.10);
        color: #46CC5E;
        border: 1px solid rgba(70, 204, 94, 0.3);
        transition: all 0.3s ease;
    }
</style>