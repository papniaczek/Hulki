@model Hulki.Web.Models.ForumTopic
@{
    ViewData["Title"] = Model.Title;
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Forum</a></li>
            <li class="breadcrumb-item"><a asp-action="Category" asp-route-id="@Model.ForumCategoryId">@Model.ForumCategory?.Name</a></li>
            <li class="breadcrumb-item active" aria-current="page">Temat</li>
        </ol>
    </nav>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success shadow-sm">@TempData["SuccessMessage"]</div>
    }

    <div class="card shadow-sm border-0 mb-4 border-start border-primary border-5">
        <div class="card-body p-4">
            <h3 class="fw-bold mb-3">@Model.Title</h3>
            <div class="d-flex align-items-center mb-4 text-muted border-bottom pb-3">
                <i class="bi bi-person-circle fs-3 me-2"></i>
                <div>
                    <span class="fw-bold text-dark">@Model.AppUser?.FirstName @Model.AppUser?.LastName</span>
                    <br />
                    <small>@Model.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                </div>
            </div>
            <p class="fs-5" style="white-space: pre-wrap;">@Model.Content</p>
        </div>
    </div>

    <h5 class="mb-3 fw-bold text-secondary">Odpowiedzi (@(Model.Posts?.Count ?? 0))</h5>
    
    @if (Model.Posts != null && Model.Posts.Any())
    {
        foreach (var post in Model.Posts.OrderBy(p => p.CreatedAt))
        {
            <div class="card shadow-sm border-0 mb-3 bg-light">
                <div class="card-body p-3">
                    <div class="d-flex justify-content-between border-bottom pb-2 mb-2 text-muted small">
                        <span class="fw-bold text-dark"><i class="bi bi-person-fill"></i> @post.AppUser?.FirstName @post.AppUser?.LastName</span>
                        <span>@post.CreatedAt.ToString("dd.MM.yyyy HH:mm")</span>
                    </div>
                    <p class="mb-0" style="white-space: pre-wrap;">@post.Content</p>
                </div>
            </div>
        }
    }

    <div class="card shadow-sm border-0 mt-4 bg-white">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-3">Dodaj odpowiedź</h5>
            <form asp-action="CreatePost" method="post">
                <input type="hidden" name="forumTopicId" value="@Model.Id" />
                <div class="mb-3">
                    <textarea name="content" class="form-control" rows="4" placeholder="Napisz co myślisz..." required></textarea>
                </div>
                <button type="submit" class="btn btn-primary fw-bold">Wyślij odpowiedź</button>
            </form>
        </div>
    </div>
</div>