@model IEnumerable<Hulki.Web.Models.ForumCategory>
@{
    ViewData["Title"] = "Forum Wsparcia";
}

<div class="container mt-4">
    <div class="forum-header-card mb-5 p-4 p-md-5 position-relative overflow-hidden rounded-4"
         style="min-height: 194px; !important">
        <div class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div class="mb-4 mb-md-0">
                <span style="display:flex;align-items: center; gap:1rem">
                    <h2 class="text-primary fw-bold mb-2 text-uppercase d-flex align-items-center"
                        style="letter-spacing: 1px;">
                        Forum Społecznościowe
                    </h2>

                    @if (User.IsInRole("Terapeuta") || User.IsInRole("Admin"))
                    {
                        <a asp-action="CreateCategory"
                           class="btn btn-custom-success fw-bold rounded-pill px-4 py-2 text-uppercase shadow"
                           style="letter-spacing: 1px; font-size: 0.85rem; margin-bottom: 8px;">
                            <i class="bi bi-plus-circle me-2"></i> Nowe forum
                        </a>
                    }
                </span>
                <p class="text-light mb-0 fs-5 fw-light opacity-75">
                    Razem łatwiej. Podziel się swoimi doświadczeniami, znajdź wsparcie i pomagaj innym.
                </p>
            </div>

            <div class="text-md-end text-center how-many-posts p-3 rounded-3 shadow-sm mt-3 mt-md-0">
                <h6 class="text-uppercase text-muted fw-bold mb-1 text-center" style="letter-spacing: 1px;">
                    Liczba FORÓW
                </h6>
                <h2 class="text-success fw-bold mb-0 d-flex align-items-center justify-content-center">
                    @Model.Count()
                </h2>
            </div>
        </div>
        <div class="forum-header-glow"></div>
    </div>

    <div class="row g-4">
        @foreach (var category in Model)
        {
            <div class="col-12">
                <a asp-action="Category" asp-route-id="@category.Id"
                   class="text-decoration-none text-light category-card-link">
                    <div class="card category-card border-0 h-100">
                        <div
                            class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center p-4">

                            <div class="d-flex align-items-center mb-3 mb-md-0">
                                <div class="category-icon-wrapper me-4 flex-shrink-0">
                                    <i class="bi bi-folder2-open text-primary fs-3"></i>
                                </div>
                                <div>
                                    <h4 class="fw-bold mb-1 category-title">
                                        @category.Name
                                    </h4>
                                    <p class="text-muted mb-0">@category.Description</p>
                                </div>
                            </div>

                            <div
                                class="text-md-end d-flex flex-column align-items-start align-items-md-end justify-content-center">
                                <span class="text-uppercase fw-bold text-muted mb-2"
                                      style="font-size: 0.70rem; letter-spacing: 1px;">
                                    Tematy
                                </span>
                                <span class="badge category-badge rounded-pill fs-6 px-3 py-2">
                                    @(category.ForumTopics?.Count ?? 0)
                                </span>
                            </div>

                        </div>
                    </div>
                </a>
            </div>
        }
    </div>
</div>

<style>
    .forum-header-card {
        background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
        border: 1px solid rgba(70, 204, 94, 0.15);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
    }

    .forum-header-glow {
        position: absolute;
        top: -50px;
        right: -50px;
        width: 250px;
        height: 250px;
        background: radial-gradient(circle, rgba(70, 204, 94, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        z-index: 0;
        pointer-events: none;
    }

    .how-many-posts {
        background: rgba(0, 0, 0, 0.25);
        border: 1px solid rgba(70, 204, 94, 0.15);
        min-width: 180px;
    }

    .btn-custom-success {
        background-color: rgba(70, 204, 94, 0.10);
        color: #46CC5E;
        border: 1px solid rgba(70, 204, 94, 0.3);
        transition: all 0.3s ease;
    }

    .btn-custom-success:hover {
        background-color: #46CC5E;
        color: #17171C;
        box-shadow: 0 0 15px rgba(70, 204, 94, 0.4);
    }

    .category-card-link {
        display: block;
        transition: transform 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .category-card {
        background-color: #1b1b22;
        border: 1px solid rgba(255, 255, 255, 0.03) !important;
        border-radius: 16px;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(0, 0, 0, 0.2);
    }

    .category-icon-wrapper {
        width: 65px;
        height: 65px;
        border-radius: 14px;
        background: rgba(70, 204, 94, 0.08);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .category-title {
        transition: color 0.3s ease;
    }

    .category-badge {
        background-color: rgba(70, 204, 94, 0.10);
        color: #46CC5E;
        border: 1px solid rgba(70, 204, 94, 0.3);
        transition: all 0.3s ease;
    }

    .category-card-link:hover {
        transform: translateY(-5px);
    }

    .category-card-link:hover .category-card {
        background-color: #1f1f27;
        border-color: rgba(70, 204, 94, 0.4) !important;
        box-shadow: 0 10px 25px rgba(70, 204, 94, 0.15);
    }

    .category-card-link:hover .category-icon-wrapper {
        background: #46CC5E;
        box-shadow: 0 0 15px rgba(70, 204, 94, 0.4);
    }

    .category-card-link:hover .category-icon-wrapper i {
        color: #17171C !important;
    }

    .category-card-link:hover .category-title {
        color: #46CC5E;
    }

    .category-card-link:hover .category-badge {
        background-color: #46CC5E;
        color: #17171C;
        box-shadow: 0 0 10px rgba(70, 204, 94, 0.4);
    }

    #flash-message {
        position: fixed;
        bottom: 5%;
        left: 50%;
        transform: translateX(-50%) translateY(20px);
        z-index: 1080;
        width: auto;
        max-width: 420px;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.35s ease, transform 0.35s ease;
    }

    #flash-message.show {
        opacity: 1;
        transform: translateX(-50%) translateY(0);
    }

    .flash-bubble {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 0.6rem;
        background: rgba(27, 27, 34, 0.98);
        color: #f8f9fa;
        border-radius: 18px;
        padding: 1rem 1.3rem;
        box-shadow: 0 18px 35px rgba(0, 0, 0, 0.28);
        border: 1px solid rgba(255, 255, 255, 0.08);
        font-weight: 500;
        line-height: 1.3;
    }

    .flash-bubble.success {
        border-color: rgba(70, 204, 94, 0.45);
    }
</style>