@model IEnumerable<Hulki.Web.Models.ForumCategory>
@{
    ViewData["Title"] = "Forum Wsparcia";
}

<div class="card mb-4"
     style="box-shadow: 0px 0px 4px 0px rgba(0, 0, 0, 0.55); !important border-radius: 0.5rem;!important">
    <div class="card-body d-flex justify-content-between align-items-center p-4">
        <div>
            <h2 class="text-primary fw-bold mb-1">Forum Społecznościowe</h2>
            <p class="text-muted mb-0">Razem łatwiej. Podziel się swoimi doświadczeniami.</p>
        </div>
    </div>
</div>

<div class="row">
    @foreach (var category in Model)
    {
        <div class="col-md-12 mb-3">
            <div class="card shadow-sm border-0 h-100 bg-dark-subtle">
                <div class="card-body d-flex justify-content-between align-items-center p-4">
                    <div>
                        <h4 class="fw-bold mb-1">
                            <a asp-action="Category" asp-route-id="@category.Id" class="text-decoration-none text-light">
                                @category.Name
                            </a>
                        </h4>
                        <p class="text-muted mb-0">@category.Description</p>
                    </div>
                    <div class="text-end text-muted small">
                        Tematów:
                        <span class="badge bg-primary rounded-pill fs-6">@(category.ForumTopics?.Count ?? 0)</span>
                    </div>
                </div>
            </div>
        </div>
    }
</div>
</div>