@model IEnumerable<Hulki.Web.Models.ForumCategory>
@{
    ViewData["Title"] = "Forum Wsparcia";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-chat-left-text-fill text-primary"></i> Forum Społecznościowe</h2>
        <p class="text-muted m-0">Razem łatwiej. Podziel się swoimi doświadczeniami.</p>
    </div>

    <div class="row">
        @foreach (var category in Model)
        {
            <div class="col-md-12 mb-3">
                <div class="card shadow-sm border-0 h-100">
                    <div class="card-body d-flex justify-content-between align-items-center p-4">
                        <div>
                            <h4 class="fw-bold mb-1">
                                <a asp-action="Category" asp-route-id="@category.Id" class="text-decoration-none text-dark">
                                    @category.Name
                                </a>
                            </h4>
                            <p class="text-muted mb-0">@category.Description</p>
                        </div>
                        <div class="text-end text-muted small">
                            <i class="bi bi-file-earmark-text"></i> Tematów: 
                            <span class="badge bg-primary rounded-pill fs-6">@(category.ForumTopics?.Count ?? 0)</span>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>