<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0, 0, 0, .15) !important;
    }

    .transition {
        transition: all 0.3s ease;
    }

    .bg-primary-light {
        background-color: rgba(13, 110, 253, 0.1);
    }

    .bg-warning-light {
        background-color: rgba(255, 193, 7, 0.1);
    }

    .bg-info-light {
        background-color: rgba(13, 202, 240, 0.1);
    }

    .icon-circle {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .quote-card {
        background: linear-gradient(135deg, rgba(13, 110, 253, 0.08), rgba(13, 202, 240, 0.08));
        border-left: 4px solid #0d6efd !important;
    }

    .quote-card.loading {
        opacity: 0.5;
    }

    .marquee-fullwidth-section {
        position: relative;
        left: 50%;
        transform: translateX(-50%);
        width: 99vw;
        overflow: hidden;
        border-radius: 1rem;
    }

    .marquee-container {
        overflow: hidden;
        white-space: nowrap;
        background-color: var(--bs-dark-bg-subtle, #f8f9fa);
        padding: 20px 0;
        position: relative;
        width: 100%;
    }



    .marquee-container::before, .marquee-container::after {
        content: "";
        height: 100%;
        position: absolute;
        width: 150px;
        z-index: 5;
        pointer-events: none;
    }

    .marquee-container::before {
        left: 0;
        top: 0;
        background: linear-gradient(to right, var(--bs-body-bg, #fff), transparent);
    }

    .marquee-container::after {
        right: 0;
        top: 0;
        background: linear-gradient(to left, var(--bs-body-bg, #fff), transparent);
    }

    .marquee-track {
        display: inline-flex;
        gap: 20px;
        animation: scrollMarquee 35s linear infinite;
        width: max-content;
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .marquee-track:hover {
        animation-play-state: paused;
    }

    .marquee-item {
        position: relative;
        overflow: hidden;
        height: 180px;
        width: 250px;
        border-radius: 12px;
        box-shadow: 0 4px 6px rgba(0,0,0,0.05);
        cursor: pointer;
        transition: transform 0.3s ease;
    }

    .marquee-item:hover {
        transform: scale(1.05);
        box-shadow: 0 8px 12px rgba(0,0,0,0.2);
    }

    .marquee-img {
        height: 100%;
        width: 100%;
        object-fit: cover;
        border-radius: 12px;
        transition: filter 0.3s ease, transform 0.3s ease;
    }

    .marquee-item:hover .marquee-img {
        filter: brightness(50%);
        transform: scale(1.1);
    }

    .marquee-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 15px;
        opacity: 0;
        transition: opacity 0.3s ease;
        z-index: 3;
        text-align: center;
        white-space: normal;
    }

    .marquee-item:hover .marquee-overlay {
        opacity: 1;
    }

    .marquee-text {
        color: #fff;
        font-weight: bold;
        font-size: 0.95rem;
        margin: 0;
        text-shadow: 0 1px 3px rgba(0,0,0,0.8);
    }

    @@keyframes scrollMarquee {
        0% {
            transform: translateX(0);
        }
        100% {
            transform: translateX(calc(-50% - 10px));
        }
    }
</style>

<script>
    (function () {
        const btn = document.getElementById('quote-refresh');
        if (!btn) return;

        const card = document.getElementById('quote-card');
        const contentEl = document.getElementById('quote-content');
        const authorEl = document.getElementById('quote-author');

        btn.addEventListener('click', async () => {
            btn.disabled = true;
            card.classList.add('loading');
            try {
                const res = await fetch('/api/quotes/random', {
                    headers: { 'Accept': 'application/json' },
                    cache: 'no-store'
                });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const data = await res.json();
                contentEl.textContent = '\u201E' + data.content + '\u201D';
                authorEl.textContent = data.author || 'Nieznany autor';
            } catch (err) {
                console.error('Nie udało się pobrać cytatu:', err);
                authorEl.textContent = 'Nie udało się pobrać nowego cytatu – spróbuj jeszcze raz.';
            } finally {
                card.classList.remove('loading');
                btn.disabled = false;
            }
        });
    })();
</script>
