<div class="container mt-4">
    <div class="row align-items-center mb-5">
        <div class="col-md-7">
            <h1 class="display-3 fw-bold text-primary">Klinika Hulki</h1>
            <p class="lead fs-4 text-muted">Twój osobisty system wsparcia w drodze do wolności od uzależnień.</p>
        </div>
        <div class="col-md-5 text-center">
            <img src="graphics/pudzian.jpg" class="img-fluid rounded-5 shadow-lg" style="max-height: 300px;" alt="Therapy">
        </div>
    </div>

    @{
        var quote = ViewBag.Quote as Hulki.Web.Models.Dto.QuoteDto;
    }
    @if (quote != null)
    {
        <div class="card border-0 shadow-sm mb-5 quote-card" id="quote-card">
            <div class="card-body p-4 p-md-5 text-center">
                <i class="bi bi-quote text-primary d-block mb-3" style="font-size:2.5rem;"></i>
                <blockquote class="blockquote mb-3">
                    <p class="fs-4 fst-italic mb-0" id="quote-content">&bdquo;@quote.Content&rdquo;</p>
                </blockquote>
                <footer class="blockquote-footer mb-3" id="quote-author-wrapper">
                    <span id="quote-author">@(quote.Author ?? "Nieznany autor")</span>
                </footer>
                <button type="button" class="btn btn-sm btn-outline-primary" id="quote-refresh">
                    <i class="bi bi-arrow-clockwise me-1"></i>Nowy cytat
                </button>
            </div>
        </div>
    }

    @if (User.Identity.IsAuthenticated)
    {
        <div class="row g-4">
            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition border-bottom border-primary border-4 bg-dark-subtle">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-primary-light text-primary mb-3 mx-auto">
                            <i class="bi bi-journal-check fs-2"></i>
                        </div>
                        <h4>Dzienniczek</h4>
                        <p class="text-muted small">Dodaj dzisiejszy raport i odbierz 10 punktów.</p>
                        <a asp-controller="Patient" asp-action="DailyReport" class="btn btn-outline-primary stretched-link">Otwórz</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition border-bottom border-warning border-4 bg-dark-subtle">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-warning-light text-warning mb-3 mx-auto">
                            <i class="bi bi-gem fs-2"></i>
                        </div>
                        <h4>Sklep Nagród</h4>
                        <p class="text-muted small">Wymień punkty na unikalne odznaki do profilu.</p>
                        <a asp-controller="Store" asp-action="Index" class="btn btn-outline-warning stretched-link">Zajrzyj</a>
                    </div>
                </div>
            </div>

            <div class="col-md-4">
                <div class="card h-100 border-0 shadow-sm hover-shadow transition border-bottom border-info border-4 bg-dark-subtle">
                    <div class="card-body text-center p-4">
                        <div class="icon-circle bg-info-light text-info mb-3 mx-auto">
                            <i class="bi bi-people fs-2"></i>
                        </div>
                        <h4>Społeczność</h4>
                        <p class="text-muted small">Rozmawiaj z innymi i szukaj wsparcia.</p>
                        <a asp-controller="Forum" asp-action="Index" class="btn btn-outline-info stretched-link">Wejdź</a>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .hover-shadow:hover { transform: translateY(-5px); box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important; }
    .transition { transition: all 0.3s ease; }
    .bg-primary-light { background-color: rgba(13, 110, 253, 0.1); }
    .bg-warning-light { background-color: rgba(255, 193, 7, 0.1); }
    .bg-info-light { background-color: rgba(13, 202, 240, 0.1); }
    .icon-circle { width: 70px; height: 70px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
    .quote-card { background: linear-gradient(135deg, rgba(13,110,253,0.08), rgba(13,202,240,0.08)); border-left: 4px solid #0d6efd !important; }
    .quote-card.loading { opacity: 0.5; }
</style>

<script>
    (function () {
        const btn = document.getElementById('quote-refresh');
        if (!btn) return;

        const card = document.getElementById('quote-card');
        const contentEl = document.getElementById('quote-content');
        const authorEl = document.getElementById('quote-author');

        btn.addEventListener('click', async () => {
            btn.disabled = true;
            card.classList.add('loading');
            try {
                const res = await fetch('/api/quotes/random', {
                    headers: { 'Accept': 'application/json' },
                    cache: 'no-store'
                });
                if (!res.ok) throw new Error('HTTP ' + res.status);
                const data = await res.json();
                contentEl.textContent = '\u201E' + data.content + '\u201D';
                authorEl.textContent = data.author || 'Nieznany autor';
            } catch (err) {
                console.error('Nie udało się pobrać cytatu:', err);
                authorEl.textContent = 'Nie udało się pobrać nowego cytatu – spróbuj jeszcze raz.';
            } finally {
                card.classList.remove('loading');
                btn.disabled = false;
            }
        });
    })();
</script>