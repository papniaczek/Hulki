@{
    ViewData["Title"] = "Logowanie";
}

@{
    var hasError = !ViewData.ModelState.IsValid;
    var inputClass = hasError ? "form-control form-control-lg is-invalid" : "form-control form-control-lg";
}

<style>
    main.pb-3 {
        padding-bottom: 0 !important;
    }
</style>

<div class="container mt-4 text-light">
    <div class="row justify-content-center" style="min-height: 76vh; align-items: center;">
        <div class="col-md-5">
            <div class="login-card card border-0 rounded-4 shadow-lg" style="background-color: #1b1b22;">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <div class="login-icon-wrapper mx-auto mb-3">
                            <i class="bi bi-lock-fill text-primary fs-3"></i>
                        </div>
                        <h3 class="text-light fw-bold" style="user-select: none; letter-spacing: 1px;">ZALOGUJ SIĘ</h3>
                        <p class="text-muted small mb-0">Wróć do swojego konta</p>
                    </div>

                    <form asp-controller="Account" asp-action="Login" method="post">
                        <div class="mb-4">
                            <label class="form-label text-muted small text-uppercase fw-bold" style="user-select: none; letter-spacing: 0.5px;">Email</label>
                            <input type="email" name="email" class="form-control form-control-lg bg-dark border-secondary text-light rounded-3" required placeholder="twoj@email.com" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label text-muted small text-uppercase fw-bold" style="user-select: none; letter-spacing: 0.5px;">Hasło</label>
                            <input type="password" name="password" class="form-control form-control-lg bg-dark border-secondary text-light rounded-3" required placeholder="••••••••" />
                            @if (hasError)
                            {
                                <div class="invalid-feedback d-block mt-2">
                                    <i class="bi bi-exclamation-circle me-1"></i>Nieprawidłowy email lub hasło.
                                </div>
                            }
                        </div>
                        <button type="submit" class="btn btn-login w-100 fw-bold py-3 rounded-3 mt-2" style="background: linear-gradient(135deg, #46CC5E 0%, #2eb34d 100%); color: #fff; border: none; transition: all 0.3s ease;">Zaloguj</button>
                    </form>
                </div>
            </div>
            <div class="text-center mt-4">
                <span class="text-muted small">Nie masz konta? </span>
                <a asp-controller="Account" asp-action="Register" class="text-primary fw-bold text-decoration-none" style="font-size: 0.95rem; transition: all 0.2s ease;" onmouseover="this.style.textShadow='0 0 10px rgba(70, 204, 94, 0.5)';" onmouseout="this.style.textShadow='none';">Zarejestruj się</a>
            </div>
        </div>
    </div>
</div>

<style>
    .login-card {
        border: 1px solid rgba(70, 204, 94, 0.15);
        transition: all 0.3s ease;
    }

    .login-icon-wrapper {
        width: 60px;
        height: 60px;
        border-radius: 16px;
        background: rgba(70, 204, 94, 0.1);
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.3s ease;
    }

    .form-control:focus {
        background-color: #1f1f27 !important;
        border-color: #46CC5E !important;
        color: #fff !important;
        box-shadow: 0 0 10px rgba(70, 204, 94, 0.2);
    }

    .form-control::placeholder {
        color: rgba(255, 255, 255, 0.5) !important;
    }

    .btn-login:hover {
        box-shadow: 0 0 20px rgba(70, 204, 94, 0.5);
        transform: translateY(-2px);
    }
</style>