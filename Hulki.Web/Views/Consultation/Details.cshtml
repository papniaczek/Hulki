@model Hulki.Web.Models.Consultation

@{
    ViewData["Title"] = "Karta Wizyty";
    bool isMedicalStaff = ViewBag.IsTherapist ?? false;

    string statusLabel = Model.StatusId switch
    {
        1 => "Zaplanowana",
        2 => "Zakończona",
        3 => "Odwołana",
        _ => Model.Status?.Name ?? "?"
    };
    string statusClass = Model.StatusId switch
    {
        1 => "status-planned",
        2 => "status-done",
        3 => "status-cancelled",
        _ => "status-unknown"
    };
    string statusIcon = Model.StatusId switch
    {
        1 => "bi-clock",
        2 => "bi-check-circle-fill",
        3 => "bi-x-circle-fill",
        _ => "bi-question-circle"
    };

    bool hasDetails = Model.Details != null && (
        !string.IsNullOrWhiteSpace(Model.Details.MedicalHistory) ||
        !string.IsNullOrWhiteSpace(Model.Details.Diagnosis) ||
        !string.IsNullOrWhiteSpace(Model.Details.Recommendations));
}

<div class="container mt-4 mb-5">

    <a asp-action="Index" class="back-link text-decoration-none d-inline-flex align-items-center gap-2 mb-4">
        <i class="bi bi-arrow-left"></i>
        <span class="small text-uppercase fw-bold" style="letter-spacing: 1px;">Powrót do listy</span>
    </a>

    <div class="details-header-card rounded-4 p-4 p-md-5 mb-4 position-relative overflow-hidden">
        <div
            class="position-relative z-1 d-flex flex-column flex-md-row justify-content-between align-items-md-start gap-3">
            <div>
                <h3 class="text-primary fw-bold mb-1 text-uppercase" style="letter-spacing: 1px;">
                    <i class="bi bi-file-earmark-medical me-2"></i>Karta Wizyty
                </h3>
                <p class="text-muted small mb-3 font-monospace">ID: @Model.Id</p>

                <div class="d-flex flex-wrap gap-4">
                    <div>
                        <div class="field-label"><i class="bi bi-calendar3 me-1"></i>Data</div>
                        <div class="text-light fw-bold">@Model.StartTime.ToString("dd.MM.yyyy")</div>
                    </div>
                    <div>
                        <div class="field-label"><i class="bi bi-clock me-1"></i>Godziny</div>
                        <div class="text-light fw-bold">@Model.StartTime.ToString("HH:mm") &ndash;
                            @Model.EndTime.ToString("HH:mm")</div>
                        </div>
                        <div>
                            <div class="field-label"><i class="bi bi-person me-1"></i>Pacjent</div>
                            <div class="text-light fw-bold">@(Model.Patient?.FirstName + " " + Model.Patient?.LastName)
                            </div>
                        </div>
                        <div>
                            <div class="field-label"><i class="bi bi-person-badge me-1"></i>Terapeuta</div>
                            <div class="text-light fw-bold">@(Model.Therapist?.FirstName + " " + Model.Therapist?.LastName)
                            </div>
                        </div>
                    </div>
                </div>
                <div>
                    <span class="badge status-badge @statusClass px-3 py-2 rounded-pill fs-6">
                        <i class="bi @statusIcon me-1"></i>@statusLabel
                    </span>
                    <div class="mt-3">
                        <a asp-action="DownloadPdf" asp-route-id="@Model.Id"
                           class="btn btn-sm btn-outline-light rounded-pill">
                            <i class="bi bi-file-earmark-pdf me-1"></i>Pobierz PDF
                        </a>
                    </div>
                </div>
            </div>
            <div class="details-header-glow"></div>
        </div>

        <div class="row g-4">
            <div class="@(isMedicalStaff ? "col-12 col-lg-6" : "col-12")">
                <div class="doc-card rounded-4 p-4 h-100">
                    <h5 class="fw-bold text-uppercase mb-4 pb-3 border-bottom border-secondary"
                        style="letter-spacing: 1px;">
                        <i class="bi bi-journal-medical me-2 text-primary"></i>Dokumentacja medyczna
                    </h5>

                    @if (!hasDetails)
                    {
                        <div class="empty-doc text-center py-4">
                            <i class="bi bi-file-earmark-x fs-2 text-muted d-block mb-2"></i>
                            <p class="text-muted mb-0">
                                @if (isMedicalStaff)
                                {
                                    <span>Brak dokumentacji. Uzupełnij kartę korzystając z formularza.</span>
                                }
                                else
                                {
                                    <span>Terapeuta nie uzupełnił jeszcze dokumentacji tej wizyty.</span>
                                }
                            </p>
                        </div>
                    }
                    else
                    {
                        <div class="doc-section mb-4">
                            <div class="field-label"><i class="bi bi-chat-left-text me-1"></i>Wywiad i objawy</div>
                            <div class="doc-value">
                                @(string.IsNullOrWhiteSpace(Model.Details.MedicalHistory) ? "—" : Model.Details.MedicalHistory)
                            </div>
                        </div>

                        <div class="doc-section mb-4">
                            <div class="field-label"><i class="bi bi-activity me-1"></i>Rozpoznanie / Diagnoza</div>
                            <div class="doc-value doc-value--diagnosis">
                                @(string.IsNullOrWhiteSpace(Model.Details.Diagnosis) ? "—" : Model.Details.Diagnosis)
                            </div>
                        </div>

                        <div class="doc-section mb-0">
                            <div class="field-label"><i class="bi bi-journal-text me-1"></i>Zalecenia i plan leczenia</div>
                            <div class="doc-value doc-value--recommendations">
                                @(string.IsNullOrWhiteSpace(Model.Details.Recommendations) ? "—" :
                            Model.Details.Recommendations)
                            </div>
                        </div>

                        @if (isMedicalStaff && !string.IsNullOrWhiteSpace(Model.Details?.InternalNotes))
                        {
                            <div class="internal-notes rounded-3 p-3 mt-4">
                                <div class="field-label mb-2"><i class="bi bi-eye-slash-fill me-1 text-warning"></i>Notatki
                                    wewnętrzne (ukryte przed pacjentem)</div>
                                    <div class="text-light small">@Model.Details.InternalNotes</div>
                                </div>
                            }
                        }
                    </div>
                </div>

                @if (isMedicalStaff)
                {
                    <div class="col-12 col-lg-6">
                        <div class="doc-card rounded-4 p-4 h-100">
                            <h5 class="fw-bold text-uppercase mb-4 pb-3 border-bottom border-secondary"
                                style="letter-spacing: 1px;">
                                <i class="bi bi-pencil-square me-2 text-primary"></i>Edycja dokumentacji
                            </h5>

                            <form asp-action="SaveDetails" method="post">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="consultationId" value="@Model.Id" />

                                <div class="mb-3">
                                    <label class="field-label"><i class="bi bi-chat-left-text me-1"></i>Wywiad i objawy</label>
                                    <textarea name="detailsFromForm.MedicalHistory" class="form-control dark-input" rows="3"
                                              placeholder="Opisz objawy i wywiad pacjenta...">@Model.Details?.MedicalHistory</textarea>
                                </div>

                                <div class="mb-3">
                                    <label class="field-label"><i class="bi bi-activity me-1"></i>Diagnoza</label>
                                    <textarea name="detailsFromForm.Diagnosis" class="form-control dark-input" rows="2"
                                              placeholder="Rozpoznanie kliniczne...">@Model.Details?.Diagnosis</textarea>
                                </div>

                                <div class="mb-3">
                                    <label class="field-label"><i class="bi bi-journal-text me-1"></i>Zalecenia</label>
                                    <textarea name="detailsFromForm.Recommendations" class="form-control dark-input" rows="3"
                                              placeholder="Plan leczenia i zalecenia...">@Model.Details?.Recommendations</textarea>
                                </div>

                                <div class="mb-4">
                                    <label class="field-label" style="color: rgba(245, 158, 11, 0.7);">
                                        <i class="bi bi-eye-slash-fill me-1"></i>Notatki wewnętrzne <span
                                        class="fw-normal opacity-75">(ukryte przed pacjentem)</span>
                                    </label>
                                    <textarea name="detailsFromForm.InternalNotes" class="form-control dark-input" rows="2"
                                              placeholder="Tylko dla personelu...">@Model.Details?.InternalNotes</textarea>
                                </div>

                                <div class="text-end">
                                    <button type="submit" class="btn btn-custom-success fw-bold rounded-pill px-5 text-uppercase"
                                            style="letter-spacing: 1px;">
                                        <i class="bi bi-floppy me-2"></i>Zapisz kartę
                                    </button>
                                </div>
                            </form>
                        </div>
                    </div>
                }
            </div>
        </div>

        <style>
            .back-link {
                color: rgba(255, 255, 255, 0.45);
                transition: color 0.2s ease;
            }

            .back-link:hover {
                color: #46CC5E;
            }

    
            .details-header-card {
                background: linear-gradient(135deg, #1b1b22 0%, #17171c 100%);
                border: 1px solid rgba(70, 204, 94, 0.15);
                box-shadow: 0 10px 30px rgba(0, 0, 0, 0.4);
            }

            .details-header-glow {
                position: absolute;
                top: -50px;
                right: -50px;
                width: 240px;
                height: 240px;
                background: radial-gradient(circle, rgba(70, 204, 94, 0.08) 0%, transparent 70%);
                border-radius: 50%;
                z-index: 0;
                pointer-events: none;
            }

    
            .status-badge {
                font-size: 0.8rem;
                font-weight: 600;
                letter-spacing: 0.5px;
            }

            .status-planned {
                background: rgba(70, 204, 94, 0.12);
                color: #46CC5E;
                border: 1px solid rgba(70, 204, 94, 0.3);
            }

            .status-done {
                background: rgba(13, 110, 253, 0.12);
                color: #6ea8fe;
                border: 1px solid rgba(13, 110, 253, 0.3);
            }

            .status-cancelled {
                background: rgba(218, 41, 46, 0.12);
                color: #f87171;
                border: 1px solid rgba(218, 41, 46, 0.3);
            }

    
            .doc-card {
                background: #1b1b22;
                border: 1px solid rgba(255, 255, 255, 0.05);
            }

            .field-label {
                font-size: 0.72rem;
                font-weight: 700;
                letter-spacing: 1px;
                text-transform: uppercase;
                color: rgba(255, 255, 255, 0.4);
                margin-bottom: 6px;
                display: block;
            }

            .doc-value {
                background: rgba(0, 0, 0, 0.25);
                border: 1px solid rgba(255, 255, 255, 0.06);
                border-radius: 10px;
                padding: 12px 14px;
                color: #d0d0d8;
                font-size: 0.92rem;
                line-height: 1.6;
                white-space: pre-wrap;
            }

            .doc-value--diagnosis {
                border-left: 3px solid rgba(218, 41, 46, 0.4);
                color: #f4a0a0;
            }

            .doc-value--recommendations {
                border-left: 3px solid rgba(70, 204, 94, 0.4);
                color: #a0d8a0;
            }

            .internal-notes {
                background: rgba(245, 158, 11, 0.06);
                border: 1px solid rgba(245, 158, 11, 0.2);
            }

    
            .dark-input {
                background-color: #13131a !important;
                border: 1px solid rgba(255, 255, 255, 0.1) !important;
                color: #f0f0f0 !important;
                border-radius: 10px !important;
                transition: border-color 0.2s ease, box-shadow 0.2s ease;
                resize: vertical;
            }

            .dark-input:focus {
                border-color: rgba(70, 204, 94, 0.5) !important;
                box-shadow: 0 0 0 3px rgba(70, 204, 94, 0.1) !important;
                outline: none !important;
            }

            .dark-input::placeholder {
                color: rgba(255, 255, 255, 0.18);
            }

    
            .btn-custom-success {
                background-color: rgba(70, 204, 94, 0.10);
                color: #46CC5E;
                border: 1px solid rgba(70, 204, 94, 0.3);
                transition: all 0.3s ease;
            }

            .btn-custom-success:hover {
                background-color: #46CC5E;
                color: #17171C;
                box-shadow: 0 0 15px rgba(70, 204, 94, 0.4);
            }

            .empty-doc {
                border: 1px dashed rgba(255, 255, 255, 0.1);
                border-radius: 12px;
                padding: 2rem;
            }
        </style>
