@model Hulki.Web.Models.Consultation

@{
    ViewData["Title"] = "Szczegóły Wizyty Lekarskiej";

    // Używamy flagi boolowskiej przekazanej z kontrolera
    bool isMedicalStaff = ViewBag.IsTherapist ?? false;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4 pb-2 border-bottom">
        <h2><i class="bi bi-file-earmark-medical"></i> Karta Wizyty #@Model.Id</h2>
        <div>
            <span class="badge @(Model.StatusId == 1 ? "bg-warning" : "bg-success") fs-6">
                @(Model.StatusId == 1 ? "Zaplanowana" : "Zakończona")
            </span>
            <a asp-action="Index" class="btn btn-outline-secondary ms-2">Powrót do listy</a>
        </div>
    </div>

    <div class="row">
        <div class="col-md-4 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-primary text-white">
                    <h5 class="card-title mb-0">Podstawowe informacje</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex flex-column px-0">
                            <strong>Rozpoczęcie:</strong>
                            <span>@Model.StartTime.ToString("dd.MM.yyyy HH:mm")</span>
                        </li>
                        <li class="list-group-item d-flex flex-column px-0">
                            <strong>Zakończenie:</strong>
                            <span>@Model.EndTime.ToString("dd.MM.yyyy HH:mm")</span>
                        </li>
                        <li class="list-group-item d-flex flex-column px-0">
                            <strong>Pacjent:</strong>
                            <span class="text-muted small">
                                @(Model.Patient?.FirstName + " " + Model.Patient?.LastName)
                            </span>

                            <strong>Terapeuta:</strong>
                            <span class="text-muted small">
                                @(Model.Therapist?.FirstName + " " + Model.Therapist?.LastName)
                            </span>
                        </li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-md-8 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-header bg-dark text-white">
                    <h5 class="card-title mb-0">Dokumentacja Medyczna</h5>
                </div>
                <div class="card-body">
                    @if (Model.Details == null || (
                             string.IsNullOrWhiteSpace(Model.Details.MedicalHistory) &&
                             string.IsNullOrWhiteSpace(Model.Details.Diagnosis) &&
                             string.IsNullOrWhiteSpace(Model.Details.Recommendations)))
                    {
                        <div class="alert alert-warning mb-0" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i> Brak uzupełnionych szczegółów dla tej wizyty.
                        </div>
                    }
                    else
                    {
                        <div class="mb-4">
                            <h6 class="text-muted text-uppercase fw-bold"><i class="bi bi-chat-left-text"></i> Wywiad lekarski i objawy</h6>
                            <p class="p-3 bg-light rounded border">
                                @(string.IsNullOrWhiteSpace(Model.Details.MedicalHistory) ? "Brak danych" : Model.Details.MedicalHistory)
                            </p>
                        </div>

                        <div class="mb-4">
                            <h6 class="text-muted text-uppercase fw-bold"><i class="bi bi-activity"></i> Rozpoznanie / Diagnoza</h6>
                            <p class="p-3 bg-light rounded border fw-semibold text-danger">
                                @(string.IsNullOrWhiteSpace(Model.Details.Diagnosis) ? "Brak diagnozy" : Model.Details.Diagnosis)
                            </p>
                        </div>

                        <div class="mb-4">
                            <h6 class="text-muted text-uppercase fw-bold"><i class="bi bi-journal-text"></i> Zalecenia i plan leczenia</h6>
                            <p class="p-3 bg-light rounded border text-success">
                                @(string.IsNullOrWhiteSpace(Model.Details.Recommendations) ? "Brak szczególnych zaleceń" : Model.Details.Recommendations)
                            </p>
                        </div>

                        @if (isMedicalStaff)
                        {
                            <div class="mt-4 pt-3 border-top">
                                <div class="alert alert-info mb-0">
                                    <h6 class="alert-heading fw-bold"><i class="bi bi-eye-slash-fill"></i> Notatki wewnętrzne (Widoczne tylko dla personelu)</h6>
                                    <hr>
                                    <p class="mb-0 text-dark">
                                        @(string.IsNullOrWhiteSpace(Model.Details.InternalNotes) ? "Brak wewnętrznych adnotacji." : Model.Details.InternalNotes)
                                    </p>
                                </div>
                            </div>
                        }
                    }
                </div>

                @if (isMedicalStaff)
                {
                    <div class="card-footer bg-light p-4 border-top">
                        <h5 class="mb-3"><i class="bi bi-pencil-square"></i> Edycja dokumentacji medycznej</h5>
                        <form asp-action="SaveDetails" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="consultationId" value="@Model.Id"/>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Wywiad i objawy</label>
                                <textarea name="detailsFromForm.MedicalHistory" class="form-control" rows="3">@Model.Details?.MedicalHistory</textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Diagnoza</label>
                                <textarea name="detailsFromForm.Diagnosis" class="form-control" rows="2">@Model.Details?.Diagnosis</textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Zalecenia</label>
                                <textarea name="detailsFromForm.Recommendations" class="form-control" rows="3">@Model.Details?.Recommendations</textarea>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold text-danger"><i class="bi bi-lock-fill"></i> Notatki wewnętrzne (Ukryte przed pacjentem)</label>
                                <textarea name="detailsFromForm.InternalNotes" class="form-control" rows="2">@Model.Details?.InternalNotes</textarea>
                            </div>

                            <div class="text-end">
                                <button type="submit" class="btn btn-primary">Zapisz zmiany w karcie</button>
                            </div>
                        </form>
                    </div>
                }
            </div>
        </div>
    </div>
</div>