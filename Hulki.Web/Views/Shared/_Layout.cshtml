@using Microsoft.AspNetCore.Identity
@using Hulki.Web.Models
@inject UserManager<AppUser> UserManager

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hulki</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hulki.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <header>
        <nav
            class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-dark-subtle border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index"
                   style="user-select: none;">HULKI</a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1" style="align-items: center">
                        <li class="nav-item">
                            <a class="nav-link text-light" asp-controller="Home" asp-action="Index"
                               style="user-select: none;">Start</a>
                        </li>

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Forum" asp-action="Index"
                                   style="user-select: none;">Forum</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="Store" asp-action="Index"
                                   style="user-select: none;">Sklep</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link text-light" asp-controller="TherapyGroup" asp-action="Index"
                                   style="user-select: none;">Grupy Wsparcia</a>
                            </li>

                            @* @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-danger fw-bold" href="#" id="adminDropdown"
                        role="button" data-bs-toggle="dropdown">
                                    Panel Terapeuty
                                </a>
                                <ul class="dropdown-menu border-0 shadow">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Index">Statystyki Kliniki</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="TherapyGroup" asp-action="Index">Zarządzaj Grupami</a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="Patients">Lista Pacjentów</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Admin" asp-action="ShopItems">Przedmioty w sklepie</a>
                                    </li>
                                </ul>
                            </li>
                        } *@
                        }
                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (User.Identity.IsAuthenticated)
                        {
                            var currentUser = await UserManager.GetUserAsync(User);
                            var displayName = currentUser?.FirstName ?? User.Identity.Name;

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle text-light" href="#" id="profileDropdown" role="button"
                                   data-bs-toggle="dropdown">
                                    @displayName
                                </a>
                                <ul class="dropdown-menu border-0 shadow">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Profile" asp-action="Index">Moje konto</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Patient" asp-action="Index">Moje
                                            statystyki</a>
                                        </li>
                                        @if (User.IsInRole("Admin"))
                                        {
                                            <li>
                                                <a class="dropdown-item custom-therapist-link" asp-controller="Admin"
                                                   asp-action="Index">Panel Terapeuty</a>
                                            </li>
                                        }
                                    </ul>
                                </li>
                                <li class="nav-item">
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                        <button type="submit" class="btn btn-link nav-link text-danger">Wyloguj</button>
                                    </form>
                                </li>
                            }
                    else
                            {
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-controller="Account"
                                       asp-action="Register">Rejestracja</a>
                                </li>
                                <li class="nav-item">
                                    <a class="nav-link text-light" asp-controller="Account" asp-action="Login">Logowanie</a>
                                </li>
                            }
                        </ul>
                    </div>
                </div>
            </nav>
        </header>
        <div class="container">
            <main role="main" class="pb-3">
                @RenderBody()
            </main>
        </div>

        <footer class="border-top footer text-muted">
            <div class="container">
                &copy; 2026 - HULKI - <a asp-area="" asp-controller="Home" asp-action="Privacy">Polityka Prywatności</a>
            </div>
        </footer>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>

</html>