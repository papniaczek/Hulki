@using Microsoft.AspNetCore.Identity
@using Hulki.Web.Models
@inject UserManager<AppUser> UserManager

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>@ViewData["Title"] - Hulki</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css"/>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true"/>
    <link rel="stylesheet" href="~/Hulki.Web.styles.css" asp-append-version="true"/>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        #flash-message {
            position: fixed;
            bottom: 5%;
            left: 50%;
            transform: translateX(-50%) translateY(30px);
            z-index: 1080;
            width: auto;
            max-width: 460px;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.35s ease, transform 0.35s ease;
        }
    
        #flash-message.show {
            opacity: 1;
            transform: translateX(-50%) translateY(0);
        }
    
        .flash-bubble {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.65rem;
            background: rgba(27, 27, 34, 0.98);
            color: #f8f9fa;
            border-radius: 18px;
            padding: 1rem 1.3rem;
            box-shadow: 0 18px 35px rgba(0, 0, 0, 0.28);
            border: 1px solid rgba(255, 255, 255, 0.08);
            font-weight: 500;
            line-height: 1.3;
        }
    
        .flash-bubble.success {
            border-color: rgba(70, 204, 94, 0.45);
        }
    
        .flash-bubble.error {
            border-color: rgba(218, 41, 46, 0.45);
        }
    
    
        .glass-dropdown {
            background: rgba(31, 41, 55, 0.95) !important;
            border: 1px solid rgba(255, 255, 255, 0.08) !important;
            border-radius: 18px !important;
            box-shadow: 0 20px 40px rgba(0, 0, 0, .35), 0 0 0 1px rgba(255, 255, 255, .03) !important;
            padding: 12px !important;
            margin-top: 12px !important;
            backdrop-filter: blur(12px);
        }
    
        .glass-dropdown::before {
            content: "";
            position: absolute;
            top: -7px;
            right: 18px;
            width: 14px;
            height: 14px;
            background: rgba(31, 41, 55, 0.95);
            border-top: 1px solid rgba(255, 255, 255, .08);
            border-left: 1px solid rgba(255, 255, 255, .08);
            transform: rotate(45deg);
            z-index: -1;
        }
    
        .glass-dropdown .dropdown-item {
            color: #e5e7eb !important;
            border-radius: 12px !important;
            padding: 10px 14px !important;
            transition: all .2s ease !important;
            display: flex;
            align-items: center;
        }
    
        .glass-dropdown .dropdown-item:hover {
            background: rgba(99, 102, 241, .15) !important;
            color: #ffffff !important;
        }
    
        .glass-dropdown .dropdown-item i.menu-icon {
            font-size: 1.15rem;
            margin-right: 12px;
            width: 20px;
            text-align: center;
        }
    
        .glass-dropdown .dropdown-divider {
            border-color: rgba(255, 255, 255, .08) !important;
            margin: 8px 0 !important;
        }
    
    
        .profile-dropdown-menu {
            min-width: 260px !important;
        }
    
        .btn-logout:hover {
            background: rgba(220, 53, 69, 0.15) !important;
            color: #ff6b6b !important;
        }
    
    
        #notificationList {
            width: 340px !important;
            max-height: 450px !important;
            overflow-y: auto !important;
        }
    
        .notification-header {
            border-color: rgba(255, 255, 255, .08) !important;
            padding: 12px 0;
            margin-bottom: 12px;
        }
    
        #notificationList::-webkit-scrollbar {
            width: 6px;
        }
    
        #notificationList::-webkit-scrollbar-track {
            background: transparent;
        }
    
        #notificationList::-webkit-scrollbar-thumb {
            background: rgba(255, 255, 255, .15);
            border-radius: 20px;
        }
    
        #notificationList::-webkit-scrollbar-thumb:hover {
            background: rgba(255, 255, 255, .25);
        }
    
        .navbar .notification-btn {
            position: relative;
            color: rgba(255, 255, 255, 0.75) !important;
            background: transparent !important;
            border: none !important;
            padding: 8px !important;
            border-radius: 12px !important;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            transition: all 0.25s ease-in-out !important;
            text-decoration: none !important;
        }
    
        .navbar .notification-btn:hover {
            color: #ffffff !important;
            transform: translateY(-1px) scale(1.03) !important;
            box-shadow: 0 0 0 1px rgba(255, 255, 255, 0.08), 0 8px 24px rgba(0, 0, 0, 0.35);
        }
    
        .navbar .notification-btn i {
            font-size: 17px;
            transition: transform 0.2s ease;
        }
    
        .navbar .notification-btn:hover i {
            transform: scale(1.08);
        }
    
        #notificationBadge {
            font-size: 10px;
            border-radius: 999px;
            width: 20px;
            height: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
        }
    
        .notification-unread {
            background: rgba(99, 102, 241, .08) !important;
        }
    
        .unread-dot {
            width: 8px;
            height: 8px;
            background-color: #6366f1;
            border-radius: 50%;
            display: inline-block;
            box-shadow: 0 0 8px rgba(99, 102, 241, 0.6);
        }
    
        #notificationBadge:not(.d-none) {
            animation: pulse 1.2s infinite;
        }
    
        @@keyframes pulse {
            0% {
                transform: scale(1);
                opacity: 1;
            }
    
            50% {
                transform: scale(1.2);
                opacity: 0.7;
            }
    
            100% {
                transform: scale(1);
                opacity: 1;
            }
        }
    </style>
</head>

<body>
@if (TempData["SuccessMessage"] != null || TempData["ErrorMessage"] != null)
{
    <div id="flash-message">
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="flash-bubble success">
                <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
            </div>
        }
        else if (TempData["ErrorMessage"] != null)
        {
            <div class="flash-bubble error">
                <i class="bi bi-exclamation-triangle-fill"></i> @TempData["ErrorMessage"]
            </div>
        }
    </div>
}
<header>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-dark-subtle mb-3 custom-navbar-gradient-border">
        <div class="container" style="padding: 0 21px;">
            <a class=" navbar-brand" asp-controller="Home" asp-action="Index" style="user-select: none;">
                <img src="~/graphics/HULKI.svg" alt="HULKI Logo" class="navbar-brand" style="height: 60px; width: auto; margin-right: 25px;"/>
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1" style="align-items: center">
                    <li class="nav-item">
                        <a class="nav-link text-light text-uppercase fw-bold" asp-controller="Forum" asp-action="Index" style="user-select: none;">
                            FORUM SPOŁECZNOŚCI
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-light text-uppercase fw-bold" asp-controller="Store" asp-action="Index" style="user-select: none;">
                            Sklep nagród
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link text-light text-uppercase fw-bold" asp-controller="TherapyGroup" asp-action="Index" style="user-select: none;">
                            Grupy wsparcia
                        </a>
                    </li>
                </ul>

                <ul class="navbar-nav ms-auto align-items-center">
                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item dropdown ms-3 me-2 d-flex">
                            <a class="position-relative notification-btn" href="#" id="notificationDropdown" role="button" data-bs-toggle="dropdown">
                                <i class="bi bi-bell-fill fs-6"></i>
                                <span id="notificationBadge" class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger d-none">0</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow glass-dropdown" aria-labelledby="notificationDropdown" id="notificationList">
                                <li class="px-3 py-2 notification-header border-bottom border-secondary">
                                    <div class="d-flex justify-content-between align-items-center">
                                        <div>
                                            <div class="fw-semibold text-white">Powiadomienia</div>
                                            <small class="text-muted">Najnowsze aktywności</small>
                                        </div>
                                        <button class="btn btn-sm btn-outline-primary" onclick="markAllAsRead(); return false;" title="Zaznacz wszystko jako przeczytane">
                                            <i class="bi bi-check-all"></i>
                                        </button>
                                    </div>
                                </li>
                                <div id="notificationItems">
                                    <li>
                                        <span class="dropdown-item text-muted justify-content-center">Ładowanie...</span>
                                    </li>
                                </div>
                            </ul>
                        </li>

                        var currentUser = await UserManager.GetUserAsync(User);
                        var displayName = currentUser?.FirstName ?? User.Identity.Name;

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-light fw-bold" href="#" id="profileDropdown" role="button" data-bs-toggle="dropdown">
                                <span class="nav-user-name text-primary">@displayName</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow glass-dropdown profile-dropdown-menu" aria-labelledby="profileDropdown">

                                <li class="px-3 py-2 border-bottom border-secondary mb-2">
                                    <div class="fw-bold text-white mb-0">Witaj, @displayName!</div>
                                    <small class="text-muted d-block">Zarządzaj swoim profilem</small>
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Index">
                                        <i class="bi bi-person-circle menu-icon text-primary"></i> Moje konto
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Patient" asp-action="Index">
                                        <i class="bi bi-bar-chart-line menu-icon text-info"></i> Moje statystyki
                                    </a>
                                </li>

                                <li>
                                    <hr class="dropdown-divider">
                                </li>

                                <li>
                                    <a class="dropdown-item" asp-controller="Consultation" asp-action="Index">
                                        <i class="bi bi-clipboard2-pulse menu-icon text-success"></i> Moje konsultacje
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="TherapyGoal" asp-action="Index">
                                        <i class="bi bi-bullseye menu-icon text-warning"></i> Cele terapeutyczne
                                    </a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Survey" asp-action="Index">
                                        <i class="bi bi-ui-radios menu-icon text-light"></i> Kwestionariusze
                                    </a>
                                </li>

                                @if (User.IsInRole("Admin") || User.IsInRole("Terapeuta"))
                                {
                                    <li>
                                        <hr class="dropdown-divider">
                                    </li>
                                    <li>
                                        <a class="dropdown-item fw-semibold" asp-controller="Admin" asp-action="Index" style="color: #c084fc !important;">
                                            <i class="bi bi-shield-lock-fill menu-icon"></i> Panel Terapeuty
                                        </a>
                                    </li>
                                }

                                <li>
                                    <hr class="dropdown-divider">
                                </li>

                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline m-0 p-0">
                                        <button type="submit" class="dropdown-item btn-logout w-100 text-danger" style="border: none; background: transparent; text-align: left;">
                                            <i class="bi bi-box-arrow-right menu-icon text-danger"></i> Wyloguj się
                                        </button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        if (ViewContext.RouteData.Values["Action"]?.ToString() != "Login" && ViewContext.RouteData.Values["Action"]?.ToString() != "Register")
                        {
                            <li class="nav-item">
                                <a class="nav-link custom-login-button" asp-controller="Account" asp-action="Login">Zaloguj się</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light fw-bold border text-uppercase" style="font-size: 0.875rem;" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-arrow-left me-2"></i>Wróć do strony głównej
                                </a>
                            </li>
                        }
                    }
                </ul>
            </div>
        </div>
    </nav>
</header>
<div class="container">
    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="footer text-muted custom-footer-gradient-border">
    <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center py-3">
        <div>
            &copy; 2026 - HULKI - <a asp-area="" asp-controller="Home" asp-action="Privacy">Polityka Prywatności</a>
        </div>
    </div>
</footer>
<button id="scrollTopBtn" class="scroll-to-top-btn shadow" aria-label="Wróć na górę">
    <i class="bi bi-arrow-up"></i>
</button>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
<script>
    document.addEventListener('DOMContentLoaded', function () {
        var flash = document.getElementById('flash-message');
        if (!flash) return;

        flash.classList.add('show');
        setTimeout(function () {
            flash.classList.remove('show');
        }, 5000);
    });
</script>
@await RenderSectionAsync("Scripts", required: false)

@if (User.Identity.IsAuthenticated)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            fetchNotifications();
            setInterval(fetchNotifications, 30000);
        });

        function fetchNotifications() {
            fetch('/Notification/GetMyNotifications')
                .then(response => response.json())
                .then(data => {
                    const badge = document.getElementById('notificationBadge');
                    const count = data.count ?? 0;

                    if (count > 0) {
                        badge.textContent = count;
                        badge.classList.remove('d-none');
                    } else {
                        badge.classList.add('d-none');
                        badge.textContent = "0";
                    }

                    const items = document.getElementById('notificationItems');
                    items.innerHTML = '';

                    if (!data.notifications || data.notifications.length === 0) {
                        items.innerHTML = '<li><span class="dropdown-item text-muted justify-content-center">Brak nowych powiadomień</span></li>';
                        return;
                    }

                    data.notifications.forEach(n => {
                        const isUnread = !n.isRead ? 'notification-unread' : '';
                        const dot = !n.isRead ? '<span class="unread-dot"></span>' : '';

                        const li = document.createElement('li');
                        li.className = "mb-1";
                        li.innerHTML = `
                                    <a class="dropdown-item text-wrap ${isUnread} d-flex align-items-start"
                                       href="#" onclick="markAsRead('${n.id}', this); return false;">
                                        
                                        <div class="flex-grow-1">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <small class="text-muted" style="font-size: 0.75rem;">${new Date(n.createdAt).toLocaleString()}</small>
                                                ${dot}
                                            </div>
                                            <div class="text-light" style="font-size: 0.85rem; line-height: 1.4;">${n.content}</div>
                                        </div>
                                    </a>
                                `;
                        items.appendChild(li);
                    });
                });
        }

        function markAsRead(id, element) {
            fetch(`/Notification/MarkAsRead/${id}`, { method: 'POST' })
                .then(response => {
                    if (response.ok) {
                        element.classList.remove('notification-unread');
                        const dot = element.querySelector('.unread-dot');
                        if (dot) dot.remove();
                        fetchNotifications();
                    }
                });
        }

        function markAllAsRead() {
            fetch('/Notification/MarkAllAsRead', { method: 'POST' })
                .then(response => {
                    if (response.ok) {
                        fetchNotifications();
                    }
                });
        }
    </script>
}
</body>
</html>