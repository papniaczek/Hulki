@using Microsoft.AspNetCore.Identity
@using Hulki.Web.Models
@inject UserManager<AppUser> UserManager

<!DOCTYPE html>
<html lang="en" data-bs-theme="dark">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Hulki</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Hulki.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-light bg-dark-subtle mb-3 custom-navbar-gradient-border">
            <div class="container" style="padding: 0 21px;">
                <a class=" navbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/graphics/HULKI.svg" alt="HULKI Logo" class="navbar-brand"
                     style="height: 60px; width: auto; margin-right: 25px;" />
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                    aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1" style="align-items: center">

                    @if (User.Identity.IsAuthenticated)
                    {
                        <li class="nav-item">
                            <a class="nav-link text-light text-uppercase fw-bold" asp-controller="Forum"
                               asp-action="Index" style="user-select: none;">FORUM SPOŁECZNOŚCI</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light text-uppercase fw-bold" asp-controller="Store"
                               asp-action="Index" style="user-select: none;">Sklep nagród</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-light text-uppercase fw-bold" asp-controller="TherapyGroup"
                               asp-action="Index" style="user-select: none;">Grupy wsparcia</a>
                        </li>
                    }
                </ul>

                <ul class="navbar-nav ms-auto">
                    @if (User.Identity.IsAuthenticated)
                    {
                        var currentUser = await UserManager.GetUserAsync(User);
                        var displayName = currentUser?.FirstName ?? User.Identity.Name;

                        <li class="nav-item dropdown">
                            <a class="nav-link dropdown-toggle text-light fw-bold" href="#" id="profileDropdown"
                               role="button" data-bs-toggle="dropdown">
                                @displayName
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end border-0 shadow">
                                <li>
                                    <a class="dropdown-item" asp-controller="Profile" asp-action="Index">Moje konto</a>
                                </li>
                                <li>
                                    <a class="dropdown-item" asp-controller="Patient" asp-action="Index">Moje
                                        statystyki</a>
                                    </li>
                                    @if (User.IsInRole("Admin"))
                                    {
                                        <li>
                                            <a class="dropdown-item custom-therapist-link" asp-controller="Admin"
                                               asp-action="Index">Panel Terapeuty</a>
                                        </li>
                                    }
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                                            <button type="submit"
                                                    class="btn btn-link dropdown-item no-hover-bg">Wyloguj</button>
                                        </form>
                                    </li>
                                </ul>
                            </li>

                        }
                    else
                        {
                            <li class="nav-item">
                                <a class="nav-link text-light text-uppercase border fs-6" asp-controller="Account"
                                   asp-action="Login">Zaloguj się</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer text-muted custom-footer-gradient-border">
        <div class="container d-flex flex-column flex-md-row justify-content-between align-items-center py-3">
            <div class="container">
                &copy; 2026 - HULKI - <a asp-area="" asp-controller="Home" asp-action="Privacy">Polityka Prywatności</a>
            </div>
        </footer>
        <script src="~/lib/jquery/dist/jquery.min.js"></script>
        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
        <script src="~/js/site.js" asp-append-version="true"></script>
        @await RenderSectionAsync("Scripts", required: false)
    </body>

</html>