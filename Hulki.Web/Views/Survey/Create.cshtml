@{
    ViewData["Title"] = "Nowa Ankieta";
}

<div class="container mt-4 mb-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">

            <a asp-action="Index" class="back-link text-decoration-none d-inline-flex align-items-center gap-2 mb-4">
                <i class="bi bi-arrow-left"></i>
                <span class="small text-uppercase fw-bold" style="letter-spacing: 1px;">Powrót do listy</span>
            </a>

            <div class="create-card rounded-4 p-4 p-md-5">

                <div class="mb-4 pb-3 border-bottom border-secondary">
                    <h3 class="fw-bold text-primary mb-1 text-uppercase" style="letter-spacing: 1px;">
                        Nowa Ankieta
                    </h3>
                    <p class="text-muted small mb-0">
                        Wypełnij formularz, aby utworzyć kwestionariusz.
                    </p>
                </div>

                <form asp-action="Create" method="post">

                    <div class="mb-4">
                        <label class="field-label">
                            <i class="bi bi-card-heading me-1"></i>Tytuł ankiety
                        </label>
                        <input type="text"
                               name="title"
                               class="form-control dark-input"
                               required
                               placeholder="np. Wywiad wstępny"/>
                    </div>

                    <div class="mb-4">
                        <label class="field-label">
                            <i class="bi bi-list-check me-1"></i>Pytania (otwarte)
                        </label>

                        <div id="questionsContainer">
                            <input type="text"
                                   name="questions"
                                   class="form-control dark-input mb-2"
                                   required
                                   placeholder="Pytanie 1..."/>

                            <input type="text"
                                   name="questions"
                                   class="form-control dark-input mb-2"
                                   placeholder="Pytanie 2..."/>
                        </div>

                        <button type="button"
                                class="btn btn-ghost-cancel mt-2"
                                onclick="addQuestionField()">
                            <i class="bi bi-plus-circle me-1"></i>Dodaj kolejne pytanie
                        </button>
                    </div>

                    <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top border-secondary">
                        <a asp-action="Index" class="btn btn-ghost-cancel rounded-pill px-4">
                            <i class="bi bi-x me-1"></i>Anuluj
                        </a>

                        <button type="submit"
                                class="btn btn-custom-success fw-bold rounded-pill px-5 text-uppercase"
                                style="letter-spacing: 1px;">
                            <i class="bi bi-save me-2"></i>Zapisz
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

<script>
    function addQuestionField() {
        const container = document.getElementById('questionsContainer');

        const input = document.createElement('input');
        input.type = 'text';
        input.name = 'questions';
        input.className = 'form-control dark-input mb-2';
        input.placeholder = 'Kolejne pytanie...';

        container.appendChild(input);
    }
</script>

<style>
    .back-link {
        color: rgba(255, 255, 255, 0.45);
        transition: color 0.2s ease;
    }

    .back-link:hover {
        color: #46CC5E;
    }

    .create-card {
        background: #1b1b22;
        border: 1px solid rgba(70, 204, 94, 0.15);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.35);
    }

    .field-label {
        display: block;
        font-size: 0.78rem;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: rgba(255, 255, 255, 0.55);
        margin-bottom: 8px;
    }

    .dark-input {
        background-color: #13131a !important;
        border: 1px solid rgba(255, 255, 255, 0.1) !important;
        color: #f0f0f0 !important;
        border-radius: 10px !important;
        transition: border-color 0.2s ease, box-shadow 0.2s ease;
    }

    .dark-input:focus {
        border-color: rgba(70, 204, 94, 0.5) !important;
        box-shadow: 0 0 0 3px rgba(70, 204, 94, 0.1) !important;
        outline: none !important;
    }

    .dark-input::placeholder {
        color: rgba(255, 255, 255, 0.2);
    }

    .btn-custom-success {
        background-color: rgba(70, 204, 94, 0.10);
        color: #46CC5E;
        border: 1px solid rgba(70, 204, 94, 0.3);
        transition: all 0.3s ease;
    }

    .btn-custom-success:hover {
        background-color: #46CC5E;
        color: #17171C;
        box-shadow: 0 0 15px rgba(70, 204, 94, 0.4);
    }

    .btn-ghost-cancel {
        font-size: 0.85rem;
        font-weight: 600;
        color: rgba(255, 255, 255, 0.4);
        background: transparent;
        border: 1px solid rgba(255, 255, 255, 0.1);
        transition: all 0.2s ease;
    }

    .btn-ghost-cancel:hover {
        color: #fff;
        border-color: rgba(255, 255, 255, 0.25);
        background: rgba(255, 255, 255, 0.06);
    }
</style>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}